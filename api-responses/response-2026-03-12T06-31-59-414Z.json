  "gameCode": "<!doctype html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>撞车复活对决（AI对手）</title>\n<style>\n  html,body{\n    height:100%;\n    margin:0;\n    background:linear-gradient(180deg,#0b1220,#081426);\n    color:#fff;\n    font-family:Arial, Helvetica, sans-serif;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n  }\n  .wrap{\n    max-width:420px;\n    margin:12px auto;\n    padding:8px;\n    text-align:center;\n  }\n  canvas { max-width: 100%; height: auto; display: block; margin: 0 auto; }\n  .hud{\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:8px;\n    margin:8px 0;\n  }\n  .panel{\n    background:rgba(255,255,255,0.04);\n    padding:8px 10px;\n    border-radius:8px;\n    min-width:100px;\n    text-align:left;\n  }\n  .center{\n    text-align:center;\n    flex:1;\n  }\n  button{\n    background:#1e90ff;\n    color:#fff;\n    border:0;\n    padding:8px 12px;\n    border-radius:8px;\n    cursor:pointer;\n    font-weight:700;\n  }\n  .small{\n    font-size:12px;\n    opacity:0.9;\n  }\n  .overlay{\n    position:fixed;\n    left:0;right:0;top:0;bottom:0;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    pointer-events:none;\n  }\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <div class=\"hud\">\n    <div class=\"panel\" id=\"leftPanel\">\n      <div style=\"font-size:14px;font-weight:700;\">玩家</div>\n      <div class=\"small\" id=\"playerLen\">长度: 0</div>\n      <div class=\"small\" id=\"playerKills\">击杀: 0</div>\n    </div>\n    <div class=\"center panel\">\n      <div id=\"timer\" style=\"font-weight:800;font-size:18px;\">01:00</div>\n      <div class=\"small\" id=\"status\">方向：← ↑ → ↓ 或 滑动控制</div>\n    </div>\n    <div class=\"panel\" id=\"rightPanel\">\n      <div style=\"font-size:14px;font-weight:700;\">AI</div>\n      <div class=\"small\" id=\"aiLen\">长度: 0</div>\n      <div class=\"small\" id=\"aiKills\">击杀: 0</div>\n    </div>\n  </div>\n\n  <canvas id=\"gameCanvas\"></canvas>\n  <div style=\"margin-top:8px;\">\n    <button id=\"restartBtn\">重新开始</button>\n  </div>\n</div>\n\n<script>\n(() => {\n  // Canvas setup (must set exactly)\n  const canvas = document.getElementById('gameCanvas');\n  const ctx = canvas.getContext('2d');\n  canvas.width = 360;\n  canvas.height = 640;\n\n  const CELL = 10; // size of one grid cell\n  const COLS = canvas.width / CELL; // 36\n  const ROWS = canvas.height / CELL; // 64\n\n  // UI elements\n  const timerEl = document.getElementById('timer');\n  const playerLenEl = document.getElementById('playerLen');\n  const aiLenEl = document.getElementById('aiLen');\n  const playerKillsEl = document.getElementById('playerKills');\n  const aiKillsEl = document.getElementById('aiKills');\n  const statusEl = document.getElementById('status');\n  const restartBtn = document.getElementById('restartBtn');\n\n  // Game config\n  const GAME_DURATION = 60 * 1000; // 1 minute\n  const RESPAWN_DELAY = 3000; // ms\n  const TICK_RATE = 10; // updates per second\n  const TICK_MS = 1000 / TICK_RATE;\n  const INITIAL_LENGTH = 8;\n  const GROW_INTERVAL = 5000; // every 5 seconds both grow by 1\n\n  // Utilities\n  function randInt(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }\n  function mod(n,m){ return ((n % m) + m) % m; }\n  function formatTime(ms){\n    const s = Math.max(0, Math.ceil(ms/1000));\n    const mm = Math.floor(s/60).toString().padStart(2,'0');\n    const ss = (s%60).toString().padStart(2,'0');\n    return `${mm}:${ss}`;\n  }\n\n  function pointEq(a,b){ return a.x===b.x && a.y===b.y; }\n\n  // Create snake prototype\n  function createSnake(opts){\n    return {\n      id: opts.id,\n      color: opts.color,\n      dir: opts.dir, // {x:0,y:-1}\n      segments: [],\n      alive: true,\n      length: INITIAL_LENGTH,\n      nextDir: opts.dir,\n      spawnSafe: opts.spawnSafe,\n      lastGrowAt: performance.now(),\n      kills: 0,\n      deadUntil: 0,\n      control: opts.control || 'ai', // 'player' or 'ai'\n    };\n  }\n\n  // Place snake safely using provided function\n  function placeSnake(snake){\n    let attempts=0;\n    while(true){\n      attempts++;\n      const x = randInt(4, COLS-5);\n      const y = randInt(6, ROWS-7);\n      const dir = randInt(0,3);\n      const d = ({0:{x:1,y:0},1:{x:-1,y:0},2:{x:0,y:1},3:{x:0,y:-1}})[dir];\n      const segs = [];\n      segs.push({x:x,y:y});\n      for(let i=1;i<snake.length;i++){\n        segs.push({x:mod(x - d.x*i,COLS), y:mod(y - d.y*i,ROWS)});\n      }\n      // check not overlapping opponent\n      const other = snake === player ? ai : player;\n      let ok = true;\n      for(const s of segs){\n        if(other.alive){\n          for(const o of other.segments){\n            if(pointEq(s,o)){ ok=false; break; }\n          }\n          if(!ok) break;\n        }\n      }\n      if(ok || attempts>200) {\n        snake.segments = segs;\n        snake.dir = d;\n        snake.nextDir = d;\n        snake.alive = true;\n        snake.deadUntil = 0;\n        snake.lastGrowAt = performance.now();\n        snake.length = INITIAL_LENGTH;\n        return;\n      }\n    }\n  }\n\n  // Initialize snakes\n  const player = createSnake({\n    id: 'player',\n    color: '#33ff88',\n    dir: {x:0,y:-1},\n    control: 'player'\n  });\n  const ai = createSnake({\n    id: 'ai',\n    color: '#ff4d6d',\n    dir: {x:0,y:1},\n    control: 'ai'\n  });\n\n  // Initial placement\n  placeSnake(player);\n  placeSnake(ai);\n\n  // Game state\n  let lastUpdate = performance.now();\n  let accumulator = 0;\n  let startTime = performance.now();\n  let gameOver = false;\n  let growthTicker = performance.now();\n\n  // Input handling (keyboard + swipe)\n  const keyMap = {\n    37: {x:-1,y:0},  // left\n    65: {x:-1,y:0},  // A\n    39: {x:1,y:0},   // right\n    68: {x:1,y:0},   // D\n    38: {x:0,y:-1},  // up\n    87: {x:0,y:-1},  //