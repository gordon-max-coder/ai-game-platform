          "content": "<!doctype html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>撞车复活对决（AI对手）</title>\n<style>\n  html,body{\n    height:100%;\n    margin:0;\n    background:linear-gradient(180deg,#0b1220,#081426);\n    color:#fff;\n    font-family:Arial, Helvetica, sans-serif;\n    -webkit-font-smoothing:antialiased;\n    -moz-osx-font-smoothing:grayscale;\n  }\n  .wrap{\n    max-width:420px;\n    margin:12px auto;\n    padding:8px;\n    text-align:center;\n  }\n  canvas { max-width: 100%; height: auto; display: block; margin: 0 auto; }\n  .hud{\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    gap:8px;\n    margin:8px 0;\n  }\n  .panel{\n    background:rgba(255,255,255,0.04);\n    padding:8px 10px;\n    border-radius:8px;\n    min-width:100px;\n    text-align:left;\n  }\n  .center{\n    text-align:center;\n    flex:1;\n  }\n  button{\n    background:#1e90ff;\n    color:#fff;\n    border:0;\n    padding:8px 12px;\n    border-radius:8px;\n    cursor:pointer;\n    font-weight:700;\n  }\n  .small{\n    font-size:12px;\n    opacity:0.9;\n  }\n  .overlay{\n    position:fixed;\n    left:0;right:0;top:0;bottom:0;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    pointer-events:none;\n  }\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <div class=\"hud\">\n    <div class=\"panel\" id=\"leftPanel\">\n      <div style=\"font-size:14px;font-weight:700;\">玩家</div>\n      <div class=\"small\" id=\"playerLen\">长度: 0</div>\n      <div class=\"small\" id=\"playerKills\">击杀: 0</div>\n    </div>\n    <div class=\"center panel\">\n      <div id=\"timer\" style=\"font-weight:800;font-size:18px;\">01:00</div>\n      <div class=\"small\" id=\"status\">方向：← ↑ → ↓ 或 滑动控制</div>\n    </div>\n    <div class=\"panel\" id=\"rightPanel\">\n      <div style=\"font-size:14px;font-weight:700;\">AI</div>\n      <div class=\"small\" id=\"aiLen\">长度: 0</div>\n      <div class=\"small\" id=\"aiKills\">击杀: 0</div>\n    </div>\n  </div>\n\n  <canvas id=\"gameCanvas\"></canvas>\n  <div style=\"margin-top:8px;\">\n    <button id=\"restartBtn\">重新开始</button>\n  </div>\n</div>\n\n<script>\n(() => {\n  // Canvas setup (must set exactly)\n  const canvas = document.getElementById('gameCanvas');\n  const ctx = canvas.getContext('2d');\n  canvas.width = 360;\n  canvas.height = 640;\n\n  const CELL = 10; // size of one grid cell\n  const COLS = canvas.width / CELL; // 36\n  const ROWS = canvas.height / CELL; // 64\n\n  // UI elements\n  const timerEl = document.getElementById('timer');\n  const playerLenEl = document.getElementById('playerLen');\n  const aiLenEl = document.getElementById('aiLen');\n  const playerKillsEl = document.getElementById('playerKills');\n  const aiKillsEl = document.getElementById('aiKills');\n  const statusEl = document.getElementById('status');\n  const restartBtn = document.getElementById('restartBtn');\n\n  // Game config\n  const GAME_DURATION = 60 * 1000; // 1 minute\n  const RESPAWN_DELAY = 3000; // ms\n  const TICK_RATE = 10; // updates per second\n  const TICK_MS = 1000 / TICK_RATE;\n  const INITIAL_LENGTH = 8;\n  const GROW_INTERVAL = 5000; // every 5 seconds both grow by 1\n\n  // Utilities\n  function randInt(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }\n  function mod(n,m){ return ((n % m) + m) % m; }\n  function formatTime(ms){\n    const s = Math.max(0, Math.ceil(ms/1000));\n    const mm = Math.floor(s/60).toString().padStart(2,'0');\n    const ss = (s%60).toString().padStart(2,'0');\n    return `${mm}:${ss}`;\n  }\n\n  function pointEq(a,b){ return a.x===b.x && a.y===b.y; }\n\n  // Create snake prototype\n  function createSnake(opts){\n    return {\n      id: opts.id,\n      color: opts.color,\n      dir: opts.dir, // {x:0,y:-1}\n      segments: [],\n      alive: true,\n      length: INITIAL_LENGTH,\n      nextDir: opts.dir,\n      spawnSafe: opts.spawnSafe,\n      lastGrowAt: performance.now(),\n      kills: 0,\n      deadUntil: 0,\n      control: opts.control || 'ai', // 'player' or 'ai'\n    };\n  }\n\n  // Place snake safely using provided function\n  function placeSnake(snake){\n    let attempts=0;\n    while(true){\n      attempts++;\n      const x = randInt(4, COLS-5);\n      const y = randInt(6, ROWS-7);\n      const dir = randInt(0,3);\n      const d = ({0:{x:1,y:0},1:{x:-1,y:0},2:{x:0,y:1},3:{x:0,y:-1}})[dir];\n      const segs = [];\n      segs.push({x:x,y:y});\n      for(let i=1;i<snake.length;i++){\n        segs.push({x:mod(x - d.x*i,COLS), y:mod(y - d.y*i,ROWS)});\n      }\n      // check not overlapping opponent\n      const other = snake === player ? ai : player;\n      let ok = true;\n      for(const s of segs){\n        if(other.alive){\n          for(const o of other.segments){\n            if(pointEq(s,o)){ ok=false; break; }\n          }\n          if(!ok) break;\n        }\n      }\n      if(ok || attempts>200) {\n        snake.segments = segs;\n        snake.dir = d;\n        snake.nextDir = d;\n        snake.alive = true;\n        snake.deadUntil = 0;\n        snake.lastGrowAt = performance.now();\n        snake.length = INITIAL_LENGTH;\n        return;\n      }\n    }\n  }\n\n  // Initialize snakes\n  const player = createSnake({\n    id: 'player',\n    color: '#33ff88',\n    dir: {x:0,y:-1},\n    control: 'player'\n  });\n  const ai = createSnake({\n    id: 'ai',\n    color: '#ff4d6d',\n    dir: {x:0,y:1},\n    control: 'ai'\n  });\n\n  // Initial placement\n  placeSnake(player);\n  placeSnake(ai);\n\n  // Game state\n  let lastUpdate = performance.now();\n  let accumulator = 0;\n  let startTime = performance.now();\n  let gameOver = false;\n  let growthTicker = performance.now();\n\n  // Input handling (keyboard + swipe)\n  const keyMap = {\n    37: {x:-1,y:0},  // left\n    65: {x:-1,y:0},  // A\n    39: {x:1,y:0},   // right\n    68: {x:1,y:0},   // D\n    38: {x:0,y:-1},  // up\n    87: {x:0,y:-1},  // W\n    40: {x:0,y:1},   // down\n    83: {x:0,y:1}    // S\n  };\n  window.addEventListener('keydown', e=>{\n    const d = keyMap[e.keyCode];\n    if(d){\n      // prevent reverse\n      if(!(d.x === -player.dir.x && d.y === -player.dir.y)){\n        player.nextDir = d;\n      }\n    }\n    if(e.key === 'r' || e.key === 'R') resetGame();\n  });\n\n  // touch swipe\n  let touchStart = null;\n  canvas.addEventListener('touchstart', e=>{\n    const t = e.touches[0];\n    touchStart = {x:t.clientX, y:t.clientY, time:performance.now()};\n  }, {passive:true});\n  canvas.addEventListener('touchmove', e=>{\n    if(!touchStart) return;\n    const t = e.touches[0];\n    const dx = t.clientX - touchStart.x;\n    const dy = t.clientY - touchStart.y;\n    if(Math.abs(dx) < 20 && Math.abs(dy) < 20) return;\n    let nd = null;\n    if(Math.abs(dx) > Math.abs(dy)){\n      nd = dx > 0 ? {x:1,y:0} : {x:-1,y:0};\n    } else {\n      nd = dy > 0 ? {x:0,y:1} : {x:0,y:-1};\n    }\n    if(nd && !(nd.x === -player.dir.x && nd.y === -player.dir.y)){\n      player.nextDir = nd;\n      touchStart = null;\n    }\n  }, {passive:true});\n  canvas.addEventListener('touchend', e=>{\n    touchStart = null;\n  });\n\n  // Helpers: occupancy map for current alive bodies\n  function buildOccupancy(ignoreDead=true){\n    const occ = new Array(COLS);\n    for(let i=0;i<COLS;i++){ occ[i]=new Array(ROWS).fill(null); }\n    if(player.alive){\n      for(let i=0;i<player.segments.length;i++){\n        const s = player.segments[i];\n        occ[s.x][s.y] = player;\n      }\n    }\n    if(ai.alive){\n      for(let i=0;i<ai.segments.length;i++){\n        const s = ai.segments[i];\n        occ[s.x][s.y] = ai;\n      }\n    }\n    return occ;\n  }\n\n  // AI decision making: evaluate candidate moves\n  function aiDecide(snake, enemy){\n    if(!snake.alive) return;\n    const candidates = [\n      snake.dir,\n      {x:1,y:0},{x:-1,y:0},{x:0,y:1},{x:0,y:-1}\n    ];\n    const uniq = [];\n    for(const c of candidates){\n      // filter reverse\n      if(uniq.find(u=>u.x===c.x && u.y===c.y)) continue;\n      if(c.x === -snake.dir.x && c.y === -snake.dir.y) continue;\n      uniq.push(c);\n    }\n    const occ = buildOccupancy();\n\n    let best = snake.dir;\n    let bestScore = -Infinity;\n    // target position ~ try to move near player's head but also maximize free space\n    const target = enemy.segments[0];\n\n    for(const cand of uniq){\n      const nx = mod(snake.segments[0].x + cand.x, COLS);\n      const ny = mod(snake.segments[0].y + cand.y, ROWS);\n\n      // If moving into opponent body -> that's immediate death. Penalize heavily.\n      let intoEnemy = false;\n      if(enemy.alive){\n        for(const s of enemy.segments){\n          if(s.x===nx && s.y===ny){ intoEnemy = true; break; }\n        }\n      }\n\n      // evaluate reachable area using BFS (avoid both bodies)\n      const visited = new Uint8Array(COLS*ROWS);\n      const q = [];\n      function push(px,py){\n        const idx = px + py*COLS;\n        if(visited[idx]) return;\n        // avoid occupied cells (by both bodies)\n        if(occ[px][py] && !(px===snake.segments[snake.segments.length-1].x && py===snake.segments[snake.segments.length-1].y)) {\n          // allow tail because tail will move; ignore tail cell to be more fluid\n          return;\n        }\n        visited[idx]=1;\n        q.push({x:px,y:py});\n      }\n      push(nx,ny);\n      let qi=0;\n      const MAX_BFS = 400; // limit\n      while(qi<q.length && qi<MAX_BFS){\n        const cur = q[qi++];\n        const dirs = [{x:1,y:0},{x:-1,y:0},{x:0,y:1},{x:0,y:-1}];\n        for(const d of dirs){\n          const px = mod(cur.x + d.x, COLS);\n          const py = mod(cur.y + d.y, ROWS);\n          const idx = px + py*COLS;\n          if(visited[idx]) continue;\n          // treat enemy head specially: cell occupied by enemy is blocked\n          if(occ[px][py]) continue;\n          visited[idx] = 1;\n          q.push({x:px,y:py});\n        }\n      }\n      const area = q.length;\n\n      const distToPlayer = Math.hypot(mod(nx - target.x, COLS), mod(ny - target.y, ROWS));\n      // Score: prefer being closer to player and larger free area; strongly avoid stepping into enemy\n      let score = -distToPlayer * 1.2 + area * 0.4;\n      if(intoEnemy) score -= 9999; // avoid suicide\n      // small randomness to break ties\n      score += Math.random() * 0.1;\n\n      if(score > bestScore){\n        bestScore = score;\n        best = cand;\n      }\n    }\n\n    snake.nextDir = best;\n  }\n\n  // Game tick: update snakes and collisions\n  function step(dt, now){\n    if(gameOver) return;\n\n    const occ = buildOccupancy();\n\n    // handle respawn timers\n    for(const s of [player, ai]){\n      if(!s.alive && now >= s.deadUntil){\n        placeSnake(s);\n        // shield a tiny bit after respawn? we'll just respawn immediately\n        s.lastGrowAt = now;\n      }\n    }\n\n    // AI decides\n    aiDecide(ai, player);\n\n    // Prepare new head positions\n    const newHeads = {};\n    for(const s of [player, ai]){\n      if(!s.alive) continue;\n      // commit nextDir\n      if(!(s.nextDir.x === -s.dir.x && s.nextDir.y === -s.dir.y)){\n        s.dir = s.nextDir;\n      }\n      const nx = mod(s.segments[0].x + s.dir.x, COLS);\n      const ny = mod(s.segments[0].y + s.dir.y, ROWS);\n      newHeads[s.id] = {x:nx,y:ny};\n    }\n\n    // Collision detection\n    // 1) head-head same cell -> both die\n    if(player.alive && ai.alive){\n      const ph = newHeads.player;\n      const ah = newHeads.ai;\n      if(ph.x === ah.x && ph.y === ah.y){\n        // both collided head-on -> both dead\n        killSnake(player, ai, now, 'both');\n        killSnake(ai, player, now, 'both');\n        return; // this tick ends here\n      }\n    }\n\n    // 2) head moved into opponent body -> that mover dies\n    // check player\n    if(player.alive){\n      const ph = newHeads.player;\n      let hit = false;\n      if(ai.alive){\n        for(const seg of ai.segments){\n          if(ph.x === seg.x && ph.y === seg.y){\n            hit = true;\n            break;\n          }\n        }\n      }\n      if(hit){\n        killSnake(player, ai, now);\n      }\n    }\n    // check ai\n    if(ai.alive){\n      const ah = newHeads.ai;\n      let hit = false;\n      if(player.alive){\n        for(const seg of player.segments){\n          if(ah.x === seg.x && ah.y === seg.y){\n            hit = true;\n            break;\n          }\n        }\n      }\n      if(hit){\n        killSnake(ai, player, now);\n      }\n    }\n\n    // If one was killed above, it has been marked dead; allow other to proceed normally\n    // Now add heads for alive snakes\n    for(const s of [player, ai]){\n      if(!s.alive) continue;\n      const nh = newHeads[s.id];\n      // Prepend head\n      s.segments.unshift({x:nh.x, y:nh.y});\n      // Trim to maintain length\n      while(s.segments.length > s.length){\n        s.segments.pop();\n      }\n    }\n\n    // Growth: every GROW_INTERVAL both gain one length\n    if(now - growthTicker >= GROW_INTERVAL){\n      growthTicker = now;\n      if(player.alive) player.length += 1;\n      if(ai.alive) ai.length += 1;\n    }\n  }\n\n  function killSnake(victim, killer, now, special){\n    // special: 'both' means head-on mutual kill (no killer increment)\n    if(!victim.alive) return;\n    victim.alive = false;\n    victim.deadUntil = now + RESPAWN_DELAY;\n    victim.segments = []; // remove body while dead\n    // reset length on respawn\n    victim.length = INITIAL_LENGTH;\n    if(special !== 'both'){\n      killer.kills += 1;\n    }\n    // update UI quickly\n    updateHUD();\n  }\n\n  // Rendering\n  function draw(now){\n    // background\n    ctx.clearRect(0,0,canvas.width,canvas.height);\n    // subtle grid background\n    ctx.fillStyle = '#071024';\n    ctx.fillRect(0,0,canvas.width,canvas.height);\n\n    // draw trail shadows (underlay)\n    // draw snakes\n    for(const s of [player, ai]){\n      if(!s.alive) continue;\n      for(let i=s.segments.length-1;i>=0;i--){\n        const seg = s.segments[i];\n        const alpha = 0.12 + (1 - i / Math.max(1,s.segments.length)) * 0.75;\n        ctx.fillStyle = rgba(s.color, alpha);\n        drawCell(seg.x, seg.y, Math.max(0.5, 0.9 - i*0.01));\n      }\n      // draw head\n      if(s.segments.length>0){\n        const h = s.segments[0];\n        drawCell(h.x, h.y, 1, true, s.color);\n      }\n    }\n\n    // If dead, show respawn timer on that side\n    const nowMs = performance.now();\n    if(!player.alive){\n      const rem = Math.max(0, Math.ceil((player.deadUntil - nowMs)/1000));\n      drawRespawnText('玩家 即将复活: ' + (rem) + 's', canvas.width*0.18, canvas.height*0.5);\n    }\n    if(!ai.alive){\n      const rem = Math.max(0, Math.ceil((ai.deadUntil - nowMs)/1000));\n      drawRespawnText('AI 即将复活: ' + (rem) + 's', canvas.width*0.62, canvas.height*0.5);\n    }\n\n    // draw center dividing line for aesthetic\n    ctx.strokeStyle = 'rgba(255,255,255,0.03)';\n    ctx.lineWidth = 1;\n    ctx.beginPath();\n    ctx.moveTo(0, canvas.height*0.5);\n    ctx.lineTo(canvas.width, canvas.height*0.5);\n    ctx.stroke();\n\n    // draw timer and game-over overlay handled in UI elements\n    if(gameOver){\n      // draw final overlay on canvas\n      ctx.fillStyle = 'rgba(0,0,0,0.5)';\n      ctx.fillRect(0,0,canvas.width,canvas.height);\n      ctx.fillStyle = '#fff';\n      ctx.textAlign = 'center';\n      ctx.font = 'bold 20px Arial';\n      const winnerText = decideWinnerText();\n      ctx.fillText(winnerText, canvas.width/2, canvas.height/2 - 10);\n      ctx.font = '14px Arial';\n      ctx.fillText('按 重置 开始新局', canvas.width/2, canvas.height/2 + 18);\n    }\n  }\n\n  function rgba(hex, a){\n    // hex like #rrggbb\n    const r = parseInt(hex.slice(1,3),16);\n    const g = parseInt(hex.slice(3,5),16);\n    const b = parseInt(hex.slice(5,7),16);\n    return `rgba(${r},${g},${b},${a})`;\n  }\n\n  function drawCell(cx,cy,scale=1, bold=false, strokeColor=null){\n    const x = cx * CELL;\n    const y = cy * CELL;\n    const pad = bold ? 0 : Math.max(0, Math.floor(CELL*(1-scale)/2));\n    const w = CELL - pad*2;\n    const h = CELL - pad*2;\n    ctx.beginPath();\n    ctx.fillRect(x+pad, y+pad, w, h);\n    if(strokeColor){\n      ctx.strokeStyle = strokeColor;\n      ctx.lineWidth = 1;\n      ctx.strokeRect(x+pad+0.5, y+pad+0.5, w-1, h-1);\n    }\n  }\n\n  function drawRespawnText(text, cx, cy){\n    ctx.fillStyle = 'rgba(0,0,0,0.6)';\n    ctx.fillRect(cx - 68, cy - 20, 136, 36);\n    ctx.fillStyle = '#fff';\n    ctx.textAlign = 'center';\n    ctx.font = '12px Arial';\n    ctx.fillText(text, cx, cy + 5);\n  }\n\n  function decideWinnerText(){\n    if(player.length > ai.length) return '玩家获胜！';\n    if(ai.length > player.length) return 'AI 获胜！';\n    return '平局！';\n  }\n\n  // HUD updates\n  function updateHUD(){\n    playerLenEl.textContent = `长度: ${player.length}`;\n    aiLenEl.textContent = `长度: ${ai.length}`;\n    playerKillsEl.textContent = `击杀: ${player.kills}`;\n    aiKillsEl.textContent = `击杀: ${ai.kills}`;\n  }\n\n  // Main loop using RAF with fixed tick rate\n  function loop(now){\n    const dt = now - lastUpdate;\n    lastUpdate = now;\n    accumulator += dt;\n    while(accumulator >= TICK_MS){\n      step(TICK_MS, now);\n      accumulator -= TICK_MS;\n    }\n    // update timer\n    const elapsed = now - startTime;\n    const rem = Math.max(0, GAME_DURATION - elapsed);\n    timerEl.textContent = formatTime(rem);\n    if(rem<=0 && !gameOver){\n      gameOver = true;\n      statusEl.textContent = decideWinnerText() + ' — 按 重新开始';\n      // ensure HUD final update\n      updateHUD();\n    }\n    updateHUD();\n    draw(now);\n    requestAnimationFrame(loop);\n  }\n\n  // reset game\n  function resetGame(){\n    // reset timers\n    startTime = performance.now();\n    lastUpdate = performance.now();\n    accumulator = 0;\n    growthTicker = performance.now();\n    gameOver = false;\n    player.kills = 0;\n    ai.kills = 0;\n    player.length = INITIAL_LENGTH;\n    ai.length = INITIAL_LENGTH;\n    player.nextDir = {x:0,y:-1};\n    ai.nextDir = {x:0,y:1};\n    // respawn both\n    player.alive = false; ai.alive = false;\n    player.deadUntil = performance.now();\n    ai.deadUntil = performance.now();\n    placeSnake(player);\n    placeSnake(ai);\n    statusEl.textContent = '方向：← ↑ → ↓ 或 滑动控制';\n  }\n\n  restartBtn.addEventListener('click', resetGame);\n\n  // Start game\n  updateHUD();\n  lastUpdate = performance.now();\n  requestAnimationFrame(loop);\n\n  // Minor feature: show small intro\n  setTimeout(()=>{ statusEl.textContent = '注��：撞到对方的人会死亡，死亡3秒后复活，1分钟后长度更长者胜利'; }, 1200);\n\n})();\n</script>\n</body>\n</html>"
        },
