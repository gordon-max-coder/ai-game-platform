          "content": "<!doctype html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>修复版贪吃蛇 - Canvas 360x640</title>\n<style>\n  html,body{height:100%;margin:0;background:#111;font-family:system-ui,-apple-system,Segoe UI,Roboto,\"Helvetica Neue\",Arial;}\n  .wrap{max-width:420px;margin:12px auto;text-align:center;color:#fff;}\n  canvas{ background:#0b2a1f; display:block; margin:0 auto; max-width: 100%; height: auto; }\n  .hud{color:#ddd;margin-top:8px;}\n  .controls{margin-top:6px;font-size:13px;color:#bbb;}\n  .small{font-size:12px;color:#99a;}\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <canvas id=\"game\"></canvas>\n  <div class=\"hud\">\n    <span id=\"score\">分数: 0</span> &nbsp;|&nbsp; 高分:\n    <span id=\"hi\">0</span>\n  </div>\n  <div class=\"controls\">\n    箭头 / WASD 控制方向，触屏滑动也可。点击画布开始/重玩或暂停。\n    <div class=\"small\">吃到果子长度+1���死亡后点击重玩，复活不会卡死。</div>\n  </div>\n</div>\n\n<script>\n/*\n  单文件 Canvas 游戏\n  Canvas 必须在 JS 中设置尺寸（360x640）\n  使用 requestAnimationFrame + 固定步长更新\n  修复关键点：\n   - 使用单一循环（单个 requestAnimationFrame），重置 timing 状态以避免复活时卡死\n   - 随机产生果子，确保不出现在蛇身上\n   - 吃到果子长度 +1\n*/\n\nconst canvas = document.getElementById('game');\nconst ctx = canvas.getContext('2d');\n\n// 强制设置画布尺寸（要求）\ncanvas.width = 360;\ncanvas.height = 640;\n\n// CSS 要求已在 <style> 中设置：canvas { max-width: 100%; height: auto; display: block; margin: 0 auto; }\n\n// 游戏参数（格子）\nconst CELL = 20; // 每格像素\nconst COLS = Math.floor(canvas.width / CELL); // 18\nconst ROWS = Math.floor(canvas.height / CELL); // 32\n\n// DOM\nconst scoreEl = document.getElementById('score');\nconst hiEl = document.getElementById('hi');\n\n// 状态\nlet state = 'menu'; // 'menu' | 'playing' | 'paused' | 'dead'\nlet score = 0;\nlet hiScore = parseInt(localStorage.getItem('snake_hi') || '0', 10);\n\n// 画面节奏\nlet speed = 8; // 格/秒\nlet moveInterval = 1000 / speed;\nlet accumulator = 0;\nlet lastTime = 0;\nlet rafId = null;\n\n// Snake\nlet snake = [];\nlet dir = {x: 1, y: 0}; // 默认向右\nlet nextDir = {x: 1, y: 0};\nlet grow = 0;\n\n// Fruit\nlet fruit = null;\n\n// 控制限制（不��瞬间反向）\nfunction setDirection(nx, ny) {\n  // 防止反向（新方向与当前方向相反时忽略）\n  if (nx === -dir.x && ny === -dir.y) return;\n  nextDir = {x: nx, y: ny};\n}\n\n// Helper: 随机整数 [0, n)\nfunction randInt(n) { return Math.floor(Math.random()*n); }\n\n// 初始化/重置\nfunction resetGame() {\n  // reset core variables\n  snake = [];\n  // 初始蛇长度 4\n  const startX = Math.floor(COLS/2);\n  const startY = Math.floor(ROWS/2);\n  for (let i=0;i<4;i++){\n    snake.push({x: startX - i, y: startY});\n  }\n  dir = {x: 1, y: 0};\n  nextDir = {x: 1, y: 0};\n  grow = 0;\n  score = 0;\n  speed = 8;\n  moveInterval = 1000 / speed;\n  spawnFruit();\n  updateHUD();\n}\n\n// 生成果子，确保不在蛇身上\nfunction spawnFruit() {\n  if (!Array.isArray(snake) || snake.length === 0) {\n    // safety: populate in center if snake missing\n    fruit = {x: randInt(COLS), y: randInt(ROWS)};\n    return;\n  }\n  let tries = 0;\n  while (true) {\n    const fx = randInt(COLS);\n    const fy = randInt(ROWS);\n    const collide = snake.some(s => s.x === fx && s.y === fy);\n    if (!collide) {\n      fruit = {x: fx, y: fy};\n      return;\n    }\n    tries++;\n    // safety escape (but very unlikely)\n    if (tries > 1000) {\n      // choose first free cell by scanning\n      for (let y=0;y<ROWS;y++){\n        for (let x=0;x<COLS;x++){\n          if (!snake.some(s => s.x===x && s.y===y)) {\n            fruit = {x,y};\n            return;\n          }\n        }\n      }\n      // fallback\n      fruit = {x: 0, y: 0};\n      return;\n    }\n  }\n}\n\n// 更新 HUD\nfunction updateHUD() {\n  scoreEl.textContent = '分数: ' + score;\n  hiEl.textContent = hiScore;\n}\n\n// 游戏更新（以格为单位）\nfunction update() {\n  if (state !== 'playing') return;\n\n  // 应用方向（nextDir 在 setDirection 中已经处理反向）\n  dir = nextDir;\n\n  // 新头\n  let head = {x: snake[0].x + dir.x, y: snake[0].y + dir.y};\n\n  // 碰墙检测（墙为死亡）\n  if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS) {\n    die();\n    return;\n  }\n\n  // 碰到自己\n  for (let i=0;i<snake.length;i++){\n    if (snake[i].x === head.x && snake[i].y === head.y) {\n      die();\n      return;\n    }\n  }\n\n  // 推入头\n  snake.unshift(head);\n\n  // 吃到果子？\n  if (fruit && head.x === fruit.x && head.y === fruit.y) {\n    // 增长1\n    grow += 1;\n    score += 1;\n    // 提升速度每吃 5 个加速 1\n    if (score % 5 === 0) {\n      speed = Math.min(20, speed + 1);\n      moveInterval = 1000 / speed;\n    }\n    // 更新高分\n    if (score > hiScore) {\n      hiScore = score;\n      localStorage.setItem('snake_hi', String(hiScore));\n    }\n    spawnFruit();\n    updateHUD();\n  }\n\n  // 如果没有增长，则去掉尾部以维持长度\n  if (grow > 0) {\n    grow--;\n    // keep tail (effectively grows by 1)\n  } else {\n    snake.pop();\n  }\n}\n\n// 死亡处理\nfunction die() {\n  state = 'dead';\n  // Render will show overlay. 不停止主循环以避免复活时卡死。\n}\n\n// 渲染\nfunction draw() {\n  // 背景\n  ctx.clearRect(0,0,canvas.width,canvas.height);\n  // 背景格纹 subtle\n  ctx.fillStyle = '#063b2f';\n  ctx.fillRect(0,0,canvas.width,canvas.height);\n\n  // Grid lines (subtle)\n  ctx.strokeStyle = 'rgba(0,0,0,0.08)';\n  ctx.lineWidth = 1;\n  for (let x = 0; x <= COLS; x++) {\n    const px = x * CELL;\n    ctx.beginPath();\n    ctx.moveTo(px, 0);\n    ctx.lineTo(px, canvas.height);\n    ctx.stroke();\n  }\n  for (let y = 0; y <= ROWS; y++) {\n    const py = y * CELL;\n    ctx.beginPath();\n    ctx.moveTo(0, py);\n    ctx.lineTo(canvas.width, py);\n    ctx.stroke();\n  }\n\n  // Draw fruit\n  if (fruit) {\n    const fx = fruit.x * CELL;\n    const fy = fruit.y * CELL;\n    // nice fruit drawing: circle with shine\n    ctx.beginPath();\n    ctx.fillStyle = '#ff4d4d';\n    ctx.strokeStyle = '#b32424';\n    ctx.lineWidth = 2;\n    ctx.ellipse(fx + CELL*0.5, fy + CELL*0.5, CELL*0.45, CELL*0.45, 0, 0, Math.PI*2);\n    ctx.fill();\n    ctx.stroke();\n    ctx.fillStyle = 'rgba(255,255,255,0.7)';\n    ctx.beginPath();\n    ctx.ellipse(fx + CELL*0.6, fy + CELL*0.35, CELL*0.12, CELL*0.12, 0, 0, Math.PI*2);\n    ctx.fill();\n  }\n\n  // Draw snake\n  for (let i=snake.length-1;i>=0;i--) {\n    const s = snake[i];\n    const px = s.x * CELL;\n    const py = s.y * CELL;\n    if (i === 0) {\n      // head\n      ctx.fillStyle = '#9aff8a';\n      ctx.strokeStyle = '#1b8717';\n      ctx.lineWidth = 2;\n      roundRect(ctx, px+1, py+1, CELL-2, CELL-2, 4, true, true);\n      // eye\n      ctx.fillStyle = '#063b2f';\n      const eyeOffsetX = dir.x === -1 ? 6 : (dir.x === 1 ? CELL-8 : CELL/2 - 3);\n      const eyeOffsetY = dir.y === -1 ? 6 : (dir.y === 1 ? CELL-8 : CELL/2 - 3);\n      ctx.beginPath();\n      ctx.ellipse(px + eyeOffsetX, py + eyeOffsetY, 2.5, 2.5, 0, 0, Math.PI*2);\n      ctx.fill();\n    } else {\n      // body\n      ctx.fillStyle = '#66d36f';\n      ctx.strokeStyle = '#1b8717';\n      ctx.lineWidth = 1;\n      roundRect(ctx, px+1, py+1, CELL-2, CELL-2, 3, true, true);\n    }\n  }\n\n  // Top bar shadow\n  ctx.fillStyle = 'rgba(0,0,0,0.25)';\n  ctx.fillRect(0,0,canvas.width,36);\n\n  // Overlays for different states\n  if (state === 'menu') {\n    ctx.fillStyle = 'rgba(0,0,0,0.55)';\n    ctx.fillRect(20, 100, canvas.width-40, 200);\n    ctx.fillStyle = '#fff';\n    ctx.font = '22px sans-serif';\n    ctx.textAlign = 'center';\n    ctx.fillText('修复版贪吃蛇', canvas.width/2, 140);\n    ctx.font = '14px sans-serif';\n    ctx.fillStyle = '#cfe';\n    ctx.fillText('点击画布开始', canvas.width/2, 170);\n    ctx.fillStyle = '#99d';\n    ctx.fillText('吃果子 +1 长度，躲墙和自己', canvas.width/2, 200);\n    ctx.fillStyle = '#aef';\n    ctx.fillText('触屏滑动或使用方向键控制', canvas.width/2, 230);\n  } else if (state === 'paused') {\n    ctx.fillStyle = 'rgba(0,0,0,0.55)';\n    ctx.fillRect(40, 200, canvas.width-80, 120);\n    ctx.fillStyle = '#fff';\n    ctx.font = '20px sans-serif';\n    ctx.textAlign = 'center';\n    ctx.fillText('已暂停', canvas.width/2, 260);\n    ctx.font = '14px sans-serif';\n    ctx.fillStyle = '#cfe';\n    ctx.fillText('点击画布恢复游戏', canvas.width/2, 290);\n  } else if (state === 'dead') {\n    // show big overlay\n    ctx.fillStyle = 'rgba(0,0,0,0.65)';\n    ctx.fillRect(20, 160, canvas.width-40, 220);\n    ctx.textAlign = 'center';\n    ctx.fillStyle = '#ffbaba';\n    ctx.font = '26px sans-serif';\n    ctx.fillText('游戏结束', canvas.width/2, 210);\n    ctx.fillStyle = '#fff';\n    ctx.font = '18px sans-serif';\n    ctx.fillText('得分: ' + score, canvas.width/2, 245);\n    ctx.fillStyle = '#cfe';\n    ctx.font = '14px sans-serif';\n    ctx.fillText('点击画布重玩', canvas.width/2, 285);\n    ctx.fillText('或使用键盘 ←→↑↓ / WASD 控制', canvas.width/2, 310);\n  }\n}\n\n// helper: rounded rectangle\nfunction roundRect(ctx, x, y, w, h, r, fill, stroke) {\n  if (typeof r === 'undefined') r = 5;\n  if (typeof r === 'number') r = {tl: r, tr: r, br: r, bl: r};\n  ctx.beginPath();\n  ctx.moveTo(x + r.tl, y);\n  ctx.lineTo(x + w - r.tr, y);\n  ctx.quadraticCurveTo(x + w, y, x + w, y + r.tr);\n  ctx.lineTo(x + w, y + h - r.br);\n  ctx.quadraticCurveTo(x + w, y + h, x + w - r.br, y + h);\n  ctx.lineTo(x + r.bl, y + h);\n  ctx.quadraticCurveTo(x, y + h, x, y + h - r.bl);\n  ctx.lineTo(x, y + r.tl);\n  ctx.quadraticCurveTo(x, y, x + r.tl, y);\n  ctx.closePath();\n  if (fill) ctx.fill();\n  if (stroke) ctx.stroke();\n}\n\n// 主循环（单一 rAF）\nfunction loop(timestamp) {\n  if (!lastTime) lastTime = timestamp;\n  const dt = timestamp - lastTime;\n  lastTime = timestamp;\n\n  // Accumulate and perform fixed-step updates\n  accumulator += dt;\n  const maxCatchUp = 250; // 防止长时间切换导致 huge accumulator 卡顿\n  if (accumulator > maxCatchUp) accumulator = maxCatchUp;\n\n  while (accumulator >= moveInterval) {\n    update();\n    accumulator -= moveInterval;\n  }\n\n  draw();\n  rafId = requestAnimationFrame(loop);\n}\n\n// Input handling\nwindow.addEventListener('keydown', (e) => {\n  const k = e.key;\n  if (k === 'ArrowLeft' || k === 'a' || k === 'A') setDirection(-1,0);\n  else if (k === 'ArrowRight' || k === 'd' || k === 'D') setDirection(1,0);\n  else if (k === 'ArrowUp' || k === 'w' || k === 'W') setDirection(0,-1);\n  else if (k === 'ArrowDown' || k === 's' || k === 'S') setDirection(0,1);\n  else if (k === ' ' || k === 'Enter') {\n    if (state === 'menu' || state === 'dead') {\n      startPlaying();\n    } else if (state === 'playing') {\n      state = 'paused';\n    } else if (state === 'paused') {\n      resumePlaying();\n    }\n  } else if (k === 'r' || k === 'R') {\n    // quick restart\n    startPlaying();\n  }\n});\n\n// Touch controls (swipe detect)\nlet touchStart = null;\ncanvas.addEventListener('touchstart', (e) => {\n  const t = e.touches[0];\n  touchStart = {x: t.clientX, y: t.clientY, time: Date.now()};\n  // prevent ghost clicks\n  e.preventDefault();\n}, {passive:false});\n\ncanvas.addEventListener('touchend', (e) => {\n  if (!touchStart) return;\n  const t = e.changedTouches[0];\n  const dx = t.clientX - touchStart.x;\n  const dy = t.clientY - touchStart.y;\n  const adx = Math.abs(dx);\n  const ady = Math.abs(dy);\n  const min = 10;\n  if (adx > ady && adx > min) {\n    if (dx > 0) setDirection(1,0);\n    else setDirection(-1,0);\n  } else if (ady > adx && ady > min) {\n    if (dy > 0) setDirection(0,1);\n    else setDirection(0,-1);\n  } else {\n    // tap\n    handleCanvasClick();\n  }\n  touchStart = null;\n}, {passive:false});\n\n// Mouse click/tap handling for start/pause/restart\ncanvas.addEventListener('click', handleCanvasClick);\nfunction handleCanvasClick() {\n  if (state === 'menu') startPlaying();\n  else if (state === 'playing') {\n    state = 'paused';\n  } else if (state === 'paused') {\n    resumePlaying();\n  } else if (state === 'dead') {\n    startPlaying();\n  }\n}\n\n// Start playing: initialize and ensure timing safe\nfunction startPlaying() {\n  resetGame();\n  state = 'playing';\n  // Reset timing counters to avoid huge dt on resume/respawn\n  accumulator = 0;\n  lastTime = performance.now();\n  updateHUD();\n}\n\n// Resume from pause: keep game as is, but reset timing so no catch-up\nfunction resumePlaying() {\n  if (state !== 'paused') return;\n  state = 'playing';\n  accumulator = 0;\n  lastTime = performance.now();\n}\n\n// Ensure single RAF running\nif (!rafId) {\n  rafId = requestAnimationFrame(loop);\n}\n\n// 初始菜单渲染\ndraw();\nupdateHUD();\n\n</script>\n</body>\n</html>"
        },
