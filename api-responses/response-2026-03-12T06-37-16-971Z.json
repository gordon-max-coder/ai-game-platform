  "gameCode": "<!doctype html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>宝石争夺战（含AI对手）</title>\n<style>\n  html,body { height:100%; margin:0; background:#111; color:#fff; font-family: Arial, Helvetica, sans-serif; -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale; }\n  .wrap { width:360px; margin:20px auto 40px; }\n  canvas { max-width: 100%; height: auto; display: block; margin: 0 auto; background: linear-gradient(#072033, #001219); border-radius:12px; box-shadow:0 6px 20px rgba(0,0,0,0.7), inset 0 3px 8px rgba(255,255,255,0.02); }\n  .footer { text-align:center; color:#aab; font-size:12px; margin-top:8px; }\n  button.ctrl { display:block; margin:10px auto; padding:8px 14px; border-radius:6px; border:none; background:#05a; color:#fff; font-weight:700; cursor:pointer; }\n  button.ctrl:hover { background:#07c; }\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <canvas id=\"game\"></canvas>\n  <div style=\"text-align:center; margin-top:8px;\">\n    <button id=\"startBtn\" class=\"ctrl\">开始游戏</button>\n    <button id=\"muteBtn\" class=\"ctrl\" style=\"background:#444;\">静音</button>\n  </div>\n  <div class=\"footer\">移动：鼠标/触摸；或 ← → 键</div>\n</div>\n\n<script>\n(() => {\n  const canvas = document.getElementById('game');\n  // Required explicit size in JS:\n  canvas.width = 360;\n  canvas.height = 640;\n  const ctx = canvas.getContext('2d');\n\n  const W = canvas.width, H = canvas.height;\n\n  // Game states\n  let running = false;\n  let started = false;\n  let lastTime = 0;\n  let spawnTimer = 0;\n  let spawnInterval = 800; // ms\n  let difficultyTimer = 0;\n  let totalTime = 60; // seconds game length\n  let timeLeft = totalTime;\n  let score = 0;\n  let aiScore = 0;\n\n  // Audio\n  let audioEnabled = true;\n  let audioCtx = null;\n  function ensureAudio() {\n    if (!audioCtx) {\n      try {\n        audioCtx = new (window.AudioContext || window.webkitAudioContext)();\n      } catch(e) {\n        audioEnabled = false;\n      }\n    }\n  }\n  function beep(freq=440, time=0.06, type='sine', vol=0.12) {\n    if(!audioEnabled) return;\n    ensureAudio();\n    if(!audioCtx) return;\n    const o = audioCtx.createOscillator();\n    const g = audioCtx.createGain();\n    o.type = type;\n    o.frequency.value = freq;\n    g.gain.value = vol;\n    o.connect(g); g.connect(audioCtx.destination);\n    o.start();\n    g.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + time);\n    o.stop(audioCtx.currentTime + time + 0.02);\n  }\n\n  // Player\n  const player = {\n    x: W/2,\n    y: H - 70,\n    w: 72,\n    h: 36,\n    color: '#38f',\n    vx: 0,\n    maxSpeed: 800 // px/s when using keyboard; pointer is instantaneous follow\n  };\n\n  // AI opponent\n  const ai = {\n    x: W/2,\n    y: H - 130,\n    w: 70,\n    h: 32,\n    color: '#f35',\n    maxSpeed: 230, // px/s\n    mistakeChance: 0.12, // base chance to make mistake\n    focus: null, // target item id\n    reactionLag: 120 // ms delay before reacting\n  };\n\n  // Items\n  let items = [];\n  let itemIdCounter = 1;\n\n  function spawnItem() {\n    // Types: gem (10), star (30), bomb (-15)\n    const r = Math.random();\n    let type = 'gem';\n    if (r > 0.92) type = 'star';      // ~8%\n    else if (r < 0.12) type = 'bomb'; // ~12%\n    const x = 18 + Math.random() * (W - 36);\n    const speed = 60 + Math.random() * (140 + Math.min(200, (totalTime - timeLeft) * 5)); // accelerate with time left decreasing\n    const size = type === 'star' ? 18 : (type === 'bomb' ? 16 : 14);\n    const value = type === 'gem' ? 10 : (type === 'star' ? 30 : -15);\n    const col = type === 'gem' ? '#00ffd5' : (type === 'star' ? '#ffd700' : '#222');\n    const id = itemIdCounter++;\n    items.push({id, type, x, y: -size-10, vy: speed, size, value, col, caught: false});\n  }\n\n  // Input handling\n  let pointerActive = false;\n  let pointerX = player.x;\n  let keyLeft = false, keyRight = false;\n  let lastPointerTime = 0;\n\n  canvas.addEventListener('mousedown', (e) => {\n    pointerActive = true;\n    const rect = canvas.getBoundingClientRect();\n    pointerX = (e.clientX - rect.left) * (canvas.width / rect.width);\n    lastPointerTime = performance.now();\n    if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();\n    if (!started) startGame();\n  });\n  window.addEventListener('mousemove', (e) => {\n    if (!pointerActive) return;\n    const rect = canvas.getBoundingClientRect();\n    pointerX = (e.clientX - rect.left) * (canvas.width / rect.width);\n    lastPointerTime = performance.now();\n  });\n  window.addEventListener('mouseup', ()=> pointerActive = false);\n  canvas.addEventListener('touchstart', (e) => {\n    e.preventDefault();\n    pointerActive = true;\n    const t = e.touches[0];\n    const rect = canvas.getBoundingClientRect();\n    pointerX = (t.clientX - rect.left) * (canvas.width / rect.width);\n    lastPointerTime = performance.now();\n    if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();\n    if (!started) startGame();\n  }, {passive:false});\n  canvas.addEventListener('touchmove', (e) => {\n    e.preventDefault();\n    if (!pointerActive) return;\n    const t = e.touches[0];\n    const rect = canvas.getBoundingClientRect();\n    pointerX = (t.clientX - rect.left) * (canvas.width / rect.width);\n    lastPointerTime = performance.now();\n  }, {passive:false});\n  canvas.addEventListener('touchend', (e) => {\n    e.preventDefault();\n    pointerActive = false;\n  }, {passive:false});\n\n  window.addEventListener('keydown', (e) => {\n    if (e.key === 'ArrowLeft' || e.key === 'a') keyLeft = true;\n    if (e.key === 'ArrowRight' || e.key === 'd') keyRight = true;\n    if (e.key === ' ' || e.key === 'Spacebar') {\n      // small jump to attract items? For simplicity, space triggers small \"scoop\" that tries to collect nearest item under player\n      // (not necessary)\n    }\n    if (!started && (e.key === 'Enter')) startGame();\n    if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();\n  });\n  window.addEventListener('keyup', (e) => {\n    if (e.key === 'ArrowLeft' || e.key === 'a') keyLeft = false;\n    if (e.key === 'ArrowRight' || e.key === 'd') keyRight = false;\n  });\n\n  // Start/Restart controls\n  const startBtn = document.getElementById('startBtn');\n  const muteBtn = document.getElementById('muteBtn');\n  startBtn.addEventListener('click', () => {\n    if (!started) startGame();\n    else resetGame();\n  });\n  muteBtn.addEventListener('click', () => {\n    audioEnabled = !audioEnabled;\n    muteBtn.textContent = audioEnabled ? '静音' : '已静音';\n    muteBtn.style.background = audioEnabled ? '#444' : '#666';\n  });\n\n  function startGame() {\n    // initialize\n    started = true;\n    running = true;\n    lastTime = performance.now();\n    spawnTimer = 0;\n    spawnInterval = 800;\n    difficultyTimer = 0;\n    totalTime = 60;\n    timeLeft = totalTime;\n    score = 0;\n    aiScore = 0;\n    items = [];\n    itemIdCounter = 1;\n    player.x = W/2;\n    ai.x = W/2;\n    ai.focus = null;\n    // reduce initial mistake with slight randomness\n    ai.mistakeChance = 0.12;\n    if (audioEnabled) ensureAudio();\n    startBtn.textContent = '重新开始';\n    loop(lastTime);\n  }\n  function resetGame() {\n    started = false;\n    running = false;\n    startBtn.textContent = '开始游戏';\n    // draw start screen\n    drawStartScreen();\n  }\n\n  // Draw start screen initially\n  function drawStartScreen() {\n    ctx.clearRect(0,0,W,H);\n    // background gradient\n    const g = ctx.createLinearGradient(0,0,0,H);\n    g.addColorStop(0,'#062033'); g.addColorStop(1,'#001219');\n    ctx.fillStyle = g;\n    ctx.fillRect(0,0,W,H);\n\n    ctx.fillStyle = '#fff';\n    ctx.textAlign = 'center';\n    ctx.font = '700 22px Arial';\n    ctx.fillText('宝石争夺战', W/2, 120);\n    ctx.font = '14px Arial';\n    ctx.fillStyle = '#cfe';\n    ctx.fillText('收集从天而降的宝石，避免炸弹。', W/2, 150);\n    ctx.fillText('与AI对手竞速，谁拿到更多分数！', W/2, 170);\n\n    // sample player and AI\n    drawPlayerPreview();\n    ctx.font = '12px Arial';\n    ctx.fillStyle = '#9fd';\n    ctx.fillText('点击/触摸开始游戏', W/2, H - 60);\n    ctx.fillStyle = '#7fb';\n    ctx.fillText('移动：鼠标/触摸或 ← → 键', W/2, H - 40);\n  }\n\n  function drawPlayerPreview() {\n    // player\n    ctx.save();\n    ctx.translate(W/2 - 90, 220);\n    // player basket\n    ctx.fillStyle = player.color;\n    roundRect(ctx, -36, -10, 72, 20, 8, true, false);\n    // ai\n    ctx.translate(180, -40);\n    ctx.fillStyle = ai.color;\n    roundRect(ctx, -35, -10, 70, 18, 8, true, false);\n    // gems\n    ctx.restore();\n    // display small gem/star\n    drawGem(W/2 - 30, 260, 12, '#00ffd5');\n    drawStar(W/2 + 30, 260, 10, '#ffd700');\n    // bomb\n    drawBomb(W/2, 300, 10, '#222');\n    ctx.fillStyle = '#ffd';\n    ctx.font = '12px Arial';\n    ctx.fillText('+10  宝石   +30 星  -15 炸弹', W/2, 340);\n  }\n\n  // Utility drawing\n  function roundRect(ctx,x,y,w,h,r,fill,stroke){\n    if (typeof stroke === 'undefined') stroke = true;\n    if (typeof r === 'undefined') r = 5;\n    ctx.beginPath();\n    ctx.moveTo(x+r,y);\n    ctx.arcTo(x+w,y,x+w,y+h,r);\n    ctx.arcTo(x+w,y+h,x,y+h,r);\n    ctx.arcTo(x,y+h,x,y,r);\n    ctx.arcTo(x,y,x+w,y,r);\n    ctx.closePath();\n    if(fill){ ctx.fill(); }\n    if(stroke){ ctx.stroke(); }\n  }\n\n  function drawGem(x,y,size,color) {\n    ctx.save();\n    ctx.translate(x,y);\n    ctx.rotate(Math.sin((x+y+performance.now()/6)/250) * 0.06);\n    ctx.fillStyle = color;\n    ctx.beginPath();\n    ctx.moveTo(0,-size);\n    ctx.lineTo(size*0.6,-size*0.2);\n    ctx.lineTo(size*0.4,size*0.7);\n    ctx.lineTo(-size*0.4,size*0.7);\n    ctx.lineTo(-size*0.6,-size*0.2);\n    ctx.closePath();\n    ctx.fill();\n    ctx.restore();\n  }\n\n  function drawStar(x,y,size,color) {\n    ctx.save();\n    ctx.translate(x,y);\n    ctx.fillStyle = color;\n    ctx.beginPath();\n    for (let i=0;i<5;i++){\n      ctx.lineTo(Math.cos((18+72*i)/180*Math.PI)*size, -Math.sin((18+72*i)/180*Math.PI)*size);\n      ctx.lineTo(Math.cos((54+72*i)/180*Math.PI)*size*0.5, -Math.sin((54+72*i)/180*Math.PI)*size*0.5);\n    }\n    ctx.closePath();\n    ctx.fill();\n    ctx.restore();\n  }\n\n  function drawBomb(x,y,size,color) {\n    ctx.save();\n    ctx.translate(x,y);\n    ctx.fillStyle = color;\n    ctx.beginPath();\n    ctx.arc(0,0,size,0,Math.PI*2);\n    ctx.fill();\n    ctx.fillStyle = '#666';\n    ctx.fillRect(size-2,-size-8,8,6);\n    ctx.restore();\n  }\n\n  // Main loop\n  function loop(time) {\n    if (!running) return;\n    const dt = Math.min(40, time - lastTime);\n    lastTime = time;\n    update(dt/1000);\n    draw();\n    if (timeLeft <= 0) {\n      running = false;\n      started = false;\n      setTimeout(()=> drawGameOver(), 220);\n      return;\n    }\n    requestAnimationFrame(loop);\n  }\n\n  function update(dt) {\n    // time\n    timeLeft -= dt;\n    if (timeLeft < 0) timeLeft = 0;\n\n    // spawn items\n    spawnTimer += dt*1000;\n    difficultyTimer += dt*1000;\n    // gradually increase spawn rate\n    const spawnDecay = Math.max(300, 800 - (totalTime - timeLeft) * 6); // min 300ms\n    if (spawnTimer >= spawnInterval) {\n      spawnTimer = 0;\n      spawnInterval = spawnDecay + Math.random()*220 - Math.min(220, (totalTime - timeLeft)*4);\n      spawnItem();\n    }\n\n    // keyboard movement\n    if (!pointerActive) {\n      if (keyLeft) player.vx = -player.maxSpeed;\n      else if (keyRight) player.vx = player.maxSpeed;\n      else player.vx = 0;\n      player.x += player.vx * dt;\n    } else {\n      // follow pointer smoothly (small smoothing)\n      const dx = pointerX - player.x;\n      player.x += dx * Math.min(12*dt, 1);\n    }\n    // clamp player\n    player.x = Math.max(player.w/2, Math.min(W - player.w/2, player.x));\n\n    // AI decision-making\n    updateAI(dt);\n\n    // update items\n    for (let it of items) {\n      it.y += it.vy * dt;\n    }\n\n    // collisions: check items near catch lines (player and ai)\n    // playerCatchZoneY and aiCatchZoneY\n    const playerCatchY = player.y - 8;\n    const aiCatchY = ai.y + 6;\n\n    // check each item for catches\n    for (let it of items) {\n      if (it.caught) continue;\n      // if item close to player horizontal and vertical in range -> catch\n      // give priority to whichever is closer at the time of passing catchY\n      // If item passes below H+20 it's missed.\n      if (it.y > H + 40) {\n        it.caught = true; // remove later\n        continue;\n      }\n      // Check player catch\n      const withinPlayerY = Math.abs(it.y - playerCatchY) < Math.max(12, it.vy * 0.02) + it.size;\n      const withinAIY = Math.abs(it.y - aiCatchY) < Math.max(12, it.vy * 0.02) + it.size;\n      let pCatch = false, aCatch = false;\n      if (withinPlayerY) {\n        const dx = Math.abs(it.x - player.x);\n        if (dx < Math.max(player.w/2, 26) + it.size) pCatch = true;\n      }\n      if (withinAIY) {\n        const dx2 = Math.abs(it.x - ai.x);\n        if (dx2 < Math.max(ai.w/2, 26) + it.size) aCatch = true;\n      }\n      if (pCatch && aCatch) {\n        // both catch: give to who is closer vertically or horizontally\n        const dp = Math.abs(it.x - player.x) + Math.abs(it.y - playerCatchY)*0.2;\n        const da = Math.abs(it.x - ai.x) + Math.abs(it.y - aiCatchY)*0.2;\n        if (dp <= da) {\n          applyCatch(it, 'player');\n        } else {\n          applyCatch(it, 'ai');\n        }\n      } else if (pCatch) {\n        applyCatch(it, 'player');\n      } else if (aCatch) {\n        applyCatch(it, 'ai');\n      }\n    }\n\n    // remove caught or out-of-screen items\n    items = items.filter(it => !it.caught && it.y < H + 80);\n  }\n\n  function applyCatch(it, who) {\n    it.caught = true;\n    if (who === 'player') {\n      // positive or negative\n      if (it.type === 'bomb') {\n        score += it.value; // negative\n        beep(120,0.08,'sine',0.14);\n      } else {\n        score += it.value;\n        // small combo/jitter effect\n        beep(it.type === 'star' ? 880 : 560, 0.08, 'sawtooth', 0.12);\n      }\n    } else {\n      // AI catches\n      if (it.type === 'bomb') {\n        aiScore += it.value; // negative\n        beep(160,0.07,'sine',0.08);\n      } else {\n        aiScore += it.value;\n        beep(it.type === 'star' ? 640 : 420, 0.06, 'triangle', 0.08);\n      }\n    }\n  }\n\n  function updateAI(dt) {\n    // AI reevaluates target occasionally\n    // choose item to intercept with highest expected reward/time and not predicted to be stolen by player if AI can't reach\n    // set target id in ai.focus\n    // Simple behavior: compute predicted time to reach y of AICatch, pick item with best score/time within reachable area\n    const aiCatchY = ai.y + 6;\n    // only consider items below top and above bottom\n    let best = null;\n    let now = performance.now();\n    for (let it of items) {\n      if (it.caught) continue;\n      // prediction time until reaching AI catch line\n      const t = (aiCatchY - it.y) / it.vy;\n      if (t < -0.35) continue; // already past\n      if (t < 0) continue;\n      // predicted x remains constant (no wind)\n      const dist = Math.abs(it.x - ai.x);\n      const timeToReach = dist / ai.maxSpeed;\n      // If AI can't reach in time, deprioritize\n      let reachable = timeToReach <= t + 0.15; // small buffer\n      // compute score weight, bombs are negative\n      const effectiveVal = it.value;\n      // prefer high value, prefer reachable\n      const scorePerSec = effectiveVal / Math.max(0.1, t);\n      const weight = scorePerSec * (reachable ? 1.2 : 0.5);\n      if (!best || weight > best.weight) best = {item: it, weight, reachable, t, timeToReach};\n    }\n\n    // occasionally make mistake: pick none or wrong\n    if (best) {\n      // reaction lag check: AI doesn't instantly shift target\n      if (!ai.focus || ai.focus.id !== best.item.id) {\n        // decide to focus or not based on mistakeChance\n        if (Math.random() > ai.mistakeChance) {\n          ai.focus = {id: best.item.id, setAt: now};\n        } else {\n          // mistake: choose some other random x or ignore for a bit\n          if (Math.random() < 0.5) {\n            // random dash to a random position\n            ai.focus = {id: null, x: Math.random()*W, setAt: now};\n          } else {\n            // deliberately ignore for a short time\n            ai.focus = {id: null, x: Math.min(W-20, Math.max(20, best.item.x + (Math.random()*120-60))), setAt: now + 200};\n          }\n        }\n      }\n    } else {\n      // no items -> position to center\n      if (!ai.focus || ai.focus.id !== null) {\n        ai.focus = {id: null, x: W/2, setAt: now};\n      }\n    }\n\n    // Move AI towards target, but respect reactionLag\n    if (ai.focus) {\n      if (ai.focus.setAt > now) {\n        // waiting due to temporary ignore\n      } else {\n        let targetX = ai.x;\n        if (ai.focus.id) {\n          const targetItem = items.find(it => it.id === ai.focus.id);\n          if (targetItem) targetX = targetItem.x;\n          else {\n            if (ai.focus.x !== undefined) targetX = ai.focus.x;\n            else targetX = W/2;\n            ai.focus.id = null;\n          }\n        } else {\n          if (ai.focus.x !== undefined) targetX = ai.focus.x;\n        }\n        // Add small smoothing and occasional overcorrection for \"human feel\"\n        const dx = targetX - ai.x;\n        const move = Math.sign(dx) * Math.min(Math.abs(dx), ai.maxSpeed * dt);\n        // sometimes AI accelerates to steal (if predicted player near a target, AI increases speed slightly)\n        let speedBoost = 1;\n        // Determine if AI should attempt to steal: if an item is also targetable by player soon\n        if (ai.focus.id) {\n          const it = items.find(it => it.id === ai.focus.id);\n          if (it) {\n            const playerCatchY = player.y - 8;\n            const tPlayer = (playerCatchY - it.y) / it.vy;\n            const tAI = (ai.y + 6 - it.y) / it.vy;\n            if (tPlayer > 0 && tAI > 0 && tAI <= tPlayer + 0.25) {\n              speedBoost = 1.25; // try to beat player\n            }\n          }\n        }\n        ai.x += move * speedBoost;\n        // randomness/friction\n        // clamp\n        ai.x = Math.max(ai.w/2, Math.min(W - ai.w/2, ai.x));\n      }\n    }\n\n    // gradually adjust AI mistake chance to scale difficulty (becomes smarter with time)\n    ai.mistakeChance = Math.max(0.02, 0.12 - (totalTime - timeLeft) * 0.0015);\n  }\n\n  function draw() {\n    // background\n    const g = ctx.createLinearGradient(0,0,0,H);\n    g.addColorStop(0,'#052233'); g.addColorStop(1,'#001219');\n    ctx.fillStyle = g;\n    ctx.fillRect(0,0,W,H);\n\n    // top HUD background\n    ctx.fillStyle = 'rgba(0,0,0,0.18)';\n    roundRect(ctx, 8, 8, W-16, 60, 10, true, false);\n\n    // scores and time\n    ctx.fillStyle = '#bfe';\n    ctx.font = '700 16px Arial';\n    ctx.textAlign = 'left';\n    ctx.fillText('你: ' + score, 18, 32);\n    ctx.fillStyle = '#fdb';\n    ctx.fillText('AI: ' + aiScore, 18, 54);\n\n    // time on right\n    ctx.textAlign = 'right';\n    ctx.fillStyle = '#fff';\n    ctx.font = '700 18px Arial';\n    const tl = Math.max(0, Math.ceil(timeLeft));\n    ctx.fillText('时间: ' + tl + 's', W-18, 38);\n\n    // draw items\n    for (let it of items) {\n      if (it.type === 'gem') drawGem(it.x, it.y, it.size, it.col);\n      else if (it.type === 'star') drawStar(it.x, it.y, it.size, it.col);\n      else drawBomb(it.x, it.y, it.size, it.col);\n      // slight glow\n      if (it.type !== 'bomb') {\n        ctx.beginPath(); ctx.fillStyle = 'rgba(255,255,255,0.03)';\n        ctx.ellipse(it.x, it.y+6, it.size*1.4, it.size*0.6, 0, 0, Math.PI*2);\n        ctx.fill();\n      }\n    }\n\n    // draw AI basket above player\n    // Draw AI\n    ctx.save();\n    ctx.translate(ai.x, ai.y);\n    // shadow\n    ctx.fillStyle = 'rgba(0,0,0,0.35)';\n    roundRect(ctx, -ai.w/2+2, 8, ai.w, ai.h, 8, true, false);\n    // body\n    ctx.fillStyle = ai.color;\n    roundRect(ctx, -ai.w/2, -6, ai.w, ai.h, 8, true, false);\n    // label\n    ctx.fillStyle = '#fff';\n    ctx.font = '600 12px Arial';\n    ctx.textAlign = 'center';\n    ctx.fillText('AI', 0, 2);\n    ctx.restore();\n\n    // draw player basket\n    ctx.save();\n    ctx.translate(player.x, player.y);\n    ctx.fillStyle = 'rgba(0,0,0,0.38)';\n    roundRect(ctx, -player.w/2+2, 10, player.w, player.h, 8, true, false);\n    ctx.fillStyle = player.color;\n    roundRect(ctx, -player.w/2, -8, player.w, player.h, 10, true, false);\n    ctx.fillStyle = '#fff';\n    ctx.font = '600 13px Arial';\n    ctx.textAlign = 'center';\n    ctx.fillText('你', 0, 2);\n    ctx.restore();\n\n    // draw separation line between AI and player area\n    ctx.strokeStyle = 'rgba(255,255,255,0.03)';\n    ctx.lineWidth = 1;\n    ctx.beginPath(); ctx.moveTo(6, ai.y + 36); ctx.lineTo(W-6, ai.y + 36); ctx.stroke();\n\n    // draw small instructions\n    ctx.fillStyle = 'rgba(255,255,255,0.07)';\n    ctx.font = '11px Arial';\n    ctx.textAlign = 'center';\n    ctx.fillText('收集宝石与星星，避免炸弹。尽量比 AI 捡到更多！', W/2, H - 18);\n  }\n\n  function drawGameOver() {\n    // overlay\n    ctx.fillStyle = 'rgba(0,0,0,0.5)';\n    ctx.fillRect(0,0,W,H);\n    ctx.fillStyle = '#fff';\n    ctx.textAlign = 'center';\n    ctx.font = '700 28px Arial';\n    ctx.fillText('游戏结束', W/2, 160);\n    ctx.font = '18px Arial';\n    ctx.fillStyle = '#9ff';\n    ctx.fillText('你的分数: ' + score, W/2, 210);\n    ctx.fillStyle = '#fdb';\n    ctx.fillText('AI 分数: ' + aiScore, W/2, 240);\n\n    let resText = '你输了';\n    if (score > aiScore) resText = '你赢了！';\n    else if (score === aiScore) resText = '平局！';\n    ctx.font = '700 22px Arial';\n    ctx.fillStyle = '#ffd';\n    ctx.fillText(resText, W/2, 288);\n\n    ctx.font = '14px Arial';\n    ctx.fillStyle = '#cfe';\n    ctx.fillText('点击\"重新开始\"再战一次', W/2, 340);\n  }\n\n  // initial draw\n  drawStartScreen();\n\n  // small helper to ensure first audio unlock on user gesture - attach to canvas touch/clicks is done.\n  // --- end of main code ---\n})();\n</script>\n</body>\n</html>",
