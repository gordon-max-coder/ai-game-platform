  let distance = 0;\n  let highScore = parseInt(localStorage.getItem('slowdown_high') || '0', 10);\n\n  // Game states\n  let state = 'menu'; // menu, playing, gameover\n  let lastTime = performance.now();\n\n  // Input\n  const keys = {};\n  let touchX = null;\n  let braking = false;\n  let pointerDown = false;\n\n  // Visual road stripes\n  const laneCount = 3;\n  const laneWidth = W / laneCount;\n  let stripeOffset = 0;\n\n  // Utility\n  function rand(min,max){ return Math.random()*(max-min)+min; }\n\n  // Reset game\n  function reset(){\n    player.x = W/2 - player.w/2;\n    player.y = H - 110;\n    player.alive = true;\n    obstacles.length = 0;\n    pickups.length = 0;\n    obstacleTimer = 0;\n    pickupTimer = 0;\n    score = 0;\n    distance = 0;\n    gameSpeed = 18.0; // start \"too fast\" deliberately\n    stripeOffset = 0;\n    braking = false;\n  }\n\n  // Spawning obstacles\n  function spawnObstacle(){\n    const lane = Math.floor(rand(0,laneCount));\n    const w = Math.floor(rand(42, 68));\n    const h = Math.floor(rand(36, 80));\n    const x = lane * laneWidth + (laneWidth - w) / 2;\n    obstacles.push({\n      x: x,\n      y: -h - rand(0,80),\n      w: w,\n      h: h,\n      color: '#E85A4F',\n      wobble: rand(-40,40),\n      angle: rand(-0.2,0.2)\n    });\n  }\n\n  // Spawning pickups\n  function spawnPickup(){\n    const lane = Math.floor(rand(0,laneCount));\n    const size = 26;\n    const x = lane * laneWidth + (laneWidth - size) / 2;\n    pickups.push({\n      x: x,\n      y: -size - rand(10,40),\n      size: size,\n      color: '#FFD166'\n    });\n  }\n\n  // Collision\n  function rectsCollide(a,b){\n    return !(a.x + a.w < b.x || a.x > b.x + (b.w||b.size) || a.y + a.h < b.y || a.y > b.y + (b.h||b.size));\n  }\n\n  // Main update\n  function update(dt){\n    if(state !== 'playing') return;\n\n    // Increase baseline speed slowly (pressure)\n    const baselineIncrease = speedIncreasePerSec * dt;\n    // If braking, reduce speed toward minSpeed quickly; else let speed drift up.\n    if(braking){\n      // braking effect stronger the faster we are\n      const brakePower = 26; // how strong manual brake is\n      gameSpeed -= brakePower * dt;\n    } else {\n      // Recover towards an increasing baseline\n      gameSpeed += baselineIncrease * Math.min(1, dt * autoRecoverRate);\n    }\n\n    // Cap speed\n    if(gameSpeed < minSpeed) gameSpeed = minSpeed;\n    if(gameSpeed > maxSpeed) gameSpeed = maxSpeed;\n\n    // Update stripe offset for road movement (visual)\n    stripeOffset += gameSpeed * dt * 30;\n    stripeOffset %= 40;\n\n    // Player lateral movement\n    let targetX = player.x;\n    // Keyboard\n    if(keys['ArrowLeft'] || keys['a'] || keys['A']) targetX -= player.speedX * dt;\n    if(keys['ArrowRight'] || keys['d'] || keys['D']) targetX += player.speedX * dt;\n    // Touch drag control\n    if(pointerDown && touchX !== null){\n      // Smooth follow finger\n      const desired = touchX - player.w / 2;\n      const diff = desired - player.x;\n      player.x += diff * Math.min(1, 10 * dt);\n    } else {\n      // Keep within road lanes boundary using targetX\n      player.x = targetX;\n    }\n\n    // Boundaries\n    if(player.x < 8) player.x = 8;\n    if(player.x + player.w > W - 8) player.x = W - 8 - player.w;\n\n    // Spawn obstacles more frequently at higher speeds\n    const obsInterval = Math.max(0.25, obstacleBaseInterval - (gameSpeed - 8) * 0.02);\n    obstacleTimer += dt;\n    if(obstacleTimer > obsInterval){\n      obstacleTimer = 0;\n      spawnObstacle();\n    }\n\n    // Spawn pickups occasionally\n    const pickInterval = Math.max(0.9, pickupSpawnIntervalBase - (gameSpeed - 8) * 0.05);\n    pickupTimer += dt;\n    if(pickupTimer > pickInterval && Math.random() < 0.9){\n      pickupTimer = 0;\n      spawnPickup();\n    }\n\n    // Update obstacles\n    for(let i=obstacles.length-1;i>=0;i--){\n      const o = obstacles[i];\n      o.y += gameSpeed * dt * 40 * 0.7 * (1 + Math.sin(o.wobble + o.y*0.02)*0.03);\n      // remove if out\n      if(o.y > H + 120) obstacles.splice(i,1);\n    }\n\n    // Update pickups\n    for(let i=pickups.length-1;i>=0;i--){\n      const p = pickups[i];\n      p.y += gameSpeed * dt * 40;\n      if(p.y > H + 40) pickups.splice(i,1);\n    }\n\n    // Check collisions\n    const pBox = {x:player.x, y:player.y, w:player.w, h:player.h};\n    // obstacles\n    for(let i=0;i<obstacles.length;i++){\n      const o = obstacles[i];\n      if(rectsCollide(pBox, o)){\n        // crash\n        player.alive = false;\n        state = 'gameover';\n        if(Math.floor(score) > highScore){\n          highScore = Math.floor(score);\n          localStorage.setItem('slowdown_high', highScore);\n        }\n        return;\n      }\n    }\n    // pickups\n    for(let i=pickups.length-1;i>=0;i--){\n      const pk = pickups[i];\n      const pkBox = {x:pk.x, y:pk.y, w:pk.size, h:pk.size};\n      if(rectsCollide(pBox, pkBox)){\n        // collect reduces speed and gives score\n        pickups.splice(i,1);\n        score += 50;\n        gameSpeed -= 3 + Math.random()*2; // instant reduction\n        if(gameSpeed < minSpeed) gameSpeed = minSpeed;\n      }\n    }\n\n    // Update score & distance (distance influenced by speed)\n    distance += gameSpeed * dt * 10;\n    score += dt * gameSpeed * 2;\n\n    // small automatic penalty for staying at top speeds (encourage using brake)\n    if(gameSpeed > 20){\n      score -= dt * (gameSpeed - 18) * 1.5; // pressure\n    }\n  }\n\n  // Draw functions\n  function draw(){\n    // background\n    ctx.fillStyle = '#1a1f2b';\n    ctx.fillRect(0,0,W,H);\n\n    // draw road with borders\n    const roadMargin = 20;\n    ctx.fillStyle = '#2b2f3a';\n    ctx.fillRect(roadMargin, 0, W - roadMargin*2, H);\n\n    // dashed center stripes / lanes\n    ctx.save();\n    ctx.clip(new Path2D());\n    ctx.translate(0, stripeOffset % 40);\n    const stripeH = 32;\n    for(let lane=1; lane<laneCount; lane++){\n      const x = lane * laneWidth;\n      ctx.fillStyle = 'rgba(255,255,255,0.06)';\n      for(let y=-40; y<H+80; y+=stripeH+16){\n        ctx.fillRect(x - 3, y, 6, stripeH);\n      }\n    }\n    ctx.restore();\n\n    // decorative roadside\n    ctx.fillStyle = '#0e6e66';\n    ctx.fillRect(0, H-60, W, 60);\n    ctx.fillStyle = '#183d3a';\n    ctx.fillRect(0, H-60, 20, 60);\n    ctx.fillRect(W-20, H-60, 20, 60);\n\n    // draw pickups\n    pickups.forEach(p=>{\n      // glow\n      ctx.fillStyle = 'rgba(255,209,102,0.12)';\n      ctx.beginPath();\n      ctx.arc(p.x + p.size/2, p.y + p.size/2, p.size, 0, Math.PI*2);\n      ctx.fill();\n      ctx.fillStyle = p.color;\n      ctx.fillRect(p.x, p.y, p.size, p.size);\n      ctx.fillStyle = '#6b3f00';\n      ctx.fillRect(p.x+6, p.y+6, p.size-12, p.size-12);\n    });\n\n    // draw obstacles\n    obstacles.forEach(o=>{\n      ctx.save();\n      ctx.translate(o.x + o.w/2, o.y + o.h/2);\n      ctx.rotate(Math.sin((o.y*0.02) + o.wobble*0.01)*0.06);\n      ctx.fillStyle = o.color;\n      ctx.fillRect(-o.w/2, -o.h/2, o.w, o.h);\n      // windows\n      ctx.fillStyle = 'rgba(0,0,0,0.15)';\n      ctx.fillRect(-o.w/4, -o.h/6, o.w/2, o.h/4);\n      ctx.restore();\n    });\n\n    // draw player\n    // slight lean based on braking\n    ctx.save();\n    const lean = (braking ? -0.06 : (keys['ArrowLeft']||keys['a'] ? -0.06 : keys['ArrowRight']||keys['d'] ? 0.06 : 0));\n    ctx.translate(player.x + player.w/2, player.y + player.h/2);\n    ctx.rotate(lean);\n    // body\n    ctx.fillStyle = player.color;\n    roundRect(ctx, -player.w/2, -player.h/2, player.w, player.h, 6, true, false);\n    // windshield\n    ctx.fillStyle = 'rgba(255,255,255,0.14)';\n    ctx.fillRect(-player.w/6, -player.h/2 + 10, player.w/3, player.h/3);\n    // wheels\n    ctx.fillStyle = '#111';\n    ctx.fillRect(-player.w/2 + 6, player.h/2 - 12, 12, 6);\n    ctx.fillRect(player.w/2 - 18, player.h/2 - 12, 12, 6);\n    ctx.restore();\n\n    // HUD - score and speed\n    ctx.fillStyle = 'rgba(0,0,0,0.4)';\n    ctx.fillRect(10,10,160,56);\n    ctx.fillStyle = '#fff';\n    ctx.font = '14px Arial';\n    ctx.fillText('得分: ' + Math.max(0, Math.floor(score)), 18, 30);\n    ctx.fillText('高分: ' + highScore, 18, 48);\n    // speed bar\n    const spX = W - 12 - 100;\n    ctx.fillStyle = 'rgba(0,0,0,0.4)';\n    ctx.fillRect(spX,10,100,56);\n    ctx.fillStyle = '#fff';\n    ctx.fillText('速度: ' + Math.floor(gameSpeed), spX+8, 30);\n    // speed meter\n    const meterH = 28;\n    const meterW = 80;\n    const meterX = spX + 10;\n    const meterY = 34;\n    const normalized = (gameSpeed - minSpeed)/(maxSpeed - minSpeed);\n    ctx.fillStyle = '#444';\n    roundRect(ctx, meterX, meterY, meterW, 8, 4, true, false);\n    ctx.fillStyle = normalized > 0.7 ? '#ff6b6b' : (normalized > 0.35 ? '#ffd166' : '#57C5A0');\n    ctx.fillRect(meterX, meterY, meterW * Math.min(1, Math.max(0, normalized)), 8);\n\n    // distance\n    ctx.fillStyle = 'rgba(255,255,255,0.9)';\n    ctx.font = '13px Arial';\n    ctx.fillText('里程: ' + Math.floor(distance) + 'm', 18, 72);\n\n    // state overlays\n    if(state === 'menu'){\n      drawMenu();\n    } else if(state === 'gameover'){\n      drawGameOver();\n    }\n  }\n\n  function drawMenu(){\n    ctx.fillStyle = 'rgba(0,0,0,0.56)';\n    ctx.fillRect(40, 140, W-80, 260);\n    ctx.fillStyle = '#fff';\n    ctx.font = '22px Arial';\n    ctx.textAlign = 'center';\n    ctx.fillText('移动速度太快了，减慢速度', W/2, 180);\n    ctx.font = '14px Arial';\n    ctx.fillText('左右移动避免障碍', W/2, 210);\n    ctx.fillText('按住屏幕或空格来刹车', W/2, 235);\n    ctx.fillText('收集黄色减速包来快速减速并得分', W/2, 260);\n    ctx.fillStyle = '#57C5A0';\n    roundRect(ctx, W/2 - 70, 300, 140, 42, 8, true, false);\n    ctx.fillStyle = '#071621';\n    ctx.font = '16px Arial';\n    ctx.fillText('开始游戏', W/2, 328);\n    ctx.textAlign = 'left';\n  }\n\n  function drawGameOver(){\n    ctx.fillStyle = 'rgba(0,0,0,0.64)';\n    ctx.fillRect(24, 120, W-48, 320);\n    ctx.fillStyle = '#fff';\n    ctx.font =