h.sin(o.wobble + o.y*0.02)*0.03);\n      // remove if out\n      if(o.y > H + 120) obstacles.splice(i,1);\n    }\n\n    // Update pickups\n    for(let i=pickups.length-1;i>=0;i--){\n      const p = pickups[i];\n      p.y += gameSpeed * dt * 40;\n      if(p.y > H + 40) pickups.splice(i,1);\n    }\n\n    // Check collisions\n    const pBox = {x:player.x, y:player.y, w:player.w, h:player.h};\n    // obstacles\n    for(let i=0;i<obstacles.length;i++){\n      const o = obstacles[i];\n      if(rectsCollide(pBox, o)){\n        // crash\n        player.alive = false;\n        state = 'gameover';\n        if(Math.floor(score) > highScore){\n          highScore = Math.floor(score);\n          localStorage.setItem('slowdown_high', highScore);\n        }\n        return;\n      }\n    }\n    // pickups\n    for(let i=pickups.length-1;i>=0;i--){\n      const pk = pickups[i];\n      const pkBox = {x:pk.x, y:pk.y, w:pk.size, h:pk.size};\n      if(rectsCollide(pBox, pkBox)){\n        // collect reduces speed and gives score\n        pickups.splice(i,1);\n        score += 50;\n        gameSpeed -= 3 + Math.random()*2; // instant reduction\n        if(gameSpeed < minSpeed) gameSpeed = minSpeed;\n      }\n    }\n\n    // Update score & distance (distance influenced by speed)\n    distance += gameSpeed * dt * 10;\n    score += dt * gameSpeed * 2;\n\n    // small automatic penalty for staying at top speeds (encourage using brake)\n    if(gameSpeed > 20){\n      score -= dt * (gameSpeed - 18) * 1.5; // pressure\n    }\n  }\n\n  // Draw functions\n  function draw(){\n    // background\n    ctx.fillStyle = '#1a1f2b';\n    ctx.fillRect(0,0,W,H);\n\n    // draw road with borders\n    const roadMargin = 20;\n    ctx.fillStyle = '#2b2f3a';\n    ctx.fillRect(roadMargin, 0, W - roadMargin*2, H);\n\n    // dashed center stripes / lanes\n    ctx.save();\n    ctx.clip(new Path2D());\n    ctx.translate(0, stripeOffset % 40);\n    const stripeH = 32;\n    for(let lane=1; lane<laneCount; lane++){\n      const x = lane * laneWidth;\n      ctx.fillStyle = 'rgba(255,255,255,0.06)';\n      for(let y=-40; y<H+80; y+=stripeH+16){\n        ctx.fillRect(x - 3, y, 6, stripeH);\n      }\n    }\n    ctx.restore();\n\n    // decorative roadside\n    ctx.fillStyle = '#0e6e66';\n    ctx.fillRect(0, H-60, W, 60);\n    ctx.fillStyle = '#183d3a';\n    ctx.fillRect(0, H-60, 20, 60);\n    ctx.fillRect(W-20, H-60, 20, 60);\n\n    // draw pickups\n    pickups.forEach(p=>{\n      // glow\n      ctx.fillStyle = 'rgba(255,209,102,0.12)';\n      ctx.beginPath();\n      ctx.arc(p.x + p.size/2, p.y + p.size/2, p.size, 0, Math.PI*2);\n      ctx.fill();\n      ctx.fillStyle = p.color;\n      ctx.fillRect(p.x, p.y, p.size, p.size);\n      ctx.fillStyle = '#6b3f00';\n      ctx.fillRect(p.x+6, p.y+6, p.size-12, p.size-12);\n    });\n\n    // draw obstacles\n    obstacles.forEach(o=>{\n      ctx.save();\n      ctx.translate(o.x + o.w/2, o.y + o.h/2);\n      ctx.rotate(Math.sin((o.y*0.02) + o.wobble*0.01)*0.06);\n      ctx.fillStyle = o.color;\n      ctx.fillRect(-o.w/2, -o.h/2, o.w, o.h);\n      // windows\n      ctx.fillStyle = 'rgba(0,0,0,0.15)';\n      ctx.fillRect(-o.w/4, -o.h/6, o.w/2, o.h/4);\n      ctx.restore();\n    });\n\n    // draw player\n    // slight lean based on braking\n    ctx.save();\n    const lean = (braking ? -0.06 : (keys['ArrowLeft']||keys['a'] ? -0.06 : keys['ArrowRight']||keys['d'] ? 0.06 : 0));\n    ctx.translate(player.x + player.w/2, player.y + player.h/2);\n    ctx.rotate(lean);\n    // body\n    ctx.fillStyle = player.color;\n    roundRect(ctx, -player.w/2, -player.h/2, player.w, player.h, 6, true, false);\n    // windshield\n    ctx.fillStyle = 'rgba(255,255,255,0.14)';\n    ctx.fillRect(-player.w/6, -player.h/2 + 10, player.w/3, player.h/3);\n    // wheels\n    ctx.fillStyle = '#111';\n    ctx.fillRect(-player.w/2 + 6, player.h/2 - 12, 12, 6);\n    ctx.fillRect(player.w/2 - 18, player.h/2 - 12, 12, 6);\n    ctx.restore();\n\n    // HUD - score and speed\n    ctx.fillStyle = 'rgba(0,0,0,0.4)';\n    ctx.fillRect(10,10,160,56);\n    ctx.fillStyle = '#fff';\n    ctx.font = '14px Arial';\n    ctx.fillText('得分: ' + Math.max(0, Math.floor(score)), 18, 30);\n    ctx.fillText('高分: ' + highScore, 18, 48);\n    // speed bar\n    const spX = W - 12 - 100;\n    ctx.fillStyle = 'rgba(0,0,0,0.4)';\n    ctx.fillRect(spX,10,100,56);\n    ctx.fillStyle = '#fff';\n    ctx.fillText('速度: ' + Math.floor(gameSpeed), spX+8, 30);\n    // speed meter\n    const meterH = 28;\n    const meterW = 80;\n    const meterX = spX + 10;\n    const meterY = 34;\n    const normalized = (gameSpeed - minSpeed)/(maxSpeed - minSpeed);\n    ctx.fillStyle = '#444';\n    roundRect(ctx, meterX, meterY, meterW, 8, 4, true, false);\n    ctx.fillStyle = normalized > 0.7 ? '#ff6b6b' : (normalized > 0.35 ? '#ffd166' : '#57C5A0');\n    ctx.fillRect(meterX, meterY, meterW * Math.min(1, Math.max(0, normalized)), 8);\n\n    // distance\n    ctx.fillStyle = 'rgba(255,255,255,0.9)';\n    ctx.font = '13px Arial';\n    ctx.fillText('里程: ' + Math.floor(distance) + 'm', 18, 72);\n\n    // state overlays\n    if(state === 'menu'){\n      drawMenu();\n    } else if(state === 'gameover'){\n      drawGameOver();\n    }\n  }\n\n  function drawMenu(){\n    ctx.fillStyle = 'rgba(0,0,0,0.56)';\n    ctx.fillRect(40, 140, W-80, 260);\n    ctx.fillStyle = '#fff';\n    ctx.font = '22px Arial';\n    ctx.textAlign = 'center';\n    ctx.fillText('移动速度太快了，减慢速度', W/2, 180);\n    ctx.font = '14px Arial';\n    ctx.fillText('左右移动避免障碍', W/2, 210);\n    ctx.fillText('按住屏幕或空格来刹车', W/2, 235);\n    ctx.fillText('收集黄色减速包来快速减速并得分', W/2, 260);\n    ctx.fillStyle = '#57C5A0';\n    roundRect(ctx, W/2 - 70, 300, 140, 42, 8, true, false);\n    ctx.fillStyle = '#071621';\n    ctx.font = '16px Arial';\n    ctx.fillText('开始游戏', W/2, 328);\n    ctx.textAlign = 'left';\n  }\n\n  function drawGameOver(){\n    ctx.fillStyle = 'rgba(0,0,0,0.64)';\n    ctx.fillRect(24, 120, W-48, 320);\n    ctx.fillStyle = '#fff';\n    ctx.font = '26px Arial';\n    ctx.textAlign = 'center';\n    ctx.fillText('撞毁了！', W/2, 170);\n    ctx.font = '18px Arial';\n    ctx.fillText('最终得分: ' + Math.max(0, Math.floor(score)), W/2, 210);\n    ctx.fillText('里程: ' + Math.floor(distance) + 'm', W/2, 240);\n    ctx.fillStyle = '#ffd166';\n    roundRect(ctx, W/2 - 90, 280, 180, 46, 8, true, false);\n    ctx.fillStyle = '#072a1c';\n    ctx.font = '16px Arial';\n    ctx.fillText('再试一次', W/2, 310);\n    ctx.font = '12px Arial';\n    ctx.fillStyle = '#ddd';\n    ctx.fillText('高分: ' + highScore, W/2, 350);\n    ctx.textAlign = 'left';\n  }\n\n  // helpers\n  function roundRect(ctx, x, y, w, h, r, fill, stroke){\n    if (typeof r === 'undefined') r = 5;\n    ctx.beginPath();\n    ctx.moveTo(x+r, y);\n    ctx.arcTo(x+w, y, x+w, y+h, r);\n    ctx.arcTo(x+w, y+h, x, y+h, r);\n    ctx.arcTo(x, y+h, x, y, r);\n    ctx.arcTo(x, y, x+w, y, r);\n    ctx.closePath();\n    if(fill) ctx.fill();\n    if(stroke) ctx.stroke();\n  }\n\n  // Main loop\n  function loop(now){\n    const dt = Math.min(0.05, (now - lastTime) / 1000);\n    lastTime = now;\n    update(dt);\n    draw();\n    requestAnimationFrame(loop);\n  }\n\n  // Input handlers\n  window.addEventListener('keydown', (e)=>{\n    keys[e.key] = true;\n    if(e.code === 'Space'){\n      braking = true;\n    }\n    if(state === 'menu' && (e.key === 'Enter' || e.code === 'Space')){\n      reset();\n      state = 'playing';\n    }\n    if(state === 'gameover' && (e.key === 'Enter' || e.code === 'Space')){\n      reset();\n      state = 'playing';\n    }\n  });\n  window.addEventListener('keyup', (e)=>{\n    keys[e.key] = false;\n    if(e.code === 'Space'){\n      braking = false;\n    }\n  });\n\n  // Mouse / pointer for braking and dragging\n  canvas.addEventListener('pointerdown', (e)=>{\n    pointerDown = true;\n    braking = true;\n    const rect = canvas.getBoundingClientRect();\n    const scaleX = canvas.width / rect.width;\n    touchX = (e.clientX - rect.left) * scaleX;\n    // if in menu or gameover, start/restart if tapping central button area\n    if(state === 'menu'){\n      // Start\n      reset();\n      state = 'playing';\n    } else if(state === 'gameover'){\n      // Restart\n      reset();\n      state = 'playing';\n    }\n    canvas.setPointerCapture(e.pointerId);\n  });\n  canvas.addEventListener('pointermove', (e)=>{\n    if(!pointerDown) return;\n    const rect = canvas.getBoundingClientRect();\n    const scaleX = canvas.width / rect.width;\n    touchX = (e.clientX - rect.left) * scaleX;\n  });\n  canvas.addEventListener('pointerup', (e)=>{\n    pointerDown = false;\n    braking = false;\n    touchX = null;\n    try{ canvas.releasePointerCapture(e.pointerId); }catch(err){}\n  });\n  canvas.addEventListener('pointercancel', (e)=>{\n    pointerDown = false;\n    braking = false;\n    touchX = null;\n  });\n\n  // Click to toggle menu buttons (for devices where pointer isn't used)\n  canvas.addEventListener('click', function(e){\n    if(state === 'menu'){\n      reset();\n      state = 'playing';\n    } else if(state === 'gameover'){\n      reset();\n      state = 'playing';\n    }\n  });\n\n  // Start loop\n  lastTime = performance.now();\n  draw(); // initial draw\n  requestAnimationFrame(loop);\n\n  // Expose for debug (optional)\n  window.__game = { reset };\n})();\n</script>\n</body>\n</html>"
