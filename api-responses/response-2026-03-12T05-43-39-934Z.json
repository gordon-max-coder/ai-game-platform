          "content": "<!doctype html>\n<html lang=\"zh-CN\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>贪食蛇 - Canvas 360x640</title>\n  <style>\n    html,body {\n      height: 100%;\n      margin: 0;\n      background: linear-gradient(180deg,#0b1220,#071428);\n      color: #fff;\n      font-family: -apple-system,BlinkMacSystemFont,\"Segoe UI\",\"PingFang SC\",\"Hiragino Sans GB\", \"Microsoft YaHei\", sans-serif;\n      -webkit-tap-highlight-color: transparent;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      padding: 18px 8px;\n      box-sizing: border-box;\n    }\n\n    /* Required by the user */\n    canvas { max-width: 100%; height: auto; display: block; margin: 0 auto; }\n\n    .hint {\n      position: absolute;\n      top: 14px;\n      left: 50%;\n      transform: translateX(-50%);\n      font-size: 13px;\n      color: rgba(255,255,255,0.85);\n      background: rgba(0,0,0,0.18);\n      padding: 6px 10px;\n      border-radius: 12px;\n      backdrop-filter: blur(6px);\n      pointer-events: none;\n    }\n\n    .buttons {\n      position: absolute;\n      bottom: 18px;\n      left: 50%;\n      transform: translateX(-50%);\n      display: flex;\n      gap: 10px;\n    }\n\n    button {\n      font-size: 14px;\n      padding: 8px 12px;\n      border-radius: 8px;\n      border: none;\n      background: rgba(255,255,255,0.06);\n      color: #fff;\n      cursor: pointer;\n      box-shadow: 0 2px 8px rgba(0,0,0,0.4);\n    }\n\n    button:active { transform: translateY(1px); }\n    a.small {\n      display:inline-block;\n      margin-left:8px;\n      color: rgba(255,255,255,0.8);\n      font-size:12px;\n      text-decoration: none;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"hint\">方向键 / WASD 控制，或滑动屏幕。按 P 暂停，Enter 重玩</div>\n  <canvas id=\"game\"></canvas>\n\n  <div class=\"buttons\" aria-hidden=\"true\">\n    <button id=\"pauseBtn\">暂停</button>\n    <button id=\"restartBtn\">重玩</button>\n  </div>\n\n  <script>\n  // Canvas requirements\n  const canvas = document.getElementById('game');\n  const ctx = canvas.getContext('2d');\n  canvas.width = 360; // 必须这样设置\n  canvas.height = 640; // 必须这样设置\n\n  // Constants for grid\n  const TILE = 20;\n  const COLS = Math.floor(canvas.width / TILE); // 18\n  const ROWS = Math.floor(canvas.height / TILE); // 32\n\n  // Game variables\n  let snake = [];\n  let dir = { x: 1, y: 0 };\n  let nextDir = { x: 1, y: 0 };\n  let apple = null;\n  let goldenApple = null;\n  let goldenTimer = 0;\n  let particles = [];\n  let score = 0;\n  let highScore = parseInt(localStorage.getItem('snake_highscore_v1') || '0', 10);\n  let gameOver = false;\n  let paused = false;\n  let lastTime = 0;\n  let accumulator = 0;\n  let speed = 6; // moves per second\n  const baseSpeed = 6;\n  const maxSpeed = 18;\n  const speedUpEvery = 5; // 每吃几个苹果加速一次\n  let movesSinceLastSpeedUp = 0;\n  let moveInterval = 1000 / speed; // ms per move\n\n  // For touch controls\n  let touchStart = null;\n\n  // Colors\n  const colors = {\n    bg1: '#071428',\n    bg2: '#0b1220',\n    grid: 'rgba(255,255,255,0.03)',\n    snakeHead: '#6ef4a1',\n    snakeBodyA: '#39d98a',\n    snakeBodyB: '#1f7d57',\n    apple: '#ff4d6d',\n    golden: '#ffd166',\n    text: '#e6f7ff'\n  };\n\n  // Initialize\n  function init() {\n    snake = [];\n    const startLen = 5;\n    const startX = Math.floor(COLS / 2);\n    const startY = Math.floor(ROWS / 2);\n    for (let i = 0; i < startLen; i++) {\n      snake.push({ x: startX - i, y: startY });\n    }\n    dir = { x: 1, y: 0 };\n    nextDir = { x: 1, y: 0 };\n    score = 0;\n    speed = baseSpeed;\n    moveInterval = 1000 / speed;\n    movesSinceLastSpeedUp = 0;\n    gameOver = false;\n    paused = false;\n    placeApple();\n    goldenApple = null;\n    goldenTimer = randRange(5000, 15000); // ms until golden apple can appear\n    particles = [];\n    lastTime = performance.now();\n    accumulator = 0;\n  }\n\n  // Helpers\n  function randRange(a, b) {\n    return Math.floor(Math.random() * (b - a + 1)) + a;\n  }\n\n  function placeApple() {\n    const occupied = new Set(snake.map(s => s.x + ':' + s.y));\n    let px, py;\n    do {\n      px = Math.floor(Math.random() * COLS);\n      py = Math.floor(Math.random() * ROWS);\n    } while (occupied.has(px + ':' + py));\n    apple = { x: px, y: py };\n  }\n\n  function placeGolden() {\n    if (goldenApple) return;\n    const occupied = new Set(snake.map(s => s.x + ':' + s.y));\n    occupied.add(apple.x + ':' + apple.y);\n    let px, py;\n    let attempts = 0;\n    do {\n      px = Math.floor(Math.random() * COLS);\n      py = Math.floor(Math.random() * ROWS);\n      attempts++;\n      if (attempts > 200) break;\n    } while (occupied.has(px + ':' + py));\n    goldenApple = { x: px, y: py, life: 7000 }; // golden apple lasts 7s\n  }\n\n  function collideSelf(x, y) {\n    return snake.some(seg => seg.x === x && seg.y === y);\n  }\n\n  // Game update (discrete grid updates)\n  function update() {\n    if (gameOver || paused) return;\n\n    // Apply next direction (prevent reversing)\n    if ((nextDir.x !== -dir.x || nextDir.y !== -dir.y) || snake.length === 1) {\n      dir = nextDir;\n    }\n\n    const head = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };\n\n    // Wall collision -> game over\n    if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS) {\n      endGame();\n      return;\n    }\n    // Self collision\n    if (collideSelf(head.x, head.y)) {\n      endGame();\n      return;\n    }\n\n    // Move snake\n    snake.unshift(head);\n\n    // Eat apple?\n    if (apple && head.x === apple.x && head.y === apple.y) {\n      eatApple(false);\n    } else if (goldenApple && head.x === goldenApple.x && head.y === goldenApple.y) {\n      eatApple(true);\n    } else {\n      snake.pop();\n    }\n\n    // Golden apple timer countdown\n    if (!goldenApple) {\n      goldenTimer -= moveInterval;\n      if (goldenTimer <= 0) {\n        placeGolden();\n      }\n    } else {\n      goldenApple.life -= moveInterval;\n      if (goldenApple.life <= 0) {\n        goldenApple = null;\n        goldenTimer = randRange(8000, 18000);\n      }\n    }\n  }\n\n  function eatApple(isGolden) {\n    if (isGolden) {\n      const gain = 5 + Math.floor(score / 10);\n      score += gain;\n      // Golden apple gives speed boost temporarily\n      speed = Math.min(maxSpeed, speed + 2);\n      moveInterval = 1000 / speed;\n      spawnParticles(apple.x * TILE + TILE / 2, apple.y * TILE + TILE / 2, 18, colors.golden);\n      goldenApple = null;\n      goldenTimer = randRange(12000, 22000);\n      placeApple();\n      movesSinceLastSpeedUp = 0;\n    } else {\n      score += 1;\n      spawnParticles(apple.x * TILE + TILE / 2, apple.y * TILE + TILE / 2, 10, colors.apple);\n      placeApple();\n      movesSinceLastSpeedUp++;\n      // Speed up every few apples\n      if (movesSinceLastSpeedUp >= speedUpEvery) {\n        speed = Math.min(maxSpeed, speed + 1);\n        moveInterval = 1000 / speed;\n        movesSinceLastSpeedUp = 0;\n      }\n    }\n    // Update high score\n    if (score > highScore) {\n      highScore = score;\n      localStorage.setItem('snake_highscore_v1', highScore);\n    }\n  }\n\n  function endGame() {\n    gameOver = true;\n    spawnParticles(snake[0].x * TILE + TILE / 2, snake[0].y * TILE + TILE / 2, 26, '#ff8080');\n  }\n\n  // Particle system for nice visuals\n  function spawnParticles(x, y, n, color) {\n    for (let i = 0; i < n; i++) {\n      const angle = Math.random() * Math.PI * 2;\n      const speed = Math.random() * 2 + 0.6;\n      particles.push({\n        x: x,\n        y: y,\n        vx: Math.cos(angle) * speed,\n        vy: Math.sin(angle) * speed,\n        life: Math.random() * 600 + 400,\n        age: 0,\n        color: color,\n        size: Math.random() * 3 + 1\n      });\n    }\n  }\n\n  function updateParticles(dt) {\n    for (let i = particles.length - 1; i >= 0; i--) {\n      const p = particles[i];\n      p.vy += 0.02 * dt; // slight gravity\n      p.x += p.vx * dt;\n      p.y += p.vy * dt;\n      p.age += dt;\n      if (p.age >= p.life) particles.splice(i, 1);\n    }\n  }\n\n  // Draw functions\n  function drawBackground() {\n    const g = ctx.createLinearGradient(0, 0, 0, canvas.height);\n    g.addColorStop(0, colors.bg1);\n    g.addColorStop(1, colors.bg2);\n    ctx.fillStyle = g;\n    ctx.fillRect(0, 0, canvas.width, canvas.height);\n\n    // subtle grid\n    ctx.strokeStyle = colors.grid;\n    ctx.lineWidth = 1;\n    ctx.beginPath();\n    for (let x = 0; x <= COLS; x++) {\n      const px = x * TILE + 0.5;\n      ctx.moveTo(px, 0);\n      ctx.lineTo(px, canvas.height);\n    }\n    for (let y = 0; y <= ROWS; y++) {\n      const py = y * TILE + 0.5;\n      ctx.moveTo(0, py);\n      ctx.lineTo(canvas.width, py);\n    }\n    ctx.stroke();\n  }\n\n  function drawSnake() {\n    // Draw body\n    for (let i = snake.length - 1; i >= 0; i--) {\n      const s = snake[i];\n      const x = s.x * TILE;\n      const y = s.y * TILE;\n      const t = i % 2 === 0 ? colors.snakeBodyA : colors.snakeBodyB;\n      ctx.fillStyle = t;\n      roundRect(ctx, x + 1, y + 1, TILE - 2, TILE - 2, 4);\n      ctx.fill();\n    }\n    // Head\n    const head = snake[0];\n    ctx.fillStyle = colors.snakeHead;\n    roundRect(ctx, head.x * TILE + 1, head.y * TILE + 1, TILE - 2, TILE - 2, 4);\n    ctx.fill();\n\n    // Eye\n    ctx.fillStyle = '#072117';\n    const hx = head.x * TILE;\n    const hy = head.y * TILE;\n    let ex = hx + (dir.x > 0 ? TILE * 0.7 : dir.x < 0 ? TILE * 0.3 : TILE * 0.5);\n    let ey = hy + (dir.y > 0 ? TILE * 0.7 : dir.y < 0 ? TILE * 0.3 : TILE * 0.4);\n    ctx.beginPath();\n    ctx.arc(ex, ey, 2.2, 0, Math.PI * 2);\n    ctx.fill();\n  }\n\n  function drawApples() {\n    // Regular apple with simple shine\n    if (apple) {\n      const ax = apple.x * TILE;\n      const ay = apple.y * TILE;\n      drawCircleCell(ax + TILE / 2, ay + TILE / 2, TILE * 0.38, colors.apple);\n      // leaf\n      ctx.fillStyle = '#2b8b5c';\n      ctx.beginPath();\n      ctx.ellipse(ax + TILE / 2 - 2, ay + TILE / 2 - TILE * 0.45, 3, 6, -0.5, 0, Math.PI * 2);\n      ctx.fill();\n    }\n    if (goldenApple) {\n      const ax = goldenApple.x * TILE;\n      const ay = goldenApple.y * TILE;\n      drawCircleCell(ax + TILE / 2, ay + TILE / 2, TILE * 0.44, colors.golden, true);\n      // small glow\n      const g = ctx.createRadialGradient(ax + TILE / 2, ay + TILE / 2, 2, ax + TILE / 2, ay + TILE / 2, TILE);\n      g.addColorStop(0, 'rgba(255,210,110,0.9)');\n      g.addColorStop(1, 'rgba(255,210,110,0)');\n      ctx.fillStyle = g;\n      ctx.beginPath();\n      ctx.arc(ax + TILE / 2, ay + TILE / 2, TILE * 0.9, 0, Math.PI * 2);\n      ctx.fill();\n    }\n  }\n\n  function drawCircleCell(cx, cy, r, color, shiny=false) {\n    ctx.fillStyle = color;\n    ctx.beginPath();\n    ctx.arc(cx, cy, r, 0, Math.PI * 2);\n    ctx.fill();\n    // shine\n    if (!shiny) {\n      ctx.fillStyle = 'rgba(255,255,255,0.18)';\n      ctx.beginPath();\n      ctx.ellipse(cx - r * 0.4, cy - r * 0.6, r * 0.45, r * 0.25, -0.4, 0, Math.PI * 2);\n      ctx.fill();\n    } else {\n      ctx.fillStyle = 'rgba(255,255,255,0.22)';\n      ctx.beginPath();\n      ctx.ellipse(cx - r * 0.2, cy - r * 0.55, r * 0.36, r * 0.22, -0.5, 0, Math.PI * 2);\n      ctx.fill();\n    }\n  }\n\n  function drawParticles() {\n    for (const p of particles) {\n      const alpha = 1 - p.age / p.life;\n      ctx.fillStyle = hexToRgba(p.color, alpha);\n      ctx.beginPath();\n      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);\n      ctx.fill();\n    }\n  }\n\n  function drawHud() {\n    // Top panel\n    const pad = 8;\n    const panelW = canvas.width - pad * 2;\n    ctx.fillStyle = 'rgba(0,0,0,0.25)';\n    roundRect(ctx, pad, pad, panelW, 36, 8);\n    ctx.fill();\n\n    ctx.fillStyle = colors.text;\n    ctx.font = 'bold 16px Arial';\n    ctx.textAlign = 'left';\n    ctx.textBaseline = 'middle';\n    ctx.fillText('得分: ' + score, pad + 10, pad + 18);\n\n    ctx.textAlign = 'right';\n    ctx.fillStyle = 'rgba(255,255,255,0.85)';\n    ctx.fillText('最高: ' + highScore, canvas.width - pad - 10, pad + 18);\n\n    // center small message\n    if (paused) {\n      ctx.fillStyle = 'rgba(255,255,255,0.9)';\n      ctx.font = '600 14px Arial';\n      ctx.textAlign = 'center';\n      ctx.fillText('已暂停', canvas.width / 2, pad + 18);\n    }\n    if (gameOver) {\n      // overlay\n      ctx.fillStyle = 'rgba(0,0,0,0.45)';\n      ctx.fillRect(0, 0, canvas.width, canvas.height);\n      ctx.fillStyle = 'rgba(255,255,255,0.98)';\n      ctx.textAlign = 'center';\n      ctx.font = '700 34px Arial';\n      ctx.fillText('游戏结束', canvas.width / 2, canvas.height / 2 - 24);\n      ctx.font = '600 18px Arial';\n      ctx.fillText('得分: ' + score, canvas.width / 2, canvas.height / 2 + 6);\n      ctx.font = '500 14px Arial';\n      ctx.fillText('按 Enter 或 点击 重玩', canvas.width / 2, canvas.height / 2 + 40);\n    }\n  }\n\n  // Utility draw helpers\n  function roundRect(ctx, x, y, w, h, r) {\n    const radius = r || 4;\n    ctx.beginPath();\n    ctx.moveTo(x + radius, y);\n    ctx.arcTo(x + w, y, x + w, y + h, radius);\n    ctx.arcTo(x + w, y + h, x, y + h, radius);\n    ctx.arcTo(x, y + h, x, y, radius);\n    ctx.arcTo(x, y, x + w, y, radius);\n    ctx.closePath();\n  }\n\n  function hexToRgba(hex, a) {\n    // hex like #rrggbb or #rgb\n    let c = hex.replace('#','');\n    if (c.length === 3) c = c.split('').map(s => s + s).join('');\n    const num = parseInt(c, 16);\n    const r = (num >> 16) & 255;\n    const g = (num >> 8) & 255;\n    const b = num & 255;\n    return 'rgba(' + r + ',' + g + ',' + b + ',' + (a || 1) + ')';\n  }\n\n  // Main loop\n  function loop(now) {\n    const dtMs = now - lastTime;\n    lastTime = now;\n\n    // Limit dt to avoid jump on tab switch\n    const maxDt = 100;\n    const dt = Math.min(dtMs, maxDt);\n\n    if (!paused && !gameOver) {\n      accumulator += dt;\n      // ensure updates occur at consistent intervals based on current speed\n      while (accumulator >= moveInterval) {\n        update();\n        accumulator -= moveInterval;\n      }\n    }\n\n    updateParticles(dt);\n\n    // Render\n    drawBackground();\n    drawApples();\n    drawSnake();\n    drawParticles();\n    drawHud();\n\n    requestAnimationFrame(loop);\n  }\n\n  // Controls\n  window.addEventListener('keydown', (e) => {\n    if (e.key === 'ArrowUp' || e.key === 'w' || e.key === 'W') setNextDir(0, -1);\n    if (e.key === 'ArrowDown' || e.key === 's' || e.key === 'S') setNextDir(0, 1);\n    if (e.key === 'ArrowLeft' || e.key === 'a' || e.key === 'A') setNextDir(-1, 0);\n    if (e.key === 'ArrowRight' || e.key === 'd' || e.key === 'D') setNextDir(1, 0);\n    if (e.key === 'p' || e.key === 'P' || e.code === 'Space') togglePause();\n    if (e.key === 'Enter') {\n      if (gameOver) init();\n    }\n  });\n\n  function setNextDir(x, y) {\n    // Prevent immediate reverse on single-cell snake edge-case handled in update\n    if (!gameOver && !paused) {\n      if (nextDir.x === x && nextDir.y === y) return;\n      // Prevent reversing into itself unless length == 1\n      if (snake.length > 1 && x === -dir.x && y === -dir.y) return;\n      nextDir = { x, y };\n    }\n  }\n\n  // Touch swipe\n  canvas.addEventListener('touchstart', (e) => {\n    if (e.touches.length === 1) {\n      const t = e.touches[0];\n      touchStart = { x: t.clientX, y: t.clientY, time: performance.now() };\n    }\n    e.preventDefault();\n  }, {passive:false});\n\n  canvas.addEventListener('touchend', (e) => {\n    if (!touchStart) return;\n    const t = e.changedTouches[0];\n    const dx = t.clientX - touchStart.x;\n    const dy = t.clientY - touchStart.y;\n    const absX = Math.abs(dx);\n    const absY = Math.abs(dy);\n    if (Math.max(absX, absY) > 20) {\n      if (absX > absY) {\n        setNextDir(dx > 0 ? 1 : -1, 0);\n      } else {\n        setNextDir(0, dy > 0 ? 1 : -1);\n      }\n    } else {\n      // tap toggles pause when small touch\n      togglePause();\n    }\n    touchStart = null;\n    e.preventDefault();\n  }, {passive:false});\n\n  // Buttons\n  document.getElementById('pauseBtn').addEventListener('click', () => {\n    togglePause();\n  });\n  document.getElementById('restartBtn').addEventListener('click', () => {\n    init();\n  });\n\n  function togglePause() {\n    if (gameOver) return;\n    paused = !paused;\n    document.getElementById('pauseBtn').textContent = paused ? '继续' : '暂停';\n  }\n\n  // Start game\n  init();\n  requestAnimationFrame(loop);\n\n  </script>\n</body>\n</html>"
