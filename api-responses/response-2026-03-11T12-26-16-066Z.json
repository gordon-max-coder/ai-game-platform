  "gameCode": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\">\n    <title>经典贪食蛇</title>\n    <style>\n        body { background: #222; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; color: white; font-family: sans-serif; }\n        canvas { max-width: 100%; height: auto; display: block; margin: 0 auto; background: #000; border: 2px solid #555; }\n        #ui { position: absolute; top: 10px; text-align: center; pointer-events: none; }\n    </style>\n</head>\n<body>\n    <div id=\"ui\">得分: <span id=\"score\">0</span></div>\n    <canvas id=\"gameCanvas\"></canvas>\n\n    <script>\n        const canvas = document.getElementById('gameCanvas');\n        const ctx = canvas.getContext('2d');\n        const scoreElement = document.getElementById('score');\n\n        canvas.width = 360;\n        canvas.height = 640;\n\n        const gridSize = 20;\n        let snake = [{x: 180, y: 320}];\n        let food = {x: 0, y: 0};\n        let dx = gridSize, dy = 0;\n        let score = 0;\n        let gameRunning = true;\n\n        function spawnFood() {\n            food.x = Math.floor(Math.random() * (canvas.width / gridSize)) * gridSize;\n            food.y = Math.floor(Math.random() * (canvas.height / gridSize)) * gridSize;\n        }\n\n        function draw() {\n            if (!gameRunning) return;\n\n            // 移动\n            const head = {x: snake[0].x + dx, y: snake[0].y + dy};\n            \n            // 撞墙/自身检测\n            if (head.x < 0 || head.x >= canvas.width || head.y < 0 || head.y >= canvas.height || \n                snake.some(segment => segment.x === head.x && segment.y === head.y)) {\n                gameRunning = false;\n                alert(\"游戏结束！得分: \" + score);\n                location.reload();\n                return;\n            }\n\n            snake.unshift(head);\n\n            // 吃食物\n            if (head.x === food.x && head.y === food.y) {\n                score += 10;\n                scoreElement.innerText = score;\n                spawnFood();\n            } else {\n                snake.pop();\n            }\n\n            // 渲染\n            ctx.fillStyle = 'black';\n            ctx.fillRect(0, 0, canvas.width, canvas.height);\n            \n            ctx.fillStyle = 'red';\n            ctx.fillRect(food.x, food.y, gridSize - 2, gridSize - 2);\n            \n            ctx.fillStyle = 'lime';\n            snake.forEach(part => ctx.fillRect(part.x, part.y, gridSize - 2, gridSize - 2));\n        }\n\n        window.addEventListener('keydown', e => {\n            if(e.key === 'ArrowUp' && dy === 0) { dx = 0; dy = -gridSize; }\n            if(e.key === 'ArrowDown' && dy === 0) { dx = 0; dy = gridSize; }\n            if(e.key === 'ArrowLeft' && dx === 0) { dx = -gridSize; dy = 0; }\n            if(e.key === 'ArrowRight' && dx === 0) { dx = gridSize; dy = 0; }\n        });\n\n        // 移动端触摸控制\n        let touchStartX = 0, touchStartY = 0;\n        window.addEventListener('touchstart', e => {\n            touchStartX = e.touches[0].clientX;\n            touchStartY = e.touches[0].clientY;\n        });\n        window.addEventListener('touchend', e => {\n            let dxTouch = e.changedTouches[0].clientX - touchStartX;\n            let dyTouch = e.changedTouches[0].clientY - touchStartY;\n            if (Math.abs(dxTouch) > Math.abs(dyTouch)) {\n                if (dxTouch > 0 && dx === 0) { dx = gridSize; dy = 0; }\n                else if (dxTouch < 0 && dx === 0) { dx = -gridSize; dy = 0; }\n            } else {\n                if (dyTouch > 0 && dy === 0) { dx = 0; dy = gridSize; }\n                else if (dyTouch < 0 && dy === 0) { dx = 0; dy = -gridSize; }\n            }\n        });\n\n        spawnFood();\n        setInterval(draw, 100);\n    </script>\n</body>\n</html>",
