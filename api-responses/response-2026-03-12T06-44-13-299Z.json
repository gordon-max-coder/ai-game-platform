          "role": "assistant",
          "content": "<!doctype html>\n<html lang=\"zh-CN\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no\" />\n<title>贪食蛇 Canvas 游戏</title>\n<style>\n  html,body{\n    height:100%;\n    margin:0;\n    background: #0b1020;\n    font-family: \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n    color:#fff;\n    -webkit-tap-highlight-color: transparent;\n  }\n  .container{\n    max-width:360px;\n    margin:10px auto;\n    text-align:center;\n  }\n  canvas { max-width: 100%; height: auto; display: block; margin: 0 auto; } /* required */\n  .hud{\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    margin:8px 0;\n    gap:8px;\n  }\n  .scoreBox{\n    background: rgba(255,255,255,0.04);\n    padding:6px 10px;\n    border-radius:6px;\n    font-size:14px;\n  }\n  .controls{\n    position: relative;\n    width:360px;\n    margin: 8px auto 0;\n    height:120px;\n    touch-action: none;\n    -webkit-user-select:none;\n    user-select:none;\n  }\n  .dpad{\n    position:absolute;\n    left:8px;\n    bottom:8px;\n    width:140px;\n    height:140px;\n    pointer-events:auto;\n  }\n  .dpad .btn{\n    position:absolute;\n    width:62px;\n    height:62px;\n    border-radius:12px;\n    background: rgba(255,255,255,0.06);\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    color:#fff;\n    font-size:20px;\n    -webkit-tap-highlight-color: transparent;\n  }\n  .dpad .up{left:39px; top:0;}\n  .dpad .down{left:39px; bottom:0;}\n  .dpad .left{left:0; top:39px;}\n  .dpad .right{right:0; top:39px;}\n  .dpad .btn:active{ background: rgba(255,255,255,0.12); }\n  .actionButtons{\n    position:absolute;\n    right:8px;\n    bottom:8px;\n    display:flex;\n    gap:8px;\n  }\n  .actionButtons button{\n    background: rgba(255,255,255,0.06);\n    border: none;\n    color:#fff;\n    padding:10px 12px;\n    border-radius:8px;\n    font-size:14px;\n  }\n  .overlay{\n    position:absolute;\n    left:0; top:0;\n    width:360px;\n    height:640px;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    background: linear-gradient(180deg, rgba(3,6,12,0.35), rgba(3,6,12,0.55));\n    pointer-events:none;\n  }\n  .menu{\n    pointer-events:auto;\n    width:86%;\n    background: rgba(255,255,255,0.03);\n    border-radius:12px;\n    padding:18px;\n    text-align:center;\n    box-shadow: 0 6px 20px rgba(0,0,0,0.6);\n  }\n  .menu h1{ margin:6px 0 12px; font-size:20px; }\n  .menu p{ margin:6px 0 16px; font-size:13px; color:#bfc9d9;}\n  .menu button{\n    background:#00c2a8;\n    color:#042023;\n    border:none;\n    padding:10px 14px;\n    font-size:16px;\n    border-radius:8px;\n  }\n  .small{ font-size:12px; color:#bfc9d9; margin-top:8px; }\n  .footerNote{ font-size:11px; color:#9fb0c8; margin-top:6px; }\n  @media (max-width: 420px){\n    .controls{ transform: scale(0.95); transform-origin: center; }\n  }\n</style>\n</head>\n<body>\n<div class=\"container\" style=\"position:relative;\">\n  <div class=\"hud\">\n    <div class=\"scoreBox\" id=\"scoreBox\">分数: 0</div>\n    <div class=\"scoreBox\" id=\"bestBox\">最高: 0</div>\n    <div style=\"display:flex;gap:6px;\">\n      <button id=\"pauseBtn\" style=\"background:rgba(255,255,255,0.06);border:none;color:#fff;padding:6px 8px;border-radius:6px;\">暂停</button>\n      <button id=\"restartBtn\" style=\"background:rgba(255,255,255,0.06);border:none;color:#fff;padding:6px 8px;border-radius:6px;\">重玩</button>\n    </div>\n  </div>\n\n  <div style=\"position:relative; width:360px; height:640px; margin:0 auto;\">\n    <canvas id=\"game\"></canvas>\n\n    <div id=\"overlay\" class=\"overlay\" style=\"display:flex;\">\n      <div class=\"menu\" id=\"menu\">\n        <h1>贪食蛇</h1>\n        <p>吃食物, 增长身体并提高得分。使用方向键 / WASD 或 屏幕按钮 / 划动 来控制。避免碰撞自己或墙壁。</p>\n        <button id=\"startBtn\">开始游戏</button>\n        <div class=\"small\">吃到金色食物会获得更多得分并短暂加速！</div>\n        <div class=\"footerNote\">适合手机与桌面 - 尺寸 360x640</div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"controls\" aria-hidden=\"false\">\n    <div class=\"dpad\" id=\"dpad\">\n      <div class=\"btn up\" data-dir=\"up\">↑</div>\n      <div class=\"btn down\" data-dir=\"down\">↓</div>\n      <div class=\"btn left\" data-dir=\"left\">←</div>\n      <div class=\"btn right\" data-dir=\"right\">→</div>\n    </div>\n    <div class=\"actionButtons\">\n      <button id=\"btnGrow\">+ 食物</button>\n      <button id=\"btnShrink\">短暂慢速</button>\n    </div>\n  </div>\n</div>\n\n<script>\n(() => {\n  const canvas = document.getElementById('game');\n  const ctx = canvas.getContext('2d');\n\n  // Required dimensions\n  canvas.width = 360;\n  canvas.height = 640;\n\n  // Game grid\n  const CELL = 20; // cell size in pixels (360/20 = 18, 640/20 = 32)\n  const COLS = canvas.width / CELL; // 18\n  const ROWS = canvas.height / CELL; // 32\n\n  // DOM\n  const overlay = document.getElementById('overlay');\n  const startBtn = document.getElementById('startBtn');\n  const scoreBox = document.getElementById('scoreBox');\n  const bestBox = document.getElementById('bestBox');\n  const pauseBtn = document.getElementById('pauseBtn');\n  const restartBtn = document.getElementById('restartBtn');\n  const dpad = document.getElementById('dpad');\n  const btnGrow = document.getElementById('btnGrow');\n  const btnShrink = document.getElementById('btnShrink');\n\n  // Game state\n  let snake, dir, nextDirQueue, food, specialFood, score, bestScore, alive, paused;\n  let speed; // moves per second\n  let moveInterval; // ms per move\n  let lastMoveTime = 0;\n  let specialTimer = 0; // special food lifetime\n  let bonusActive = false;\n  let bonusTimer = 0;\n\n  // Input flags\n  let touchStartX = 0, touchStartY = 0;\n\n  // Initialize best score\n  const STORAGE_KEY = 'snakeHighScore';\n  bestScore = parseInt(localStorage.getItem(STORAGE_KEY) || '0', 10);\n  bestBox.textContent = '最高: ' + bestScore;\n\n  // Utility\n  function randInt(min, max) { return Math.floor(Math.random()*(max-min+1))+min; }\n  function pointEq(a,b){ return a.x===b.x && a.y===b.y; }\n\n  // Start or reset game\n  function initGame(){\n    // Start snake center\n    const startX = Math.floor(COLS/2);\n    const startY = Math.floor(ROWS/2);\n    snake = [\n      {x:startX, y:startY},\n      {x:startX-1, y:startY},\n      {x:startX-2, y:startY}\n    ];\n    dir = {x:1,y:0}; // moving right\n    nextDirQueue = [];\n    score = 0;\n    speed = 6; // moves per second\n    moveInterval = 1000 / speed;\n    lastMoveTime = 0;\n    alive = true;\n    paused = false;\n    specialFood = null;\n    specialTimer = 0;\n    bonusActive = false;\n    bonusTimer = 0;\n    spawnFood();\n    updateHUD();\n  }\n\n  function spawnFood(){\n    let pos;\n    do {\n      pos = {x: randInt(0, COLS-1), y: randInt(0, ROWS-1)};\n    } while (snake.some(s => pointEq(s,pos)));\n    // chance to spawn special gold food (10%)\n    if (Math.random() < 0.10){\n      specialFood = {pos, kind:'gold', ttl: randInt(6,10)}; // seconds\n      food = null;\n      specialTimer = specialFood.ttl * 1000;\n    } else {\n      food = pos;\n      specialFood = null;\n    }\n  }\n\n  function setDirection(newDir){\n    // prevent reversing: can't go opposite to current dir\n    // also queue commands to avoid skipping rapid inputs\n    const lastDir = nextDirQueue.length ? nextDirQueue[nextDirQueue.length-1] : dir;\n    if (newDir.x === -lastDir.x && newDir.y === -lastDir.y) return;\n    nextDirQueue.push(newDir);\n    // limit queue\n    if (nextDirQueue.length > 2) nextDirQueue.shift();\n  }\n\n  // Controls\n  window.addEventListener('keydown', (e) => {\n    if (!alive) return;\n    const k = e.key;\n    if (k === 'ArrowUp' || k === 'w' || k === 'W') setDirection({x:0,y:-1});\n    else if (k === 'ArrowDown' || k === 's' || k === 'S') setDirection({x:0,y:1});\n    else if (k === 'ArrowLeft' || k === 'a' || k === 'A') setDirection({x:-1,y:0});\n    else if (k === 'ArrowRight' || k === 'd' || k === 'D') setDirection({x:1,y:0});\n    else if (k === ' ' || k === 'Escape' || k === 'p' || k === 'P'){ togglePause(); }\n  });\n\n  // DPad buttons\n  dpad.addEventListener('click', (e) => {\n    const btn = e.target.closest('.btn');\n    if(!btn) return;\n    const dirKey = btn.dataset.dir;\n    if (dirKey === 'up') setDirection({x:0,y:-1});\n    if (dirKey === 'down') setDirection({x:0,y:1});\n    if (dirKey === 'left') setDirection({x:-1,y:0});\n    if (dirKey === 'right') setDirection({x:1,y:0});\n  });\n\n  // Touch swipe\n  canvas.addEventListener('touchstart', (e) => {\n    const t = e.touches[0];\n    touchStartX = t.clientX;\n    touchStartY = t.clientY;\n  }, {passive:true});\n  canvas.addEventListener('touchend', (e) => {\n    if (!e.changedTouches || e.changedTouches.length===0) return;\n    const t = e.changedTouches[0];\n    const dx = t.clientX - touchStartX;\n    const dy = t.clientY - touchStartY;\n    if (Math.abs(dx) < 20 && Math.abs(dy) < 20) return;\n    if (Math.abs(dx) > Math.abs(dy)){\n      if (dx>0) setDirection({x:1,y:0}); else setDirection({x:-1,y:0});\n    } else {\n      if (dy>0) setDirection({x:0,y:1}); else setDirection({x:0,y:-1});\n    }\n  }, {passive:true});\n\n  // Pause & restart\n  pauseBtn.addEventListener('click', togglePause);\n  restartBtn.addEventListener('click', () => {\n    initGame();\n    overlay.style.display = 'none';\n  });\n\n  function togglePause(){\n    if (!alive) return;\n    paused = !paused;\n    pauseBtn.textContent = paused ? '继续' : '暂停';\n    if (!paused) {\n      // resume loop by updating lastMoveTime\n      lastMoveTime = performance.now();\n      requestAnimationFrame(loop);\n    }\n  }\n\n  // Start button\n  startBtn.addEventListener('click', () => {\n    initGame();\n    overlay.style.display = 'none';\n    lastMoveTime = performance.now();\n    requestAnimationFrame(loop);\n  });\n\n  // Extra action buttons for fun (cheats for quick testing)\n  btnGrow.addEventListener('click', () => {\n    // spawn a normal food under snake head to instantly grow\n    const head = snake[0];\n    const pos = {x: (head.x+dir.x+COLS)%COLS, y: (head.y+dir.y+ROWS)%ROWS};\n    if (!snake.some(s=>pointEq(s,pos))){\n      food = pos;\n      specialFood = null;\n    }\n  });\n  btnShrink.addEventListener('click', () => {\n    // activate temporary slow mode\n    bonusActive = true;\n    bonusTimer = 3000;\n  });\n\n  // Game update logic\n  function update(dt){\n    if (!alive || paused) return;\n    lastMoveTime += dt;\n    // handle special food timer\n    if (specialFood){\n      specialTimer -= dt;\n      if (specialTimer <= 0){\n        specialFood = null;\n        spawnFood();\n      }\n    }\n\n    if (bonusActive){\n      bonusTimer -= dt;\n      if (bonusTimer <= 0){\n        bonusActive = false;\n        speed = Math.max(4, speed - 0); // revert if we had changed speed on pickup\n        moveInterval = 1000 / speed;\n      }\n    }\n\n    // process movement at defined interval\n    if (lastMoveTime >= moveInterval){\n      lastMoveTime -= moveInterval;\n      // apply queued direction\n      if (nextDirQueue.length) dir = nextDirQueue.shift();\n\n      const newHead = {x: snake[0].x + dir.x, y: snake[0].y + dir.y};\n\n      // collision with walls -> game over\n      if (newHead.x < 0 || newHead.x >= COLS || newHead.y < 0 || newHead.y >= ROWS){\n        alive = false;\n        gameOver();\n        return;\n      }\n\n      // collision with self?\n      if (snake.some(seg => pointEq(seg, newHead))){\n        alive = false;\n        gameOver();\n        return;\n      }\n\n      snake.unshift(newHead);\n\n      // eat food?\n      if (food && pointEq(newHead, food)){\n        // grow, score up\n        score += 10;\n        // small speed bump\n        speed = Math.min(18, speed + 0.25);\n        moveInterval = 1000 / speed;\n        spawnFood();\n      } else if (specialFood && pointEq(newHead, specialFood.pos)){\n        // gold: more points and temporary speed boost\n        score += 30;\n        speed = Math.min(22, speed + 1.2);\n        moveInterval = 1000 / speed;\n        specialFood = null;\n        bonusActive = true;\n        bonusTimer = 1200;\n      } else {\n        // normal move: remove tail\n        snake.pop();\n      }\n\n      updateHUD();\n    }\n  }\n\n  // Rendering\n  function draw(){\n    // background\n    ctx.fillStyle = '#051027';\n    ctx.fillRect(0,0,canvas.width,canvas.height);\n\n    // subtle grid\n    ctx.strokeStyle = 'rgba(255,255,255,0.03)';\n    ctx.lineWidth = 1;\n    for (let x=0;x<=COLS;x++){\n      ctx.beginPath();\n      ctx.moveTo(x*CELL,0);\n      ctx.lineTo(x*CELL,canvas.height);\n      ctx.stroke();\n    }\n    for (let y=0;y<=ROWS;y++){\n      ctx.beginPath();\n      ctx.moveTo(0,y*CELL);\n      ctx.lineTo(canvas.width,y*CELL);\n      ctx.stroke();\n    }\n\n    // draw food\n    if (food){\n      drawCell(food.x, food.y, '#ff6b6b', true);\n      drawFoodSparkle(food.x, food.y, '#ffd6d6');\n    }\n    if (specialFood){\n      drawCell(specialFood.pos.x, specialFood.pos.y, '#ffd166', true);\n      drawStar(specialFood.pos.x, specialFood.pos.y, '#6b3cff');\n    }\n\n    // draw snake\n    for (let i=snake.length-1;i>=0;i--){\n      const seg = snake[i];\n      if (i===0){\n        // head gradient\n        drawHead(seg.x, seg.y);\n      } else {\n        // body color gradient\n        const t = i / snake.length;\n        const r = Math.floor(30 + 180 * (1 - t));\n        const g = Math.floor(220 * t);\n        const b = Math.floor(200 * (1 - t));\n        drawCell(seg.x, seg.y, `rgb(${r},${g},${b})`);\n      }\n    }\n\n    // draw score and status small indicator\n    ctx.fillStyle = 'rgba(255,255,255,0.06)';\n    ctx.fillRect(6,6,140,28);\n    ctx.fillStyle = '#fff';\n    ctx.font = '12px sans-serif';\n    ctx.fillText('分数: ' + score, 12, 24);\n    ctx.fillText('速度: ' + speed.toFixed(1), 90, 24);\n  }\n\n  function drawCell(cx, cy, color, inner=false){\n    const x = cx * CELL, y = cy * CELL;\n    const pad = inner ? 2 : 1;\n    const w = CELL - pad*2, h = CELL - pad*2;\n    const grd = ctx.createLinearGradient(x, y, x+w, y+h);\n    grd.addColorStop(0, color);\n    grd.addColorStop(1, '#000000');\n    ctx.fillStyle = grd;\n    roundRect(ctx, x+pad, y+pad, w, h, 6);\n    ctx.fill();\n  }\n\n  function drawHead(cx, cy){\n    const x = cx * CELL, y = cy * CELL;\n    const grd = ctx.createLinearGradient(x, y, x+CELL, y+CELL);\n    grd.addColorStop(0, '#00e2a8');\n    grd.addColorStop(1, '#00826a');\n    ctx.fillStyle = grd;\n    roundRect(ctx, x+1, y+1, CELL-2, CELL-2, 6);\n    ctx.fill();\n    // eye\n    ctx.fillStyle = '#042023';\n    const ex = x + (dir.x === 1 ? CELL-7 : (dir.x===-1?4: CELL/2 -3));\n    const ey = y + (dir.y === 1 ? CELL-7 : (dir.y===-1?4: CELL/2 -3));\n    ctx.beginPath();\n    ctx.arc(ex, ey, 2.6, 0, Math.PI*2);\n    ctx.fill();\n    // second eye\n    const ex2 = x + (dir.x === 1 ? CELL-7 : (dir.x===-1?4: CELL/2 +3));\n    const ey2 = y + (dir.y === 1 ? CELL-7 : (dir.y===-1?4: CELL/2 +3));\n    ctx.beginPath();\n    ctx.arc(ex2, ey2, 2.6, 0, Math.PI*2);\n    ctx.fill();\n  }\n\n  function drawFoodSparkle(cx, cy, color){\n    const x = cx * CELL + CELL/2;\n    const y = cy * CELL + CELL/2;\n    ctx.fillStyle = color;\n    ctx.beginPath();\n    ctx.ellipse(x, y, 6, 6, Math.PI/4, 0, Math.PI*2);\n    ctx.fill();\n  }\n\n  function drawStar(cx, cy, color){\n    const x = cx * CELL + CELL/2;\n    const y = cy * CELL + CELL/2;\n    ctx.fillStyle = color;\n    ctx.beginPath();\n    for (let i=0;i<5;i++){\n      const a = (i*2)*Math.PI/5 - Math.PI/2;\n      ctx.lineTo(x + Math.cos(a)*6, y + Math.sin(a)*6);\n      const b = (i*2+1)*Math.PI/5 - Math.PI/2;\n      ctx.lineTo(x + Math.cos(b)*3, y + Math.sin(b)*3);\n    }\n    ctx.closePath();\n    ctx.fill();\n  }\n\n  function roundRect(ctx, x, y, w, h, r){\n    const radius = r;\n    ctx.beginPath();\n    ctx.moveTo(x + radius, y);\n    ctx.arcTo(x + w, y,   x + w, y + h, radius);\n    ctx.arcTo(x + w, y + h, x,   y + h, radius);\n    ctx.arcTo(x,   y + h, x,   y,   radius);\n    ctx.arcTo(x,   y,   x + w, y,   radius);\n    ctx.closePath();\n  }\n\n  function updateHUD(){\n    scoreBox.textContent = '分数: ' + score;\n    if (score > bestScore){\n      bestScore = score;\n      localStorage.setItem(STORAGE_KEY, bestScore);\n      bestBox.textContent = '最高: ' + bestScore;\n    }\n  }\n\n  function gameOver(){\n    // show overlay with game over\n    overlay.style.display = 'flex';\n    const menu = document.getElementById('menu');\n    menu.innerHTML = `<h1>游戏结束</h1>\n    <p>你的得分: <strong>${score}</strong></p>\n    <p>最高得分: <strong>${bestScore}</strong></p>\n    <button id=\"restart2\">再玩一次</button>\n    <div class=\"small\">按方向键或划动控制。金色食物给予额外分数！</div>`;\n    document.getElementById('restart2').addEventListener('click', () => {\n      initGame();\n      overlay.style.display = 'none';\n      lastMoveTime = performance.now();\n      requestAnimationFrame(loop);\n    });\n  }\n\n  // Main loop uses requestAnimationFrame but controls update timing by moveInterval\n  let lastFrameTime = performance.now();\n  function loop(now){\n    const dt = now - lastFrameTime;\n    lastFrameTime = now;\n    if (!paused){\n      update(dt);\n      draw();\n    } else {\n      // draw paused overlay\n      draw();\n      ctx.fillStyle = 'rgba(0,0,0,0.25)';\n      ctx.fillRect(0,0,canvas.width,canvas.height);\n      ctx.fillStyle = '#fff';\n      ctx.font = '22px sans-serif';\n      ctx.fillText('已暂停', canvas.width/2 - 34, canvas.height/2);\n    }\n    if (alive && !paused) requestAnimationFrame(loop);\n    else if (alive && paused) {\n      // keep requesting to render paused state\n      requestAnimationFrame(loop);\n    }\n  }\n\n  // initial draw for menu\n  draw();\n\n  // expose for testing (optional)\n  window.__snakeGame = { initGame, spawnFood };\n})();\n</script>\n</body>\n</html>"
        },
        "finish_reason": "stop"
      }
    ],
