      "prompt": "请创建一个完整的 HTML5 游戏。游戏描述：蛇可以穿墙，这边进那边出。\n                    \n重要技术要求：\n1. 单个 HTML 文件\n2. 使用 Canvas API\n3. Canvas 尺寸必须为 360x640 像素（9:16 竖屏比例）\n4. 在 JavaScript 中设置：canvas.width = 360; canvas.height = 640;\n5. 在 CSS 中设置：canvas { max-width: 100%; height: auto; display: block; margin: 0 auto; }\n6. 包含完整游戏循环\n7. 有得分系统\n8. 确保有趣可玩\n\n只返回 HTML 代码，不要其他说明。",
      "code": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>穿墙贪吃蛇</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        body {\n            background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);\n            font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            min-height: 100vh;\n            overflow: hidden;\n        }\n        #gameContainer {\n            position: relative;\n            width: 360px;\n            height: 640px;\n        }\n        #gameCanvas {\n            width: 100%;\n            height: auto;\n            display: block;\n            margin: 0 auto;\n            border-radius: 12px;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);\n            background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);\n        }\n        #uiOverlay {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n        }\n        #scoreDisplay {\n            position: absolute;\n            top: 20px;\n            left: 50%;\n            transform: translateX(-50%);\n            color: white;\n            font-size: 24px;\n            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);\n            z-index: 10;\n        }\n        #scoreDisplay span {\n            color: #4fd1c5;\n            font-weight: bold;\n        }\n        #menuScreen, #gameOverScreen {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            background: rgba(26, 26, 46, 0.9);\n            pointer-events: auto;\n            border-radius: 12px;\n            z-index: 20;\n        }\n        .screenTitle {\n            color: white;\n            font-size: 36px;\n            margin-bottom: 20px;\n            text-shadow: 0 4px 8px rgba(0, 0, 0, 0.5);\n        }\n        .screenText {\n            color: #a0aec0;\n            font-size: 18px;\n            margin-bottom: 30px;\n            text-align: center;\n            padding: 0 20px;\n        }\n        .gameButton {\n            background: linear-gradient(135deg, #4fd1c5, #38b2ac);\n            color: white;\n            border: none;\n            padding: 15px 40px;\n            font-size: 20px;\n            border-radius: 12px;\n            cursor: pointer;\n            margin: 10px;\n            transition: transform 0.2s, box-shadow 0.2s;\n            box-shadow: 0 4px 12px rgba(79, 209, 197, 0.3);\n            font-family: inherit;\n        }\n        .gameButton:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 16px rgba(79, 209, 197, 0.4);\n        }\n        .gameButton:active {\n            transform: translateY(0);\n        }\n        #highScoreDisplay {\n            color: #4fd1c5;\n            font-size: 22px;\n            margin-bottom: 20px;\n        }\n        .hidden {\n            display: none !important;\n        }\n        #pauseIndicator {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            color: white;\n            font-size: 32px;\n            text-shadow: 0 4px 8px rgba(0, 0, 0, 0.5);\n            pointer-events: none;\n            opacity: 0;\n            transition: opacity 0.3s;\n            z-index: 15;\n        }\n        #pauseIndicator.visible {\n            opacity: 1;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"gameContainer\">\n        <canvas id=\"gameCanvas\" width=\"360\" height=\"640\"></canvas>\n        <div id=\"uiOverlay\">\n            <div id=\"scoreDisplay\">得分: <span id=\"scoreValue\">0</span></div>\n            <div id=\"pauseIndicator\">暂停</div>\n            <div id=\"menuScreen\">\n                <div class=\"screenTitle\">穿墙贪吃蛇</div>\n                <div class=\"screenText\">控制蛇移动，吃食物得分。<br>蛇可以穿墙，从另一边出现！<br>避免撞到自己。</div>\n                <div id=\"highScoreDisplay\">最高分: <span id=\"highScoreValue\">0</span></div>\n                <button class=\"gameButton\" id=\"startButton\">开始游戏</button>\n            </div>\n            <div id=\"gameOverScreen\" class=\"hidden\">\n                <div class=\"screenTitle\">游戏结束</div>\n                <div class=\"screenText\">你的得分: <span id=\"finalScore\">0</span></div>\n                <div id=\"newHighScoreText\" class=\"hidden\" style=\"color: #4fd1c5; font-size: 20px; margin-bottom: 20px;\">新纪录！</div>\n                <button class=\"gameButton\" id=\"restartButton\">重新开始</button>\n                <button class=\"gameButton\" id=\"menuButton\">返回菜单</button>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // 游戏常量\n        const GRID_SIZE = 20;\n        const CELL_SIZE = 18;\n        const GAME_WIDTH = 360;\n        const GAME_HEIGHT = 640;\n        const GRID_COLS = Math.floor(GAME_WIDTH / CELL_SIZE);\n        const GRID_ROWS = Math.floor(GAME_HEIGHT / CELL_SIZE);\n        const SNAKE_SPEED = 8; // 每秒移动格数\n\n        // 游戏状态\n        let gameState = 'menu';\n        let score = 0;\n        let highScore = parseInt(localStorage.getItem('snakeHighScore')) || 0;\n\n        // 游戏对象\n        let snake = [];\n        let food = { x: 0, y: 0 };\n        let direction = { x: 1, y: 0 };\n        let nextDirection = { x: 1, y: 0 };\n        let lastUpdateTime = 0;\n        let accumulator = 0;\n        let moveInterval = 1000 / SNAKE_SPEED;\n\n        // Canvas 和上下文\n        const canvas = document.getElementById('gameCanvas');\n        const ctx = canvas.getContext('2d');\n\n        // UI 元素\n        const menuScreen = document.getElementById('menuScreen');\n        const gameOverScreen = document.getElementById('gameOverScreen');\n        const scoreValue = document.getElementById('scoreValue');\n        const highScoreValue = document.getElementById('highScoreValue');\n        const finalScore = document.getElementById('finalScore');\n        const newHighScoreText = document.getElementById('newHighScoreText');\n        const pauseIndicator = document.getElementById('pauseIndicator');\n\n        // 初始化\n        function init() {\n            canvas.width = GAME_WIDTH;\n            canvas.height = GAME_HEIGHT;\n            highScoreValue.textContent = highScore;\n            setupInput();\n            requestAnimationFrame(gameLoop);\n        }\n\n        // 设置输入处理\n        function setupInput() {\n            document.addEventListener('keydown', (e) => {\n                handleInput(e.key, true);\n            });\n            document.addEventListener('keyup', (e) => {\n                handleInput(e.key, false);\n            });\n\n            // 按钮事件\n            document.getElementById('startButton').addEventListener('click', startGame);\n            document.getElementById('restartButton').addEventListener('click', startGame);\n            document.getElementById('menuButton').addEventListener('click', showMenu);\n        }\n\n        // 输入处理\n        function handleInput(key, pressed) {\n            if (!pressed) return;\n\n            switch (gameState) {\n                case 'playing':\n                    switch (key) {\n                        case 'ArrowUp':\n                        case 'w':\n                        case 'W':\n                            if (direction.y !== 1) nextDirection = { x: 0, y: -1 };\n                            break;\n                        case 'ArrowDown':\n                        case 's':\n                        case 'S':\n                            if (direction.y !== -1) nextDirection = { x: 0, y: 1 };\n                            break;\n                        case 'ArrowLeft':\n                        case 'a':\n                        case 'A':\n                            if (direction.x !== 1) nextDirection = { x: -1, y: 0 };\n                            break;\n                        case 'ArrowRight':\n                        case 'd':\n                        case 'D':\n                            if (direction.x !== -1) nextDirection = { x: 1, y: 0 };\n                            break;\n                        case 'p':\n                        case 'P':\n                        case 'Escape':\n                            togglePause();\n                            break;\n                    }\n                    break;\n                case 'paused':\n                    if (key === 'p' || key === 'P' || key === 'Escape') {\n                        togglePause();\n                    }\n                    break;\n                case 'gameover':\n                    if (key === 'Enter' || key === ' ') {\n                        startGame();\n                    }\n                    break;\n                case 'menu':\n                    if (key === 'Enter' || key === ' ') {\n                        startGame();\n                    }\n                    break;\n            }\n        }\n\n        // 游戏循环\n        function gameLoop(timestamp) {\n            const deltaTime = timestamp - lastUpdateTime;\n            lastUpdateTime = timestamp;\n\n            if (gameState === 'playing') {\n                accumulator += deltaTime;\n                while (accumulator >= moveInterval) {\n                    update(moveInterval);\n                    accumulator -= moveInterval;\n                }\n            }\n\n            render();\n            requestAnimationFrame(gameLoop);\n        }\n\n        // 游戏更新\n        function update(deltaTime) {\n            // 更新方向\n            direction = { ...nextDirection };\n\n            // 移动蛇\n            const head = { ...snake[0] };\n            head.x += direction.x;\n            head.y += direction.y;\n\n            // 穿墙逻辑\n            if (head.x < 0) head.x = GRID_COLS - 1;\n            if (head.x >= GRID_COLS) head.x = 0;\n            if (head.y < 0) head.y = GRID_ROWS - 1;\n            if (head.y >= GRID_ROWS) head.y = 0;\n\n            // 检查是否撞到自己\n            for (let i = 0; i < snake.length; i++) {\n                if (head.x === snake[i].x && head.y === snake[i].y) {\n                    gameOver();\n                    return;\n                }\n            }\n\n            // 添加新头部\n            snake.unshift(head);\n\n            // 检查是否吃到食物\n            if (head.x === food.x && head.y === food.y) {\n                score++;\n                scoreValue.textContent = score;\n                spawnFood();\n            } else {\n                // 如果没有吃到食物，移除尾部\n                snake.pop();\n            }\n        }\n\n        // 渲染游戏\n        function render() {\n            // 清除画布\n            ctx.clearRect(0, 0, GAME_WIDTH, GAME_HEIGHT);\n\n            // 绘制背景\n            const gradient = ctx.createLinearGradient(0, 0, 0, GAME_HEIGHT);\n            gradient.addColorStop(0, '#1a1a2e');\n            gradient.addColorStop(1, '#16213e');\n            ctx.fillStyle = gradient;\n            ctx.fillRect(0, 0, GAME_WIDTH, GAME_HEIGHT);\n\n            // 绘制网格线（可选，增加视觉效果）\n            ctx.strokeStyle = 'rgba(255, 255, 255, 0.05)';\n            ctx.lineWidth = 1;\n            for (let x = 0; x <= GAME_WIDTH; x += CELL_SIZE) {\n                ctx.beginPath();\n                ctx.moveTo(x, 0);\n                ctx.lineTo(x, GAME_HEIGHT);\n                ctx.stroke();\n            }\n            for (let y = 0; y <= GAME_HEIGHT; y += CELL_SIZE) {\n                ctx.beginPath();\n                ctx.moveTo(0, y);\n                ctx.lineTo(GAME_WIDTH, y);\n                ctx.stroke();\n            }\n\n            // 绘制食物\n            if (gameState === 'playing' || gameState === 'paused') {\n                ctx.fillStyle = '#ff6b6b';\n                ctx.shadowColor = '#ff6b6b';\n                ctx.shadowBlur = 10;\n                ctx.beginPath();\n                ctx.arc(\n                    food.x * CELL_SIZE + CELL_SIZE / 2,\n                    food.y * CELL_SIZE + CELL_SIZE / 2,\n                    CELL_SIZE / 2 - 2,\n                    0,\n                    Math.PI * 2\n                );\n                ctx.fill();\n                ctx.shadowBlur = 0;\n            }\n\n            // 绘制蛇\n            if (gameState === 'playing' || gameState === 'paused') {\n                snake.forEach((segment, index) => {\n                    const x = segment.x * CELL_SIZE;\n                    const y = segment.y * CELL_SIZE;\n\n                    // 蛇身渐变\n                    const hue = (index * 5) % 360;\n                    ctx.fillStyle = index === 0 ? '#4fd1c5' : `hsl(${hue}, 70%, 60%)`;\n                    ctx.shadowColor = index === 0 ? '#4fd1c5' : `hsl(${hue}, 70%, 60%)`;\n                    ctx.shadowBlur = index === 0 ? 8 : 4;\n\n                    // 绘制圆角矩形\n                    const radius = 4;\n                    ctx.beginPath();\n                    ctx.roundRect(x + 1, y + 1, CELL_SIZE - 2, CELL_SIZE - 2, radius);\n                    ctx.fill();\n                    ctx.shadowBlur = 0;\n\n                    // 蛇头眼睛\n                    if (index === 0) {\n                        ctx.fillStyle = 'white';\n                        const eyeSize = 3;\n                        const eyeOffset = 5;\n                        if (direction.x === 1) {\n                            ctx.beginPath();\n                            ctx.arc(x + CELL_SIZE - eyeOffset, y + eyeOffset, eyeSize, 0, Math.PI * 2);\n                            ctx.arc(x + CELL_SIZE - eyeOffset, y + CELL_SIZE - eyeOffset, eyeSize, 0, Math.PI * 2);\n                            ctx.fill();\n                        } else if (direction.x === -1) {\n                            ctx.beginPath();\n                            ctx.arc(x + eyeOffset, y + eyeOffset, eyeSize, 0, Math.PI * 2);\n                            ctx.arc(x + eyeOffset, y + CELL_SIZE - eyeOffset, eyeSize, 0, Math.PI * 2);\n                            ctx.fill();\n                        } else if (direction.y === -1) {\n                            ctx.beginPath();\n                            ctx.arc(x + eyeOffset, y + eyeOffset, eyeSize, 0, Math.PI * 2);\n                            ctx.arc(x + CELL_SIZE - eyeOffset, y + eyeOffset, eyeSize, 0, Math.PI * 2);\n                            ctx.fill();\n                        } else if (direction.y === 1) {\n                            ctx.beginPath();\n                            ctx.arc(x + eyeOffset, y + CELL_SIZE - eyeOffset, eyeSize, 0, Math.PI * 2);\n                            ctx.arc(x + CELL_SIZE - eyeOffset, y + CELL_SIZE - eyeOffset, eyeSize, 0, Math.PI * 2);\n                            ctx.fill();\n                        }\n                    }\n                });\n            }\n        }\n\n        // 开始游戏\n        function startGame() {\n            // 重置游戏状态\n            snake = [\n                { x: Math.floor(GRID_COLS / 2), y: Math.floor(GRID_ROWS / 2) }\n            ];\n            direction = { x: 1, y: 0 };\n            nextDirection = { x: 1, y: 0 };\n            score = 0;\n            scoreValue.textContent = score;\n            accumulator = 0;\n\n            // 生成食物\n            spawnFood();\n\n            // 更新 UI\n            menuScreen.classList.add('hidden');\n            gameOverScreen.classList.add('hidden');\n            pauseIndicator.classList.remove('visible');\n\n            gameState = 'playing';\n        }\n\n        // 生成食物\n        function spawnFood() {\n            let newFood;\n            do {\n                newFood = {\n                    x: Math.floor(Math.random() * GRID_COLS),\n                    y: Math.floor(Math.random() * GRID_ROWS)\n                };\n            } while (snake.some(segment => segment.x === newFood.x && segment.y === newFood.y));\n            food = newFood;\n        }\n\n        // 游戏结束\n        function gameOver() {\n            gameState = 'gameover';\n\n            // 更新最高分\n            if (score > highScore) {\n                highScore = score;\n                localStorage.setItem('snakeHighScore', highScore);\n                highScoreValue.textContent = highScore;\n                newHighScoreText.classList.remove('hidden');\n            } else {\n                newHighScoreText.classList.add('hidden');\n            }\n\n            finalScore.textContent = score;\n            gameOverScreen.classList.remove('hidden');\n        }\n\n        // 切换暂停\n        function togglePause() {\n            if (gameState === 'playing') {\n                gameState = 'paused';\n                pauseIndicator.classList.add('visible');\n            } else if (gameState === 'paused') {\n                gameState = 'playing';\n                pauseIndicator.classList.remove('visible');\n                lastUpdateTime = performance.now();\n            }\n        }\n\n        // 显示菜单\n        function showMenu() {\n            gameState = 'menu';\n            menuScreen.classList.remove('hidden');\n            gameOverScreen.classList.add('hidden');\n            pauseIndicator.classList.remove('visible');\n        }\n\n        // 初始化游戏\n        init();\n    </script>\n</body>\n</html>",
