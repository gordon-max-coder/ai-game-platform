      "prompt": "请创建一个完整的 HTML5 游戏。游戏描述：创建一个贪食蛇游戏。\n                    \n重要技术要求：\n1. 单个 HTML 文件\n2. 使用 Canvas API\n3. Canvas 尺寸必须为 360x640 像素（9:16 竖屏比例）\n4. 在 JavaScript 中设置：canvas.width = 360; canvas.height = 640;\n5. 在 CSS 中设置：canvas { max-width: 100%; height: auto; display: block; margin: 0 auto; }\n6. 包含完整游戏循环\n7. 有得分系统\n8. 确保有趣可玩\n\n只返回 HTML 代码，不要其他说明。",
      "code": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>贪食蛇游戏</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            min-height: 100vh;\n            background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);\n            font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;\n            overflow: hidden;\n        }\n        \n        #gameContainer {\n            position: relative;\n            width: 360px;\n            height: 640px;\n            border-radius: 12px;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);\n            overflow: hidden;\n        }\n        \n        canvas {\n            max-width: 100%;\n            height: auto;\n            display: block;\n            margin: 0 auto;\n            border-radius: 12px;\n        }\n        \n        #scoreDisplay {\n            position: absolute;\n            top: 20px;\n            left: 50%;\n            transform: translateX(-50%);\n            color: white;\n            font-size: 24px;\n            font-weight: bold;\n            text-align: center;\n            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);\n            z-index: 10;\n        }\n        \n        #scoreDisplay span {\n            color: #4fd1c5;\n        }\n        \n        #highScoreDisplay {\n            position: absolute;\n            top: 50px;\n            left: 50%;\n            transform: translateX(-50%);\n            color: #aaa;\n            font-size: 14px;\n            text-align: center;\n            z-index: 10;\n        }\n        \n        #instructions {\n            position: absolute;\n            bottom: 20px;\n            left: 50%;\n            transform: translateX(-50%);\n            color: #888;\n            font-size: 12px;\n            text-align: center;\n            z-index: 10;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"gameContainer\">\n        <div id=\"scoreDisplay\">得分: <span id=\"score\">0</span></div>\n        <div id=\"highScoreDisplay\">最高分: <span id=\"highScore\">0</span></div>\n        <div id=\"instructions\">方向键或WASD控制 | 空格暂停</div>\n        <canvas id=\"gameCanvas\"></canvas>\n    </div>\n\n    <script>\n        // 固定UI规范设置\n        const canvas = document.getElementById('gameCanvas');\n        const ctx = canvas.getContext('2d');\n        canvas.width = 360;\n        canvas.height = 640;\n        \n        // 游戏状态\n        const GAME_STATE = {\n            MENU: 'menu',\n            PLAYING: 'playing',\n            PAUSED: 'paused',\n            GAMEOVER: 'gameover'\n        };\n        \n        // 游戏变量\n        let gameState = GAME_STATE.MENU;\n        let score = 0;\n        let highScore = 0;\n        let lastTime = 0;\n        let deltaTime = 0;\n        let snake = [];\n        let food = {};\n        let direction = 'right';\n        let nextDirection = 'right';\n        let moveTimer = 0;\n        let moveInterval = 150; // 蛇移动间隔(毫秒)\n        \n        // 游戏区域设置\n        const GRID_SIZE = 20;\n        const GRID_COUNT = 18;\n        const GAME_OFFSET_X = (canvas.width - GRID_SIZE * GRID_COUNT) / 2;\n        const GAME_OFFSET_Y = 100;\n        \n        // 初始化游戏\n        function initGame() {\n            // 从localStorage加载最高分\n            const savedHighScore = localStorage.getItem('snakeHighScore');\n            if (savedHighScore) {\n                highScore = parseInt(savedHighScore);\n                document.getElementById('highScore').textContent = highScore;\n            }\n            \n            // 初始化蛇\n            resetGame();\n            \n            // 开始游戏循环\n            requestAnimationFrame(gameLoop);\n        }\n        \n        // 重置游戏\n        function resetGame() {\n            score = 0;\n            document.getElementById('score').textContent = score;\n            \n            // 初始化蛇身(3节)\n            snake = [\n                {x: 5, y: 9},\n                {x: 4, y: 9},\n                {x: 3, y: 9}\n            ];\n            \n            direction = 'right';\n            nextDirection = 'right';\n            \n            // 生成食物\n            spawnFood();\n            \n            moveTimer = 0;\n        }\n        \n        // 生成食物\n        function spawnFood() {\n            let validPosition = false;\n            while (!validPosition) {\n                food = {\n                    x: Math.floor(Math.random() * GRID_COUNT),\n                    y: Math.floor(Math.random() * GRID_COUNT)\n                };\n                \n                // 确保食物不会出现在蛇身上\n                validPosition = true;\n                for (let segment of snake) {\n                    if (segment.x === food.x && segment.y === food.y) {\n                        validPosition = false;\n                        break;\n                    }\n                }\n            }\n        }\n        \n        // 游戏主循环\n        function gameLoop(currentTime) {\n            deltaTime = currentTime - lastTime;\n            lastTime = currentTime;\n            \n            update(deltaTime);\n            render();\n            \n            requestAnimationFrame(gameLoop);\n        }\n        \n        // 更新游戏逻辑\n        function update(deltaTime) {\n            if (gameState !== GAME_STATE.PLAYING) return;\n            \n            moveTimer += deltaTime;\n            if (moveTimer >= moveInterval) {\n                moveTimer = 0;\n                moveSnake();\n            }\n        }\n        \n        // 移动蛇\n        function moveSnake() {\n            direction = nextDirection;\n            \n            // 计算新的头部位置\n            const head = {...snake[0]};\n            switch (direction) {\n                case 'up': head.y--; break;\n                case 'down': head.y++; break;\n                case 'left': head.x--; break;\n                case 'right': head.x++; break;\n            }\n            \n            // 检查游戏结束条件\n            if (checkCollision(head)) {\n                gameOver();\n                return;\n            }\n            \n            // 添加新头部\n            snake.unshift(head);\n            \n            // 检查是否吃到食物\n            if (head.x === food.x && head.y === food.y) {\n                // 吃到食物，增加分数\n                score += 10;\n                document.getElementById('score').textContent = score;\n                \n                // 更新最高分\n                if (score > highScore) {\n                    highScore = score;\n                    document.getElementById('highScore').textContent = highScore;\n                    localStorage.setItem('snakeHighScore', highScore);\n                }\n                \n                // 生成新食物\n                spawnFood();\n                \n                // 加速游戏\n                moveInterval = Math.max(50, moveInterval - 2);\n            } else {\n                // 没吃到食物，移除尾部\n                snake.pop();\n            }\n        }\n        \n        // 检查碰撞\n        function checkCollision(head) {\n            // 检查墙壁碰撞\n            if (head.x < 0 || head.x >= GRID_COUNT || head.y < 0 || head.y >= GRID_COUNT) {\n                return true;\n            }\n            \n            // 检查自身碰撞\n            for (let i = 1; i < snake.length; i++) {\n                if (head.x === snake[i].x && head.y === snake[i].y) {\n                    return true;\n                }\n            }\n            \n            return false;\n        }\n        \n        // 游戏结束\n        function gameOver() {\n            gameState = GAME_STATE.GAMEOVER;\n            \n            // 绘制游戏结束画面\n            render();\n            \n            // 显示游戏结束信息\n            ctx.fillStyle = 'rgba(0, 0, 0, 0.7)';\n            ctx.fillRect(0, 0, canvas.width, canvas.height);\n            \n            ctx.fillStyle = '#fff';\n            ctx.font = 'bold 36px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n            ctx.textAlign = 'center';\n            ctx.fillText('游戏结束', canvas.width / 2, canvas.height / 2 - 50);\n            \n            ctx.font = '24px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n            ctx.fillText(`最终得分: ${score}`, canvas.width / 2, canvas.height / 2);\n            \n            ctx.font = '18px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n            ctx.fillStyle = '#4fd1c5';\n            ctx.fillText('按空格键重新开始', canvas.width / 2, canvas.height / 2 + 50);\n        }\n        \n        // 渲染游戏\n        function render() {\n            // 清除画布\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            \n            // 绘制背景\n            ctx.fillStyle = '#16213e';\n            ctx.fillRect(0, 0, canvas.width, canvas.height);\n            \n            // 绘制游戏区域背景\n            ctx.fillStyle = '#1a1a2e';\n            ctx.fillRect(GAME_OFFSET_X, GAME_OFFSET_Y, GRID_SIZE * GRID_COUNT, GRID_SIZE * GRID_COUNT);\n            \n            // 绘制网格线\n            ctx.strokeStyle = '#2a2a4e';\n            ctx.lineWidth = 1;\n            for (let i = 0; i <= GRID_COUNT; i++) {\n                // 垂直线\n                ctx.beginPath();\n                ctx.moveTo(GAME_OFFSET_X + i * GRID_SIZE, GAME_OFFSET_Y);\n                ctx.lineTo(GAME_OFFSET_X + i * GRID_SIZE, GAME_OFFSET_Y + GRID_SIZE * GRID_COUNT);\n                ctx.stroke();\n                \n                // 水平线\n                ctx.beginPath();\n                ctx.moveTo(GAME_OFFSET_X, GAME_OFFSET_Y + i * GRID_SIZE);\n                ctx.lineTo(GAME_OFFSET_X + GRID_SIZE * GRID_COUNT, GAME_OFFSET_Y + i * GRID_SIZE);\n                ctx.stroke();\n            }\n            \n            // 绘制食物\n            ctx.fillStyle = '#ff6b6b';\n            ctx.beginPath();\n            ctx.arc(\n                GAME_OFFSET_X + food.x * GRID_SIZE + GRID_SIZE / 2,\n                GAME_OFFSET_Y + food.y * GRID_SIZE + GRID_SIZE / 2,\n                GRID_SIZE / 2 - 2,\n                0,\n                Math.PI * 2\n            );\n            ctx.fill();\n            \n            // 绘制蛇\n            snake.forEach((segment, index) => {\n                // 蛇头\n                if (index === 0) {\n                    ctx.fillStyle = '#4fd1c5';\n                } else {\n                    // 蛇身渐变\n                    const green = Math.floor(180 - (index * 3));\n                    ctx.fillStyle = `rgb(79, ${green}, 197)`;\n                }\n                \n                ctx.beginPath();\n                ctx.roundRect(\n                    GAME_OFFSET_X + segment.x * GRID_SIZE + 1,\n                    GAME_OFFSET_Y + segment.y * GRID_SIZE + 1,\n                    GRID_SIZE - 2,\n                    GRID_SIZE - 2,\n                    4\n                );\n                ctx.fill();\n            });\n            \n            // 绘制菜单或暂停界面\n            if (gameState === GAME_STATE.MENU) {\n                ctx.fillStyle = 'rgba(0, 0, 0, 0.7)';\n                ctx.fillRect(0, 0, canvas.width, canvas.height);\n                \n                ctx.fillStyle = '#fff';\n                ctx.font = 'bold 36px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n                ctx.textAlign = 'center';\n                ctx.fillText('贪食蛇', canvas.width / 2, canvas.height / 2 - 80);\n                \n                ctx.font = '18px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n                ctx.fillText('经典贪食蛇游戏', canvas.width / 2, canvas.height / 2 - 30);\n                \n                ctx.fillStyle = '#4fd1c5';\n                ctx.fillText('按空格键开始游戏', canvas.width / 2, canvas.height / 2 + 30);\n                \n                ctx.fillStyle = '#aaa';\n                ctx.font = '14px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n                ctx.fillText('使用方向键或WASD控制蛇的移动', canvas.width / 2, canvas.height / 2 + 80);\n                ctx.fillText('吃到红色食物可以得分并变长', canvas.width / 2, canvas.height / 2 + 110);\n            } else if (gameState === GAME_STATE.PAUSED) {\n                ctx.fillStyle = 'rgba(0, 0, 0, 0.5)';\n                ctx.fillRect(0, 0, canvas.width, canvas.height);\n                \n                ctx.fillStyle = '#fff';\n                ctx.font = 'bold 36px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n                ctx.textAlign = 'center';\n                ctx.fillText('游戏暂停', canvas.width / 2, canvas.height / 2);\n                \n                ctx.font = '18px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n                ctx.fillText('按空格键继续', canvas.width / 2, canvas.height / 2 + 40);\n            }\n        }\n        \n        // 处理输入\n        function handleInput(key, pressed) {\n            if (!pressed) return;\n            \n            switch (gameState) {\n                case GAME_STATE.MENU:\n                    if (key === ' ') {\n                        gameState = GAME_STATE.PLAYING;\n                    }\n                    break;\n                    \n                case GAME_STATE.PLAYING:\n                    switch (key) {\n                        case 'ArrowUp':\n                        case 'w':\n                        case 'W':\n                            if (direction !== 'down') nextDirection = 'up';\n                            break;\n                        case 'ArrowDown':\n                        case 's':\n                        case 'S':\n                            if (direction !== 'up') nextDirection = 'down';\n                            break;\n                        case 'ArrowLeft':\n                        case 'a':\n                        case 'A':\n                            if (direction !== 'right') nextDirection = 'left';\n                            break;\n                        case 'ArrowRight':\n                        case 'd':\n                        case 'D':\n                            if (direction !== 'left') nextDirection = 'right';\n                            break;\n                        case ' ':\n                            gameState = GAME_STATE.PAUSED;\n                            break;\n                    }\n                    break;\n                    \n                case GAME_STATE.PAUSED:\n                    if (key === ' ') {\n                        gameState = GAME_STATE.PLAYING;\n                    }\n                    break;\n                    \n                case GAME_STATE.GAMEOVER:\n                    if (key === ' ') {\n                        resetGame();\n                        gameState = GAME_STATE.PLAYING;\n                    }\n                    break;\n            }\n        }\n        \n        // 键盘事件监听\n        document.addEventListener('keydown', (e) => {\n            handleInput(e.key, true);\n            // 阻止方向键滚动页面\n            if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight', ' '].includes(e.key)) {\n                e.preventDefault();\n            }\n        });\n        \n        // 添加触摸控制（适用于移动设备）\n        let touchStartX = 0;\n        let touchStartY = 0;\n        \n        document.addEventListener('touchstart', (e) => {\n            touchStartX = e.touches[0].clientX;\n            touchStartY = e.touches[0].clientY;\n        });\n        \n        document.addEventListener('touchend', (e) => {\n            const touchEndX = e.changedTouches[0].clientX;\n            const touchEndY = e.changedTouches[0].clientY;\n            \n            const dx = touchEndX - touchStartX;\n            const dy = touchEndY - touchStartY;\n            \n            // 判断滑动方向\n            if (Math.abs(dx) > Math.abs(dy)) {\n                // 水平滑动\n                if (dx > 30) {\n                    handleInput('ArrowRight', true);\n                } else if (dx < -30) {\n                    handleInput('ArrowLeft', true);\n                }\n            } else {\n                // 垂直滑动\n                if (dy > 30) {\n                    handleInput('ArrowDown', true);\n                } else if (dy < -30) {\n                    handleInput('ArrowUp', true);\n                }\n            }\n        });\n        \n        // 初始化游戏\n        initGame();\n    </script>\n</body>\n</html>",
