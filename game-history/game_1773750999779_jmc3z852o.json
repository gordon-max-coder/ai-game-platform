      "prompt": "请创建一个完整的 HTML5 游戏。游戏描述：蛇初始长度3。\n                    \n重要技术要求：\n1. 单个 HTML 文件\n2. 使用 Canvas API\n3. Canvas 尺寸必须为 360x640 像素（9:16 竖屏比例）\n4. 在 JavaScript 中设置：canvas.width = 360; canvas.height = 640;\n5. 在 CSS 中设置：canvas { max-width: 100%; height: auto; display: block; margin: 0 auto; }\n6. 包含完整游戏循环\n7. 有得分系统\n8. 确保有趣可玩\n\n只返回 HTML 代码，不要其他说明。",
      "code": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>贪吃蛇游戏</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            min-height: 100vh;\n            background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);\n            font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;\n            overflow: hidden;\n        }\n        \n        #gameContainer {\n            position: relative;\n            border-radius: 12px;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);\n            overflow: hidden;\n        }\n        \n        #gameCanvas {\n            display: block;\n            max-width: 100%;\n            height: auto;\n            margin: 0 auto;\n            border-radius: 12px;\n        }\n        \n        #scoreDisplay {\n            position: absolute;\n            top: 20px;\n            left: 50%;\n            transform: translateX(-50%);\n            font-size: 24px;\n            font-weight: bold;\n            color: white;\n            z-index: 10;\n            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);\n        }\n        \n        #scoreDisplay span {\n            color: #4fd1c5;\n        }\n        \n        #highScoreDisplay {\n            position: absolute;\n            top: 50px;\n            left: 50%;\n            transform: translateX(-50%);\n            font-size: 14px;\n            color: rgba(255, 255, 255, 0.7);\n            z-index: 10;\n        }\n        \n        #instructions {\n            position: absolute;\n            bottom: 20px;\n            left: 50%;\n            transform: translateX(-50%);\n            font-size: 12px;\n            color: rgba(255, 255, 255, 0.5);\n            z-index: 10;\n            text-align: center;\n            width: 90%;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"gameContainer\">\n        <div id=\"scoreDisplay\">得分: <span id=\"currentScore\">0</span></div>\n        <div id=\"highScoreDisplay\">最高分: <span id=\"highScore\">0</span></div>\n        <canvas id=\"gameCanvas\" width=\"360\" height=\"640\"></canvas>\n        <div id=\"instructions\">方向键或WASD控制移动 | 空格键暂停</div>\n    </div>\n\n    <script>\n        const canvas = document.getElementById('gameCanvas');\n        const ctx = canvas.getContext('2d');\n        const currentScoreElement = document.getElementById('currentScore');\n        const highScoreElement = document.getElementById('highScore');\n        \n        // 游戏配置\n        const config = {\n            gridSize: 20,\n            initialSnakeLength: 3,\n            gameSpeed: 150, // 毫秒\n            colors: {\n                background: '#1a1a2e',\n                snakeHead: '#4fd1c5',\n                snakeBody: '#38b2ac',\n                snakeBorder: '#2c7a7b',\n                food: '#f56565',\n                foodBorder: '#c53030',\n                text: 'white',\n                menuBackground: 'rgba(22, 33, 62, 0.95)'\n            }\n        };\n        \n        // 游戏状态\n        let gameState = {\n            current: 'menu', // menu, playing, paused, gameover\n            score: 0,\n            highScore: parseInt(localStorage.getItem('snakeHighScore')) || 0,\n            lastUpdateTime: 0,\n            gameLoopId: null\n        };\n        \n        // 蛇对象\n        let snake = {\n            body: [],\n            direction: 'right',\n            nextDirection: 'right',\n            speed: config.gameSpeed\n        };\n        \n        // 食物对象\n        let food = {\n            position: { x: 0, y: 0 }\n        };\n        \n        // 初始化游戏\n        function initGame() {\n            // 初始化蛇\n            const startX = Math.floor(canvas.width / config.gridSize / 2);\n            const startY = Math.floor(canvas.height / config.gridSize / 2);\n            \n            snake.body = [];\n            for (let i = 0; i < config.initialSnakeLength; i++) {\n                snake.body.push({ x: startX - i, y: startY });\n            }\n            \n            snake.direction = 'right';\n            snake.nextDirection = 'right';\n            \n            // 生成食物\n            generateFood();\n            \n            // 重置分数\n            gameState.score = 0;\n            updateScoreDisplay();\n            \n            // 开始游戏\n            gameState.current = 'playing';\n            gameState.lastUpdateTime = performance.now();\n            \n            if (gameState.gameLoopId) {\n                cancelAnimationFrame(gameState.gameLoopId);\n            }\n            \n            gameLoop(performance.now());\n        }\n        \n        // 生成食物\n        function generateFood() {\n            const maxX = Math.floor(canvas.width / config.gridSize);\n            const maxY = Math.floor(canvas.height / config.gridSize);\n            \n            let newFoodPosition;\n            let isOnSnake;\n            \n            do {\n                newFoodPosition = {\n                    x: Math.floor(Math.random() * maxX),\n                    y: Math.floor(Math.random() * maxY)\n                };\n                \n                // 检查食物是否生成在蛇身上\n                isOnSnake = snake.body.some(segment => \n                    segment.x === newFoodPosition.x && segment.y === newFoodPosition.y\n                );\n            } while (isOnSnake);\n            \n            food.position = newFoodPosition;\n        }\n        \n        // 更新游戏逻辑\n        function update(deltaTime) {\n            if (gameState.current !== 'playing') return;\n            \n            // 更新蛇的方向\n            snake.direction = snake.nextDirection;\n            \n            // 计算蛇头新位置\n            const head = { ...snake.body[0] };\n            \n            switch (snake.direction) {\n                case 'up':\n                    head.y -= 1;\n                    break;\n                case 'down':\n                    head.y += 1;\n                    break;\n                case 'left':\n                    head.x -= 1;\n                    break;\n                case 'right':\n                    head.x += 1;\n                    break;\n            }\n            \n            // 检查边界碰撞\n            const maxX = Math.floor(canvas.width / config.gridSize);\n            const maxY = Math.floor(canvas.height / config.gridSize);\n            \n            if (head.x < 0 || head.x >= maxX || head.y < 0 || head.y >= maxY) {\n                gameOver();\n                return;\n            }\n            \n            // 检查自身碰撞\n            if (snake.body.some(segment => segment.x === head.x && segment.y === head.y)) {\n                gameOver();\n                return;\n            }\n            \n            // 移动蛇\n            snake.body.unshift(head);\n            \n            // 检查是否吃到食物\n            if (head.x === food.position.x && head.y === food.position.y) {\n                // 增加分数\n                gameState.score += 10;\n                updateScoreDisplay();\n                \n                // 生成新食物\n                generateFood();\n            } else {\n                // 如果没有吃到食物，移除尾部\n                snake.body.pop();\n            }\n        }\n        \n        // 渲染游戏\n        function render() {\n            // 清除画布\n            ctx.fillStyle = config.colors.background;\n            ctx.fillRect(0, 0, canvas.width, canvas.height);\n            \n            // 绘制网格（可选，增加视觉效果）\n            ctx.strokeStyle = 'rgba(255, 255, 255, 0.05)';\n            ctx.lineWidth = 1;\n            \n            for (let x = 0; x < canvas.width; x += config.gridSize) {\n                ctx.beginPath();\n                ctx.moveTo(x, 0);\n                ctx.lineTo(x, canvas.height);\n                ctx.stroke();\n            }\n            \n            for (let y = 0; y < canvas.height; y += config.gridSize) {\n                ctx.beginPath();\n                ctx.moveTo(0, y);\n                ctx.lineTo(canvas.width, y);\n                ctx.stroke();\n            }\n            \n            if (gameState.current === 'playing' || gameState.current === 'paused') {\n                // 绘制蛇\n                snake.body.forEach((segment, index) => {\n                    const x = segment.x * config.gridSize;\n                    const y = segment.y * config.gridSize;\n                    \n                    // 蛇头和蛇身颜色不同\n                    if (index === 0) {\n                        ctx.fillStyle = config.colors.snakeHead;\n                    } else {\n                        ctx.fillStyle = config.colors.snakeBody;\n                    }\n                    \n                    ctx.fillRect(x, y, config.gridSize, config.gridSize);\n                    \n                    // 绘制边框\n                    ctx.strokeStyle = config.colors.snakeBorder;\n                    ctx.lineWidth = 2;\n                    ctx.strokeRect(x, y, config.gridSize, config.gridSize);\n                    \n                    // 为蛇头添加眼睛\n                    if (index === 0) {\n                        ctx.fillStyle = 'white';\n                        const eyeSize = config.gridSize / 5;\n                        const eyeOffset = config.gridSize / 3;\n                        \n                        // 根据方向调整眼睛位置\n                        let leftEyeX, leftEyeY, rightEyeX, rightEyeY;\n                        \n                        switch (snake.direction) {\n                            case 'up':\n                                leftEyeX = x + eyeOffset;\n                                leftEyeY = y + eyeOffset;\n                                rightEyeX = x + config.gridSize - eyeOffset - eyeSize;\n                                rightEyeY = y + eyeOffset;\n                                break;\n                            case 'down':\n                                leftEyeX = x + eyeOffset;\n                                leftEyeY = y + config.gridSize - eyeOffset - eyeSize;\n                                rightEyeX = x + config.gridSize - eyeOffset - eyeSize;\n                                rightEyeY = y + config.gridSize - eyeOffset - eyeSize;\n                                break;\n                            case 'left':\n                                leftEyeX = x + eyeOffset;\n                                leftEyeY = y + eyeOffset;\n                                rightEyeX = x + eyeOffset;\n                                rightEyeY = y + config.gridSize - eyeOffset - eyeSize;\n                                break;\n                            case 'right':\n                                leftEyeX = x + config.gridSize - eyeOffset - eyeSize;\n                                leftEyeY = y + eyeOffset;\n                                rightEyeX = x + config.gridSize - eyeOffset - eyeSize;\n                                rightEyeY = y + config.gridSize - eyeOffset - eyeSize;\n                                break;\n                        }\n                        \n                        ctx.fillRect(leftEyeX, leftEyeY, eyeSize, eyeSize);\n                        ctx.fillRect(rightEyeX, rightEyeY, eyeSize, eyeSize);\n                    }\n                });\n                \n                // 绘制食物\n                const foodX = food.position.x * config.gridSize;\n                const foodY = food.position.y * config.gridSize;\n                \n                ctx.fillStyle = config.colors.food;\n                ctx.beginPath();\n                ctx.arc(\n                    foodX + config.gridSize / 2,\n                    foodY + config.gridSize / 2,\n                    config.gridSize / 2 - 2,\n                    0,\n                    Math.PI * 2\n                );\n                ctx.fill();\n                \n                ctx.strokeStyle = config.colors.foodBorder;\n                ctx.lineWidth = 2;\n                ctx.stroke();\n                \n                // 绘制暂停界面\n                if (gameState.current === 'paused') {\n                    drawOverlay('游戏暂停', '按空格键继续');\n                }\n            } else if (gameState.current === 'menu') {\n                drawMenu();\n            } else if (gameState.current === 'gameover') {\n                drawGameOver();\n            }\n        }\n        \n        // 绘制菜单界面\n        function drawMenu() {\n            // 半透明遮罩\n            ctx.fillStyle = config.colors.menuBackground;\n            ctx.fillRect(0, 0, canvas.width, canvas.height);\n            \n            // 标题\n            ctx.fillStyle = config.colors.text;\n            ctx.font = 'bold 36px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n            ctx.textAlign = 'center';\n            ctx.fillText('贪吃蛇游戏', canvas.width / 2, canvas.height / 2 - 60);\n            \n            // 说明\n            ctx.font = '18px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n            ctx.fillText('按空格键开始游戏', canvas.width / 2, canvas.height / 2);\n            \n            // 操作说明\n            ctx.font = '14px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n            ctx.fillStyle = 'rgba(255, 255, 255, 0.7)';\n            ctx.fillText('方向键或WASD控制移动', canvas.width / 2, canvas.height / 2 + 40);\n            ctx.fillText('空格键暂停游戏', canvas.width / 2, canvas.height / 2 + 65);\n            \n            // 显示最高分\n            ctx.fillStyle = config.colors.snakeHead;\n            ctx.font = 'bold 20px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n            ctx.fillText(`最高分: ${gameState.highScore}`, canvas.width / 2, canvas.height / 2 + 110);\n        }\n        \n        // 绘制游戏结束界面\n        function drawGameOver() {\n            // 半透明遮罩\n            ctx.fillStyle = 'rgba(22, 33, 62, 0.9)';\n            ctx.fillRect(0, 0, canvas.width, canvas.height);\n            \n            // 游戏结束标题\n            ctx.fillStyle = config.colors.food;\n            ctx.font = 'bold 36px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n            ctx.textAlign = 'center';\n            ctx.fillText('游戏结束', canvas.width / 2, canvas.height / 2 - 60);\n            \n            // 显示分数\n            ctx.fillStyle = config.colors.text;\n            ctx.font = '24px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n            ctx.fillText(`得分: ${gameState.score}`, canvas.width / 2, canvas.height / 2);\n            \n            // 显示最高分\n            ctx.fillStyle = config.colors.snakeHead;\n            ctx.font = '20px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n            ctx.fillText(`最高分: ${gameState.highScore}`, canvas.width / 2, canvas.height / 2 + 40);\n            \n            // 重新开始提示\n            ctx.fillStyle = config.colors.text;\n            ctx.font = '18px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n            ctx.fillText('按空格键重新开始', canvas.width / 2, canvas.height / 2 + 100);\n        }\n        \n        // 绘制覆盖层（用于暂停等）\n        function drawOverlay(title, subtitle) {\n            ctx.fillStyle = 'rgba(22, 33, 62, 0.7)';\n            ctx.fillRect(0, 0, canvas.width, canvas.height);\n            \n            ctx.fillStyle = config.colors.text;\n            ctx.font = 'bold 32px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n            ctx.textAlign = 'center';\n            ctx.fillText(title, canvas.width / 2, canvas.height / 2 - 20);\n            \n            ctx.font = '18px \"PingFang SC\", \"Microsoft YaHei\", sans-serif';\n            ctx.fillText(subtitle, canvas.width / 2, canvas.height / 2 + 20);\n        }\n        \n        // 更新分数显示\n        function updateScoreDisplay() {\n            currentScoreElement.textContent = gameState.score;\n            \n            // 更新最高分\n            if (gameState.score > gameState.highScore) {\n                gameState.highScore = gameState.score;\n                localStorage.setItem('snakeHighScore', gameState.highScore);\n            }\n            \n            highScoreElement.textContent = gameState.highScore;\n        }\n        \n        // 游戏结束\n        function gameOver() {\n            gameState.current = 'gameover';\n            \n            if (gameState.gameLoopId) {\n                cancelAnimationFrame(gameState.gameLoopId);\n                gameState.gameLoopId = null;\n            }\n        }\n        \n        // 处理输入\n        function handleInput(key, pressed) {\n            if (!pressed) return;\n            \n            switch (key) {\n                case 'ArrowUp':\n                case 'w':\n                case 'W':\n                    if (snake.direction !== 'down') {\n                        snake.nextDirection = 'up';\n                    }\n                    break;\n                case 'ArrowDown':\n                case 's':\n                case 'S':\n                    if (snake.direction !== 'up') {\n                        snake.nextDirection = 'down';\n                    }\n                    break;\n                case 'ArrowLeft':\n                case 'a':\n                case 'A':\n                    if (snake.direction !== 'right') {\n                        snake.nextDirection = 'left';\n                    }\n                    break;\n                case 'ArrowRight':\n                case 'd':\n                case 'D':\n                    if (snake.direction !== 'left') {\n                        snake.nextDirection = 'right';\n                    }\n                    break;\n                case ' ':\n                    // 空格键处理\n                    if (gameState.current === 'menu' || gameState.current === 'gameover') {\n                        initGame();\n                    } else if (gameState.current === 'playing') {\n                        gameState.current = 'paused';\n                    } else if (gameState.current === 'paused') {\n                        gameState.current = 'playing';\n                        gameState.lastUpdateTime = performance.now();\n                    }\n                    break;\n            }\n        }\n        \n        // 游戏循环\n        function gameLoop(currentTime) {\n            gameState.gameLoopId = requestAnimationFrame(gameLoop);\n            \n            const deltaTime = currentTime - gameState.lastUpdateTime;\n            \n            // 控制游戏速度\n            if (deltaTime >= snake.speed) {\n                update(deltaTime);\n                gameState.lastUpdateTime = currentTime;\n            }\n            \n            render();\n        }\n        \n        // 键盘事件监听\n        document.addEventListener('keydown', (e) => {\n            handleInput(e.key, true);\n            \n            // 阻止方向键滚动页面\n            if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight', ' '].includes(e.key)) {\n                e.preventDefault();\n            }\n        });\n        \n        // 初始化显示\n        updateScoreDisplay();\n        \n        // 开始游戏循环（显示菜单）\n        gameState.gameLoopId = requestAnimationFrame(gameLoop);\n    </script>\n</body>\n</html>",
