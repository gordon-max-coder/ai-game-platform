      "prompt": "请创建一个完整的 HTML5 游戏。游戏描述：要保持贪食蛇游戏基本规则，只能走直线。\n                    \n重要技术要求：\n1. 单个 HTML 文件\n2. 使用 Canvas API\n3. Canvas 尺寸必须为 360x640 像素（9:16 竖屏比例）\n4. 在 JavaScript 中设置：canvas.width = 360; canvas.height = 640;\n5. 在 CSS 中设置：canvas { max-width: 100%; height: auto; display: block; margin: 0 auto; }\n6. 包含完整游戏循环\n7. 有得分系统\n8. 确保有趣可玩\n\n只返回 HTML 代码，不要其他说明。",
      "code": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>贪吃蛇</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            min-height: 100vh;\n            background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);\n            font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;\n            overflow: hidden;\n        }\n        \n        #game-container {\n            position: relative;\n            width: 360px;\n            height: 640px;\n            border-radius: 12px;\n            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);\n            overflow: hidden;\n        }\n        \n        #gameCanvas {\n            display: block;\n            margin: 0 auto;\n            background: transparent;\n        }\n        \n        #ui-overlay {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n        }\n        \n        .ui-screen {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            background: rgba(0, 0, 0, 0.7);\n            color: white;\n            pointer-events: auto;\n            transition: opacity 0.3s;\n        }\n        \n        .hidden {\n            opacity: 0;\n            pointer-events: none;\n        }\n        \n        h1 {\n            font-size: 36px;\n            margin-bottom: 20px;\n            color: #4fd1c5;\n            text-shadow: 0 2px 10px rgba(79, 209, 197, 0.3);\n        }\n        \n        .score-display {\n            position: absolute;\n            top: 20px;\n            left: 0;\n            width: 100%;\n            text-align: center;\n            font-size: 20px;\n            color: white;\n            z-index: 10;\n        }\n        \n        .score-value {\n            color: #4fd1c5;\n            font-weight: bold;\n        }\n        \n        .high-score {\n            position: absolute;\n            top: 50px;\n            left: 0;\n            width: 100%;\n            text-align: center;\n            font-size: 16px;\n            color: rgba(255, 255, 255, 0.7);\n        }\n        \n        button {\n            background: linear-gradient(135deg, #4fd1c5 0%, #38b2ac 100%);\n            color: white;\n            border: none;\n            border-radius: 12px;\n            padding: 15px 40px;\n            font-size: 18px;\n            font-weight: bold;\n            margin: 10px;\n            cursor: pointer;\n            transition: transform 0.2s, box-shadow 0.2s;\n            box-shadow: 0 4px 15px rgba(79, 209, 197, 0.3);\n        }\n        \n        button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 20px rgba(79, 209, 197, 0.4);\n        }\n        \n        button:active {\n            transform: translateY(0);\n        }\n        \n        .instructions {\n            margin: 30px 0;\n            text-align: center;\n            color: rgba(255, 255, 255, 0.8);\n            line-height: 1.6;\n            max-width: 300px;\n        }\n        \n        .game-over-stats {\n            margin: 20px 0;\n            text-align: center;\n            font-size: 18px;\n        }\n        \n        .final-score {\n            color: #4fd1c5;\n            font-size: 32px;\n            font-weight: bold;\n            margin: 10px 0;\n        }\n        \n        .controls-hint {\n            position: absolute;\n            bottom: 20px;\n            left: 0;\n            width: 100%;\n            text-align: center;\n            font-size: 14px;\n            color: rgba(255, 255, 255, 0.5);\n        }\n    </style>\n</head>\n<body>\n    <div id=\"game-container\">\n        <canvas id=\"gameCanvas\" width=\"360\" height=\"640\"></canvas>\n        \n        <div class=\"score-display\">\n            得分: <span id=\"score\" class=\"score-value\">0</span>\n        </div>\n        \n        <div class=\"high-score\">\n            最高分: <span id=\"highScore\">0</span>\n        </div>\n        \n        <div id=\"ui-overlay\">\n            <!-- 菜单界面 -->\n            <div id=\"menu-screen\" class=\"ui-screen\">\n                <h1>贪吃蛇</h1>\n                <div class=\"instructions\">\n                    使用方向键控制蛇移动<br>\n                    吃到食物可以增长并得分<br>\n                    撞到墙壁或自己则游戏结束\n                </div>\n                <button id=\"start-btn\">开始游戏</button>\n                <div class=\"controls-hint\">按 Enter 开始游戏</div>\n            </div>\n            \n            <!-- 暂停界面 -->\n            <div id=\"pause-screen\" class=\"ui-screen hidden\">\n                <h1>游戏暂停</h1>\n                <button id=\"resume-btn\">继续游戏</button>\n                <button id=\"restart-btn\">重新开始</button>\n                <div class=\"controls-hint\">按 P 暂停/继续</div>\n            </div>\n            \n            <!-- 游戏结束界面 -->\n            <div id=\"gameover-screen\" class=\"ui-screen hidden\">\n                <h1>游戏结束</h1>\n                <div class=\"game-over-stats\">\n                    <div>最终得分</div>\n                    <div id=\"final-score\" class=\"final-score\">0</div>\n                </div>\n                <button id=\"play-again-btn\">再玩一次</button>\n                <button id=\"menu-btn\">返回菜单</button>\n                <div class=\"controls-hint\">按 Enter 重新开始</div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // 游戏常量\n        const CANVAS_WIDTH = 360;\n        const CANVAS_HEIGHT = 640;\n        const GRID_SIZE = 15;\n        const GAME_AREA_SIZE = 300;\n        const GAME_AREA_X = (CANVAS_WIDTH - GAME_AREA_SIZE) / 2;\n        const GAME_AREA_Y = 100;\n        const GAME_AREA_ROWS = GAME_AREA_SIZE / GRID_SIZE;\n        const GAME_AREA_COLS = GAME_AREA_SIZE / GRID_SIZE;\n        \n        // 游戏状态\n        const GAME_STATES = {\n            MENU: 'menu',\n            PLAYING: 'playing',\n            PAUSED: 'paused',\n            GAMEOVER: 'gameover'\n        };\n        \n        // 方向\n        const DIRECTIONS = {\n            UP: { x: 0, y: -1 },\n            DOWN: { x: 0, y: 1 },\n            LEFT: { x: -1, y: 0 },\n            RIGHT: { x: 1, y: 0 }\n        };\n        \n        // 游戏变量\n        let canvas, ctx;\n        let gameState = GAME_STATES.MENU;\n        let score = 0;\n        let highScore = 0;\n        let snake = [];\n        let food = null;\n        let direction = DIRECTIONS.RIGHT;\n        let nextDirection = DIRECTIONS.RIGHT;\n        let lastUpdateTime = 0;\n        let updateInterval = 150; // 蛇移动间隔(ms)\n        let gameLoopId = null;\n        \n        // DOM元素\n        let scoreElement, highScoreElement, finalScoreElement;\n        let menuScreen, pauseScreen, gameoverScreen;\n        \n        // 初始化游戏\n        function init() {\n            canvas = document.getElementById('gameCanvas');\n            ctx = canvas.getContext('2d');\n            \n            // 获取DOM元素\n            scoreElement = document.getElementById('score');\n            highScoreElement = document.getElementById('highScore');\n            finalScoreElement = document.getElementById('final-score');\n            menuScreen = document.getElementById('menu-screen');\n            pauseScreen = document.getElementById('pause-screen');\n            gameoverScreen = document.getElementById('gameover-screen');\n            \n            // 加载最高分\n            highScore = parseInt(localStorage.getItem('snakeHighScore')) || 0;\n            highScoreElement.textContent = highScore;\n            \n            // 设置事件监听器\n            setupEventListeners();\n            \n            // 开始游戏循环\n            gameLoopId = requestAnimationFrame(gameLoop);\n        }\n        \n        // 设置事件监听器\n        function setupEventListeners() {\n            // 键盘输入\n            document.addEventListener('keydown', handleKeyDown);\n            \n            // 按钮点击\n            document.getElementById('start-btn').addEventListener('click', startGame);\n            document.getElementById('resume-btn').addEventListener('click', resumeGame);\n            document.getElementById('restart-btn').addEventListener('click', restartGame);\n            document.getElementById('play-again-btn').addEventListener('click', restartGame);\n            document.getElementById('menu-btn').addEventListener('click', showMenu);\n        }\n        \n        // 处理键盘输入\n        function handleKeyDown(e) {\n            if (gameState === GAME_STATES.PLAYING) {\n                switch (e.key) {\n                    case 'ArrowUp':\n                        if (direction !== DIRECTIONS.DOWN) {\n                            nextDirection = DIRECTIONS.UP;\n                        }\n                        e.preventDefault();\n                        break;\n                    case 'ArrowDown':\n                        if (direction !== DIRECTIONS.UP) {\n                            nextDirection = DIRECTIONS.DOWN;\n                        }\n                        e.preventDefault();\n                        break;\n                    case 'ArrowLeft':\n                        if (direction !== DIRECTIONS.RIGHT) {\n                            nextDirection = DIRECTIONS.LEFT;\n                        }\n                        e.preventDefault();\n                        break;\n                    case 'ArrowRight':\n                        if (direction !== DIRECTIONS.LEFT) {\n                            nextDirection = DIRECTIONS.RIGHT;\n                        }\n                        e.preventDefault();\n                        break;\n                    case 'p':\n                    case 'P':\n                        togglePause();\n                        e.preventDefault();\n                        break;\n                }\n            } else if (gameState === GAME_STATES.MENU) {\n                if (e.key === 'Enter') {\n                    startGame();\n                    e.preventDefault();\n                }\n            } else if (gameState === GAME_STATES.PAUSED) {\n                if (e.key === 'p' || e.key === 'P') {\n                    togglePause();\n                    e.preventDefault();\n                }\n            } else if (gameState === GAME_STATES.GAMEOVER) {\n                if (e.key === 'Enter') {\n                    restartGame();\n                    e.preventDefault();\n                }\n            }\n        }\n        \n        // 开始游戏\n        function startGame() {\n            // 初始化蛇\n            snake = [\n                { x: 5, y: 10 },\n                { x: 4, y: 10 },\n                { x: 3, y: 10 }\n            ];\n            \n            // 初始化方向\n            direction = DIRECTIONS.RIGHT;\n            nextDirection = DIRECTIONS.RIGHT;\n            \n            // 初始化分数\n            score = 0;\n            scoreElement.textContent = score;\n            \n            // 生成食物\n            generateFood();\n            \n            // 切换到游戏状态\n            gameState = GAME_STATES.PLAYING;\n            menuScreen.classList.add('hidden');\n            gameoverScreen.classList.add('hidden');\n            \n            // 重置更新时间\n            lastUpdateTime = performance.now();\n        }\n        \n        // 重新开始游戏\n        function restartGame() {\n            startGame();\n            pauseScreen.classList.add('hidden');\n            gameoverScreen.classList.add('hidden');\n        }\n        \n        // 返回菜单\n        function showMenu() {\n            gameState = GAME_STATES.MENU;\n            menuScreen.classList.remove('hidden');\n            gameoverScreen.classList.add('hidden');\n            pauseScreen.classList.add('hidden');\n        }\n        \n        // 切换暂停状态\n        function togglePause() {\n            if (gameState === GAME_STATES.PLAYING) {\n                gameState = GAME_STATES.PAUSED;\n                pauseScreen.classList.remove('hidden');\n            } else if (gameState === GAME_STATES.PAUSED) {\n                gameState = GAME_STATES.PLAYING;\n                pauseScreen.classList.add('hidden');\n                lastUpdateTime = performance.now();\n            }\n        }\n        \n        // 继续游戏\n        function resumeGame() {\n            gameState = GAME_STATES.PLAYING;\n            pauseScreen.classList.add('hidden');\n            lastUpdateTime = performance.now();\n        }\n        \n        // 生成食物\n        function generateFood() {\n            let validPosition = false;\n            let newFood;\n            \n            while (!validPosition) {\n                newFood = {\n                    x: Math.floor(Math.random() * GAME_AREA_COLS),\n                    y: Math.floor(Math.random() * GAME_AREA_ROWS)\n                };\n                \n                // 检查食物是否生成在蛇身上\n                validPosition = true;\n                for (let segment of snake) {\n                    if (segment.x === newFood.x && segment.y === newFood.y) {\n                        validPosition = false;\n                        break;\n                    }\n                }\n            }\n            \n            food = newFood;\n        }\n        \n        // 游戏逻辑更新\n        function update(deltaTime) {\n            if (gameState !== GAME_STATES.PLAYING) return;\n            \n            // 更新方向\n            direction = nextDirection;\n            \n            // 计算新的头部位置\n            const head = snake[0];\n            const newHead = {\n                x: head.x + direction.x,\n                y: head.y + direction.y\n            };\n            \n            // 检查碰撞\n            if (checkCollision(newHead)) {\n                gameOver();\n                return;\n            }\n            \n            // 移动蛇\n            snake.unshift(newHead);\n            \n            // 检查是否吃到食物\n            if (newHead.x === food.x && newHead.y === food.y) {\n                // 吃到食物，增加分数\n                score += 10;\n                scoreElement.textContent = score;\n                \n                // 生成新食物\n                generateFood();\n                \n                // 加速（可选）\n                if (updateInterval > 50) {\n                    updateInterval -= 2;\n                }\n            } else {\n                // 没吃到食物，移除尾部\n                snake.pop();\n            }\n        }\n        \n        // 检查碰撞\n        function checkCollision(position) {\n            // 检查墙壁碰撞\n            if (position.x < 0 || position.x >= GAME_AREA_COLS || \n                position.y < 0 || position.y >= GAME_AREA_ROWS) {\n                return true;\n            }\n            \n            // 检查自身碰撞（从第二个身体部分开始检查）\n            for (let i = 1; i < snake.length; i++) {\n                if (position.x === snake[i].x && position.y === snake[i].y) {\n                    return true;\n                }\n            }\n            \n            return false;\n        }\n        \n        // ��戏结束\n        function gameOver() {\n            gameState = GAME_STATES.GAMEOVER;\n            \n            // 更新最高分\n            if (score > highScore) {\n                highScore = score;\n                localStorage.setItem('snakeHighScore', highScore);\n                highScoreElement.textContent = highScore;\n            }\n            \n            // 显示游戏结束界面\n            finalScoreElement.textContent = score;\n            gameoverScreen.classList.remove('hidden');\n        }\n        \n        // 游戏渲染\n        function render() {\n            // 清空画布\n            ctx.clearRect(0, 0, CANVAS_WIDTH, CANVAS_HEIGHT);\n            \n            // 绘制游戏区域背景\n            ctx.fillStyle = 'rgba(0, 0, 0, 0.3)';\n            ctx.fillRect(GAME_AREA_X, GAME_AREA_Y, GAME_AREA_SIZE, GAME_AREA_SIZE);\n            \n            // 绘制网格线\n            ctx.strokeStyle = 'rgba(255, 255, 255, 0.05)';\n            ctx.lineWidth = 1;\n            \n            for (let i = 0; i <= GAME_AREA_COLS; i++) {\n                ctx.beginPath();\n                ctx.moveTo(GAME_AREA_X + i * GRID_SIZE, GAME_AREA_Y);\n                ctx.lineTo(GAME_AREA_X + i * GRID_SIZE, GAME_AREA_Y + GAME_AREA_SIZE);\n                ctx.stroke();\n            }\n            \n            for (let i = 0; i <= GAME_AREA_ROWS; i++) {\n                ctx.beginPath();\n                ctx.moveTo(GAME_AREA_X, GAME_AREA_Y + i * GRID_SIZE);\n                ctx.lineTo(GAME_AREA_X + GAME_AREA_SIZE, GAME_AREA_Y + i * GRID_SIZE);\n                ctx.stroke();\n            }\n            \n            // 绘制游戏区域边框\n            ctx.strokeStyle = 'rgba(79, 209, 197, 0.5)';\n            ctx.lineWidth = 2;\n            ctx.strokeRect(GAME_AREA_X, GAME_AREA_Y, GAME_AREA_SIZE, GAME_AREA_SIZE);\n            \n            if (gameState === GAME_STATES.PLAYING || gameState === GAME_STATES.PAUSED) {\n                // 绘制食物\n                if (food) {\n                    const foodX = GAME_AREA_X + food.x * GRID_SIZE + GRID_SIZE / 2;\n                    const foodY = GAME_AREA_Y + food.y * GRID_SIZE + GRID_SIZE / 2;\n                    \n                    ctx.beginPath();\n                    ctx.arc(foodX, foodY, GRID_SIZE / 2 - 2, 0, Math.PI * 2);\n                    ctx.fillStyle = '#ff6b6b';\n                    ctx.fill();\n                    ctx.strokeStyle = '#ff8e8e';\n                    ctx.lineWidth = 2;\n                    ctx.stroke();\n                }\n                \n                // 绘制蛇\n                for (let i = 0; i < snake.length; i++) {\n                    const segment = snake[i];\n                    const x = GAME_AREA_X + segment.x * GRID_SIZE;\n                    const y = GAME_AREA_Y + segment.y * GRID_SIZE;\n                    \n                    // 蛇头颜色不同\n                    if (i === 0) {\n                        ctx.fillStyle = '#4fd1c5';\n                    } else {\n                        // 蛇身渐变效果\n                        const greenValue = Math.max(100, 200 - i * 5);\n                        ctx.fillStyle = `rgb(50, ${greenValue}, 150)`;\n                    }\n                    \n                    // 绘制圆角矩形\n                    const radius = 4;\n                    ctx.beginPath();\n                    ctx.moveTo(x + radius, y);\n                    ctx.lineTo(x + GRID_SIZE - radius, y);\n                    ctx.quadraticCurveTo(x + GRID_SIZE, y, x + GRID_SIZE, y + radius);\n                    ctx.lineTo(x + GRID_SIZE, y + GRID_SIZE - radius);\n                    ctx.quadraticCurveTo(x + GRID_SIZE, y + GRID_SIZE, x + GRID_SIZE - radius, y + GRID_SIZE);\n                    ctx.lineTo(x + radius, y + GRID_SIZE);\n                    ctx.quadraticCurveTo(x, y + GRID_SIZE, x, y + GRID_SIZE - radius);\n                    ctx.lineTo(x, y + radius);\n                    ctx.quadraticCurveTo(x, y, x + radius, y);\n                    ctx.closePath();\n                    ctx.fill();\n                    \n                    // 蛇头添加眼睛\n                    if (i === 0) {\n                        ctx.fillStyle = 'white';\n                        \n                        // 根据方向调整眼睛位置\n                        let eyeOffsetX = 0, eyeOffsetY = 0;\n                        if (direction === DIRECTIONS.RIGHT) {\n                            eyeOffsetX = 3;\n                        } else if (direction === DIRECTIONS.LEFT) {\n                            eyeOffsetX = -3;\n                        } else if (direction === DIRECTIONS.UP) {\n                            eyeOffsetY = -3;\n                        } else if (direction === DIRECTIONS.DOWN) {\n                            eyeOffsetY = 3;\n                        }\n                        \n                        // 左眼\n                        ctx.beginPath();\n                        ctx.arc(x + GRID_SIZE / 2 - 3 + eyeOffsetX, y + GRID_SIZE / 2 - 2 + eyeOffsetY, 2, 0, Math.PI * 2);\n                        ctx.fill();\n                        \n                        // 右眼\n                        ctx.beginPath();\n                        ctx.arc(x + GRID_SIZE / 2 + 3 + eyeOffsetX, y + GRID_SIZE / 2 - 2 + eyeOffsetY, 2, 0, Math.PI * 2);\n                        ctx.fill();\n                    }\n                }\n            }\n        }\n        \n        // 游戏主循环\n        function gameLoop(currentTime) {\n            // 计算时间增量\n            const deltaTime = currentTime - lastUpdateTime;\n            \n            // 按固定间隔更新游戏逻辑\n            if (deltaTime >= updateInterval) {\n                update(deltaTime);\n                lastUpdateTime = currentTime;\n            }\n            \n            // 渲染游戏\n            render();\n            \n            // 继续循环\n            gameLoopId = requestAnimationFrame(gameLoop);\n        }\n        \n        // 页面加载完成后初始化游戏\n        window.addEventListener('load', init);\n    </script>\n</body>\n</html>",
